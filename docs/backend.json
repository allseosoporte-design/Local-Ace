{
  "entities": {
    "Business": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Business",
      "type": "object",
      "description": "Represents a business using the Local Leap platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Business entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the business."
        },
        "address": {
          "type": "string",
          "description": "Address of the business."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Phone number of the business."
        },
        "websiteUrl": {
          "type": "string",
          "description": "Website URL of the business.",
          "format": "uri"
        },
        "googleMapsUrl": {
          "type": "string",
          "description": "Google Maps URL of the business.",
          "format": "uri"
        },
        "industryCategory": {
          "type": "string",
          "description": "Category of the business's industry (e.g., Restaurant, Retail)."
        },
        "subscriptionPlanId": {
          "type": "string",
          "description": "Reference to SubscriptionPlan. (Relationship: SubscriptionPlan 1:N Business)"
        }
      },
      "required": [
        "id",
        "name",
        "address",
        "phoneNumber",
        "websiteUrl",
        "googleMapsUrl",
        "industryCategory",
        "subscriptionPlanId"
      ]
    },
    "Review": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Review",
      "type": "object",
      "description": "Represents a customer review of a business.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Review entity."
        },
        "businessId": {
          "type": "string",
          "description": "Reference to Business. (Relationship: Business 1:N Review)"
        },
        "rating": {
          "type": "number",
          "description": "Rating given by the customer (1-5 stars)."
        },
        "comment": {
          "type": "string",
          "description": "Textual comment provided by the customer."
        },
        "reviewDate": {
          "type": "string",
          "description": "Date and time when the review was submitted.",
          "format": "date-time"
        },
        "isFiltered": {
          "type": "boolean",
          "description": "Indicates whether the review was filtered (1-4 stars)."
        },
        "customerName": {
          "type": "string",
          "description": "Name of the customer who submitted the review."
        },
        "customerEmail": {
          "type": "string",
          "description": "Email of the customer who submitted the review.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "businessId",
        "rating",
        "reviewDate",
        "isFiltered"
      ]
    },
    "GoogleBusinessProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "GoogleBusinessProfile",
      "type": "object",
      "description": "Represents a Google Business Profile listing.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the GoogleBusinessProfile entity."
        },
        "businessId": {
          "type": "string",
          "description": "Reference to Business. (Relationship: Business 1:1 GoogleBusinessProfile)"
        },
        "profileName": {
          "type": "string",
          "description": "Name of the business as it appears on Google."
        },
        "categoryIds": {
          "type": "array",
          "description": "References to Categories. (Relationship: Category N:N GoogleBusinessProfile)",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string",
          "description": "Description of the business on Google."
        },
        "latitude": {
          "type": "number",
          "description": "Latitude coordinate of the business location."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude coordinate of the business location."
        }
      },
      "required": [
        "id",
        "businessId",
        "profileName",
        "latitude",
        "longitude"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Represents a category for Google Business Profile listings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Category entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the category."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a post on a Google Business Profile.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Post entity."
        },
        "googleBusinessProfileId": {
          "type": "string",
          "description": "Reference to GoogleBusinessProfile. (Relationship: GoogleBusinessProfile 1:N Post)"
        },
        "title": {
          "type": "string",
          "description": "Title of the post."
        },
        "content": {
          "type": "string",
          "description": "Content of the post."
        },
        "postDateTime": {
          "type": "string",
          "description": "Date and time the post was published.",
          "format": "date-time"
        },
        "imageUrl": {
          "type": "string",
          "description": "URL of the image associated with the post.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "googleBusinessProfileId",
        "title",
        "content",
        "postDateTime"
      ]
    },
    "LandingPage": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LandingPage",
      "type": "object",
      "description": "Represents a landing page created for a business.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the LandingPage entity."
        },
        "businessId": {
          "type": "string",
          "description": "Reference to Business. (Relationship: Business 1:N LandingPage)"
        },
        "title": {
          "type": "string",
          "description": "Title of the landing page."
        },
        "description": {
          "type": "string",
          "description": "Description on the landing page."
        },
        "logoUrl": {
          "type": "string",
          "description": "URL of the logo displayed on the landing page.",
          "format": "uri"
        },
        "primaryColor": {
          "type": "string",
          "description": "Primary color used in the landing page design (e.g., #4285F4)."
        },
        "contactFormId": {
          "type": "string",
          "description": "Reference to ContactForm. (Relationship: ContactForm 1:1 LandingPage)"
        }
      },
      "required": [
        "id",
        "businessId",
        "title",
        "description"
      ]
    },
    "SubscriptionPlan": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SubscriptionPlan",
      "type": "object",
      "description": "Represents a subscription plan for the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the SubscriptionPlan entity."
        },
        "name": {
          "type": "string",
          "description": "Name of the subscription plan (e.g., Basic, Premium)."
        },
        "price": {
          "type": "number",
          "description": "Price of the subscription plan (monthly or annually)."
        },
        "locationLimit": {
          "type": "number",
          "description": "Maximum number of locations allowed for this plan."
        },
        "featureSet": {
          "type": "array",
          "description": "List of features included in this subscription plan.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "locationLimit"
      ]
    },
    "ContactForm": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ContactForm",
      "type": "object",
      "description": "Represents a contact form associated with a landing page.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ContactForm entity."
        },
        "fields": {
          "type": "array",
          "description": "Array of fields to be displayed in the Contact Form",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "id"
      ]
    },
    "PaymentSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PaymentSettings",
      "type": "object",
      "description": "Represents the payment settings for a specific subscription plan.",
      "properties": {
        "nequi": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "qrImageUrl": { "type": "string", "format": "uri" },
            "accountNumber": { "type": "string" },
            "holderName": { "type": "string" },
            "idDocument": { "type": "string" },
            "phone": { "type": "string" },
            "isMainQR": { "type": "boolean" },
            "instructions": { "type": "string" }
          }
        },
        "bancolombia": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "qrImageUrl": { "type": "string", "format": "uri" },
            "accountNumber": { "type": "string" },
            "holderName": { "type": "string" },
            "idDocument": { "type": "string" },
            "phone": { "type": "string" },
            "isMainQR": { "type": "boolean" },
            "instructions": { "type": "string" }
          }
        },
        "stripe": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "publicKey": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "mercadoPago": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "accessToken": { "type": "string" },
            "publicKey": { "type": "string" },
            "mode": { "type": "string", "enum": ["production", "sandbox"] },
            "instructions": { "type": "string" }
          }
        }
      }
    },
    "SuperAdmin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SuperAdmin",
      "type": "object",
      "description": "Represents a super administrator with full access to the platform.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "lastName"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": { "$ref": "#/entities/Business" },
      "description": "Stores business entities.  `businessId` is the unique identifier for each business."
    },
    "/businesses/{businessId}/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Stores reviews associated with a business. Includes denormalized business information as necessary for authorization independence."
    },
    "/businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}": {
      "schema": { "$ref": "#/entities/GoogleBusinessProfile" },
      "description": "Stores Google Business Profiles associated with a business."
    },
    "/businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores posts associated with a Google Business Profile."
    },
    "/businesses/{businessId}/landingPages/{landingPageId}": {
      "schema": { "$ref": "#/entities/LandingPage" },
      "description": "Stores landing pages associated with a business."
    },
    "/businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}": {
      "schema": { "$ref": "#/entities/ContactForm" },
      "description": "Stores contact forms associated with a landing page."
    },
    "/subscriptionPlans/{subscriptionPlanId}": {
      "schema": { "$ref": "#/entities/SubscriptionPlan" },
      "description": "Stores subscription plan details."
    },
    "/paymentSettings/{planSettingsId}": {
      "schema": { "$ref": "#/entities/PaymentSettings" },
      "description": "Stores payment gateway settings for each subscription plan. `planSettingsId` could be 'plan_starter', 'plan_professional', etc."
    },
    "/superAdmins/{superAdminId}": {
      "schema": { "$ref": "#/entities/SuperAdmin" },
      "description": "Stores super administrator user profiles."
    }
  }
}

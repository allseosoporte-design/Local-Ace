/**
 * @fileOverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model, with super admins having broad access and businesses having more restricted access to their own data.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles. Super admins have elevated privileges.
 * - /businesses/{businessId}: Stores business profiles, owned by super admins.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for businesses.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for businesses.
 * - /subscriptionPlans/{planId}: Stores subscription plans available to businesses.
 *
 * Key Security Decisions:
 * - Super admins can manage businesses and view reviews/landingPages associated with those businesses.
 * - Businesses do not have individual user accounts. They are managed by SuperAdmins.
 * - Subscription plans are publicly readable but only writable by authenticated users.
 *
 * Denormalization for Authorization:
 * - Business documents include a `superAdminId` field to avoid needing to `get()` the super admin document for authorization. This enables fast and efficient security checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows super admins to manage their own profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (get, list) Request from a super admin to read their own profile.
     * @deny (create, update, delete) Request to create, update, or delete a profile that doesn't match the authenticated user's ID.
     * @principle Enforces document ownership for super admin profiles.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSignedIn() && isOwner(superAdminId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(superAdminId);
      allow update: if isSignedIn() && isOwner(superAdminId);
      allow delete: if false;
    }

    /**
     * @description Allows super admins to manage businesses they own.
     * @path /businesses/{businessId}
     * @allow (create) Request from a super admin to create a new business with their ID in the `superAdminId` field.
     * @allow (get, list, update, delete) Request from a super admin to manage a business they own (based on the `superAdminId` field).
     * @deny (create, update, delete) Request to create, update, or delete a business if the user is not a super admin or doesn't own the business.
     * @principle Enforces ownership of business profiles by super admins.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows super admins to manage reviews associated with businesses they own.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) Request from a super admin to read reviews for a business they own.
     * @allow (create, update, delete) Request from a super admin to create, update, or delete reviews for a business they own.
     * @deny (create, update, delete) Request to manage reviews if the user is not a super admin or doesn't own the associated business.
     * @principle Enforces ownership of reviews through the parent business.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows super admins to manage landing pages associated with businesses they own.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) Request from a super admin to read landing pages for a business they own.
     * @allow (create, update, delete) Request from a super admin to create, update, or delete landing pages for a business they own.
     * @deny (create, update, delete) Request to manage landing pages if the user is not a super admin or doesn't own the associated business.
     * @principle Enforces ownership of landing pages through the parent business.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

     /**
      * @description Allows public read access to subscription plans, with write access restricted to authenticated users.
      * @path /subscriptionPlans/{planId}
      * @allow (get, list) Any user (authenticated or not) can read the subscription plans.
      * @allow (create, update, delete) Authenticated users can create, update, or delete subscription plans.
      * @deny (create, update, delete) Non-authenticated users cannot create, update, or delete subscription plans.
      * @principle Allows public read access for subscription plans while restricting write access to authenticated users.
      */
    match /subscriptionPlans/{planId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
  }
}
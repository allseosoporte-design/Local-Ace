/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-ownership model, ensuring that users can only access data related to their associated business.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, linking their auth UID to their businessId.
 * - /businesses/{businessId}: Root collection for all business-related data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Stores internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information (publicly readable).
 *
 * Key Security Decisions:
 * - User profiles can only be created by the user themselves (self-creation) and are linked to a business.
 * - All business-related data (GMB profiles, reviews, posts, landing pages, feedback) is secured by businessId, ensuring only authorized users can access it.
 * - Subscriptions are publicly readable.
 * - Listing of user profiles is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - GoogleMyBusinessProfile documents include a businessId field for independent authorization checks.
 * - Reviews, AutomatedPosts are stored as subcollections of GoogleMyBusinessProfile, but they *also* rely on the googleMyBusinessProfileId field within the document for data integrity validation on create.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profile data, linking auth ID to business ID.
     * @path /users/{userId}
     * @allow (create) - A user can create their own profile if the userId matches their auth UID.
     * @allow (get) - A user can read their own profile.
     * @allow (update) - A user can update their own profile if the userId matches their auth UID and the businessId is immutable.
     * @allow (delete) - A user can delete their own profile if the userId matches their auth UID.
     * @deny (list) - Listing user profiles is not allowed.
     * @deny (create) - A user cannot create a profile for another user.
     * @deny (update) - A user cannot update another user's profile.
     * @deny (delete) - A user cannot delete another user's profile.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree, and validates relational integrity between documents.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.businessId is string && request.auth.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.businessId == resource.data.businessId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Manages business information.  Root collection for all business-related data.
     * @path /businesses/{businessId}
     * @allow (get) - Any authenticated user can read a business's information.
     * @allow (create) - Any authenticated user can create a business.
     * @allow (update) - Only the business administrator can update the business information.
     * @allow (delete) - Only the business administrator can delete the business.
     * @deny (list) - Listing businesses is not allowed.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages Google My Business profile information.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get) - Any authenticated user can read a GMB profile.
     * @allow (create) - Only the business administrator can create a GMB profile for their business.
     * @allow (update) - Only the business administrator can update their business's GMB profile.
     * @allow (delete) - Only the business administrator can delete their business's GMB profile.
     * @deny (list) - Listing GMB profiles is not allowed.
     * @principle Enforces business ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId is string;  // Added check for businessId on create
      allow update: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages customer reviews for a Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get) - Any authenticated user can read a review.
     * @allow (create) - Only the business administrator can create a review for their business's GMB profile.
     * @allow (update) - Only the business administrator can update a review for their business's GMB profile.
     * @allow (delete) - Only the business administrator can delete a review for their business's GMB profile.
     * @deny (list) - Listing reviews is not allowed.
     * @principle Enforces business ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.googleMyBusinessProfileId == googleMyBusinessProfileId; //ensures referential integrity
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages internal feedback collected from customers.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (get) - Any authenticated user can read internal feedback for a business.
     * @allow (create) - Only the business administrator can create internal feedback for their business.
     * @allow (update) - Only the business administrator can update internal feedback for their business.
     * @allow (delete) - Only the business administrator can delete internal feedback for their business.
     * @deny (list) - Listing internal feedback is not allowed.
     * @principle Enforces business ownership for writes and allows public read access.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages automated posts scheduled for a Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get) - Any authenticated user can read an automated post.
     * @allow (create) - Only the business administrator can create an automated post for their business's GMB profile.
     * @allow (update) - Only the business administrator can update an automated post for their business's GMB profile.
     * @allow (delete) - Only the business administrator can delete an automated post for their business's GMB profile.
     * @deny (list) - Listing automated posts is not allowed.
     * @principle Enforces business ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.googleMyBusinessProfileId == googleMyBusinessProfileId; //ensures referential integrity
      allow update: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages landing pages created for a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get) - Any authenticated user can read a landing page for a business.
     * @allow (create) - Only the business administrator can create a landing page for their business.
     * @allow (update) - Only the business administrator can update a landing page for their business.
     * @allow (delete) - Only the business administrator can delete a landing page for their business.
     * @deny (list) - Listing landing pages is not allowed.
     * @principle Enforces business ownership for writes and allows public read access.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if isSignedIn();  // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Manages subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) - Any user can read subscription plan information.
     * @deny (create) - No user can create subscription plans via the client.
     * @deny (update) - No user can update subscription plans via the client.
     * @deny (delete) - No user can delete subscription plans via the client.
     * @allow (list) - Any user can list subscription plans.
     * @principle Allows public read access and restricts write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @fileOverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model with super-admin privileges.
 * Super admins have full access to businesses, reviews, and landing pages.
 * The rules leverage path-based ownership and denormalization to optimize security and performance.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Super administrator accounts.
 * - /businesses/{businessId}: Business accounts, each owned by a super admin.
 * - /businesses/{businessId}/reviews/{reviewId}: Reviews associated with a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages associated with a business.
 *
 * Key Security Decisions:
 * - Only authenticated users can access the database.
 * - Super admins can manage all business data (create, read, update, delete).
 * - Data validation is minimized in the prototyping phase to allow for rapid iteration.
 *
 * Denormalization for Authorization:
 * - Each `Business` document stores the `superAdminId` of its owner. This allows rules on `/businesses/{businessId}` to directly check the owner without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to super admin accounts.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - If the authenticated user's ID matches the superAdminId.
     * @deny (create) - If the authenticated user's ID does not match the superAdminId.
     * @allow (get, list) - If the user is authenticated.
     * @deny (get, list) - If the user is not authenticated.
     * @principle Enforces user-ownership for writes and requires authentication for reads.
     */
    match /superAdmins/{superAdminId} {
      // Verified Identity: Only the user with matching id can create
      allow create: if isSignedIn() && isOwner(superAdminId) && request.resource.data.id == superAdminId;
      allow get, list: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to business accounts.
     * @path /businesses/{businessId}
     * @allow (create) - If the user is a super admin.
     * @deny (create) - If the user is not a super admin.
     * @allow (get, list) - If the user is a super admin.
     * @deny (get, list) - If the user is not a super admin.
     * @principle Super admins can manage businesses.
     */
    match /businesses/{businessId} {
      allow create: if isSignedIn() && isSuperAdmin();
      allow get, list: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Controls access to reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) - If the user is a super admin.
     * @deny (create) - If the user is not a super admin.
     * @allow (get, list) - If the user is a super admin.
     * @deny (get, list) - If the user is not a super admin.
     * @principle Super admins can manage reviews for their businesses.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow create: if isSignedIn() && isSuperAdmin();
      allow get, list: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Controls access to landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - If the user is a super admin.
     * @deny (create) - If the user is not a super admin.
     * @allow (get, list) - If the user is a super admin.
     * @deny (get, list) - If the user is not a super admin.
     * @principle Super admins can manage landing pages for their businesses.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow create: if isSignedIn() && isSuperAdmin();
      allow get, list: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isSuperAdmin() {
        return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.id == request.auth.uid;
    }
  }
}
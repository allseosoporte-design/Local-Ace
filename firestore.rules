/**
 * @fileOverview Firestore Security Rules for Prototyping.
 *
 * Core Philosophy:
 * This ruleset prioritizes strict authorization based on user and business ownership,
 * while maintaining flexible data shapes for rapid iteration. It enforces who can
 * access what, but avoids strict schema validation during this prototyping phase.
 *
 * Data Structure:
 * - User profiles are stored under /users/{userId}, linking their auth UID to a businessId.
 * - Business data is stored under /businesses/{businessId}, acting as the root for
 *   all business-related subcollections.
 * - Google My Business profiles, reviews, automated posts, and landing pages are
 *   nested under their respective business or profile.
 * - Internal feedback is nested under businesses.
 * - Subscription plans are stored in a top-level /subscriptions collection.
 *
 * Key Security Decisions:
 * - **Ownership**: Most data is secured using an ownership model, where only the
 *   authenticated user associated with a specific business can create, read, update,
 *   or delete data. This association is maintained via the businessId field in
 *   various documents and subcollections.
 * - **No User Listing**: Listing of users is explicitly denied for privacy.
 * - **Public Subscriptions**: Subscription plans are publicly readable.
 * - **Internal Feedback**: Allows public submissions, but restricts reading to business owners.
 * - **Denormalization**: The `businessId` is denormalized (copied) into subcollections
 *   to allow efficient security rules without complex queries.
 * - **Business ID Lookup**: The `isOwner` function uses the `businessId` stored in the user's profile to authorize requests to resources within that business.
 *
 * Denormalization for Authorization:
 * - The `businessId` is present in `/users/{userId}`, `/businesses/{businessId}`,
 *   `/googleMyBusinessProfiles/{googleMyBusinessProfileId}`, and their subcollections.
 *   This allows for simple, performant authorization checks without needing extra reads.
 *
 * Structural Segregation:
 * - Public subscription plans are stored in a separate top-level collection (/subscriptions)
 *   to allow public read access without compromising the security of private business data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the user is signed in and the userId matches the authenticated user's UID.
     * @deny (list) Listing users is not permitted.
     * @deny (get, create, update, delete) if the user is not signed in, or the userId does not match the authenticated user's UID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows businesses to manage their own information.
     * @path /businesses/{businessId}
     * @allow (get, create, update, delete) if the user is signed in and the businessId matches the user's businessId.
     * @deny (list) Listing businesses is not permitted.
     * @deny (get, create, update, delete) if the user is not signed in, or the businessId does not match the user's businessId.
     * @principle Enforces business ownership for writes.
     */
    match /businesses/{businessId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExisting(businessId) {
          return exists(/databases/$(database)/documents/businesses/$(businessId));
      }

      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isOwner(businessId) && isExisting(businessId);
      allow delete: if isSignedIn() && isOwner(businessId) && isExisting(businessId);
    }

    /**
     * @description Allows businesses to manage their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, create, update, delete) if the user is signed in and the businessId in the profile matches the user's businessId.
     * @deny (list) Listing profiles is not permitted.
     * @deny (get, create, update, delete) if the user is not signed in, or the businessId does not match.
     * @principle Enforces business ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExisting(googleMyBusinessProfileId) {
        return exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      }

      allow get: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.businessId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
      allow update: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow delete: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage customer reviews.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list, create, update, delete) if the user is signed in and associated with the business owning the profile.
     * @deny if the user is not signed in or not associated with the business.
     * @principle Enforces business ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      function isExisting(googleMyBusinessProfileId) {
        return exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)/reviews/$(reviewId));
      }

      allow get: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow list: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow delete: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage internal feedback collected from customers.
     * PUBLIC FORM can create, OWNER can read.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (create) if the businessId in the data matches the businessId in the path (public form).
     * @allow (get, list) if the user is signed in and the businessId matches the user's businessId.
     * @deny (update, delete) No client-side updates or deletes allowed.
     * @principle Public submissions with restricted reads.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      // ✅ CREATE: Anyone can create (public form)
      // Validate that businessId in data matches businessId in path
      allow create: if request.resource.data.businessId == businessId;
      
      // ✅ READ: Only business owner can read
      // Check user's businessId against path businessId
      allow get, list: if request.auth != null && isOwner(businessId);
      
      // ❌ UPDATE/DELETE: Nobody from client
      allow update, delete: if false;
    }

    /**
     * @description Allows businesses to manage automated posts.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list, create, update, delete) if the user is signed in and associated with the business owning the profile.
     * @deny if the user is not signed in or not associated with the business.
     * @principle Enforces business ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      function isExisting(googleMyBusinessProfileId) {
        return exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)/automatedPosts/$(automatedPostId));
      }

      allow get: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow list: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
      allow delete: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId)) && isExisting(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list, create, update, delete) if the user is signed in and associated with the business.
     * @deny if the user is not signed in or not associated with the business.
     * @principle Enforces business ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }
      
      function isExisting(businessId) {
        return exists(/databases/$(database)/documents/businesses/$(businessId)/landingPages/$(landingPageId));
      }

      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isOwner(businessId) && isExisting(businessId);
      allow delete: if isSignedIn() && isOwner(businessId) && isExisting(businessId);
    }

    /**
     * @description Public read access to subscription plans.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Public read access.
     * @deny (create, update, delete) No client-side writes allowed.
     * @principle Public read, owner-only write (backend).
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
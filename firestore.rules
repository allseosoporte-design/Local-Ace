/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict ownership model for businesses and their associated data.
 * All data is nested under /businesses/{businessId}, with some top-level collections for specific entities.
 *
 * Data Structure:
 * - /businesses/{businessId}: Business information, owned by the user who created the business.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Reviews for a GMB profile.
 * - /internalFeedback/{internalFeedbackId}: Internal feedback from customers (top-level collection).
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for a GMB profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for a business.
 * - /subscriptions/{subscriptionId}: Subscription plan information (top-level collection).
 *
 * Key Security Decisions:
 * - Enforces strict ownership for businesses and their associated resources.
 * - Top-level collections like /internalFeedback and /subscriptions have limited write access.
 * - Employs data denormalization to avoid costly `get()` calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId - The user ID to compare against.
     * @return {bool} True if the user is signed in and the UID matches, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document.
     * @param {string} userId - The user ID of the document owner.
     * @return {bool} True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /businesses/{businessId} collection.
     * @path /businesses/{businessId}
     * @allow (create) User 'user_abc' can create a business document where businessId == user_abc.
     * @deny (create) User 'user_def' cannot create a business document for user 'user_abc'.
     * @allow (get, list) Any signed-in user can read a business document.
     * @deny (update, delete) Only the owner of the business can modify or delete it.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      allow get, list: if true;
      allow create: if isOwner(businessId);
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) Signed-in user can create a GMB profile
     * @deny (create) User cannot create a GMB profile if not signed in.
     * @allow (get, list) Any signed-in user can read a GMB profile.
     * @deny (update, delete) Only the owner of the business can modify or delete a GMB profile.
     * @principle Enforces document ownership for writes, requires businessId match.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false; // TODO: Add owner validation once businessId is available.
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list) Any signed-in user can read a review.
     * @deny (create, update, delete) Only the owner of the parent GMB profile can create, update, or delete a review.
     * @principle Enforces document ownership for writes on a subcollection.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once businessId is available in the parent document.
    }

    /**
     * @description Rules for the /internalFeedback/{internalFeedbackId} collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any signed-in user can create internal feedback.
     * @deny (get, list, update, delete) No one can read, list, update, or delete internal feedback.
     * @principle Restricts access to internal feedback data.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow create: if isSignedIn();
      allow get, list, update, delete: if false;
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list) Any signed-in user can read an automated post.
     * @deny (create, update, delete) Only the owner of the parent GMB profile can create, update, or delete an automated post.
     * @principle Enforces document ownership for writes on a subcollection.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once businessId is available in the parent document.
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages/{landingPageId} collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) Any signed-in user can read a landing page.
     * @deny (create, update, delete) Only the owner of the business can create, update, or delete a landing page.
     * @principle Enforces document ownership for writes on a subcollection.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if true;
      allow create, update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for the /subscriptions/{subscriptionId} collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Any signed-in user can read a subscription.
     * @deny (create, update, delete) No one can create, update, or delete a subscription.
     * @principle Restricts access to subscription data.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
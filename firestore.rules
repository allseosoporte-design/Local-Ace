/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Each business can manage its own Google My Business profiles, landing pages, and other related content.
 * Authorization independence is achieved through data denormalization, avoiding `get()` calls in rules.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - All write operations are restricted to authenticated users.
 * - Ownership is enforced for all business-related data, ensuring that only the business owner can modify their data.
 * - Data consistency is enforced between the path and the document's internal fields.
 * - Public read access is not generally permitted, except where explicitly noted.
 *
 * Denormalization for Authorization:
 * The `businessId` is denormalized into the `GoogleMyBusinessProfile` and `LandingPage` entities to avoid `get()` calls
 * when validating access to these resources. This ensures that security rules can validate access based on the
 * `request.auth.uid` without needing to fetch data from parent documents.
 *
 * Structural Segregation:
 * The platform uses dedicated collections for distinct entities (e.g., `/businesses`, `/googleMyBusinessProfiles`, `/landingPages`).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to business documents.
     * @path /businesses/{businessId}
     * @allow (create) User with matching auth.uid can create a business document.
     * @deny (create) User with non-matching auth.uid cannot create a business document.
     * @allow (get, list) Anyone can read business documents.
     * @allow (update, delete) User with matching auth.uid can update or delete the business document.
     * @deny (update, delete) User with non-matching auth.uid cannot update or delete the business document.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(businessId);
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Allows access to Google My Business profile documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User with matching businessId can create a Google My Business profile document.
     * @deny (create) User with non-matching businessId cannot create a Google My Business profile document.
     * @allow (get, list) Anyone can read Google My Business profile documents.
     * @allow (update, delete) User with matching businessId can update or delete the Google My Business profile document.
     * @deny (update, delete) User with non-matching businessId cannot update or delete the Google My Business profile document.
     * @principle Enforces document ownership for writes based on the businessId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function getBusinessId() {
        return request.resource.data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if true;
      allow create: if isOwner(getBusinessId());
      allow update, delete: if isExistingOwner(resource.data.businessId);
    }

    /**
     * @description Allows access to review documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) User with matching googleMyBusinessProfileId can create a review document.
     * @deny (create) User with non-matching googleMyBusinessProfileId cannot create a review document.
     * @allow (get, list) Anyone can read review documents.
     * @allow (update, delete) User with matching googleMyBusinessProfileId can update or delete the review document.
     * @deny (update, delete) User with non-matching googleMyBusinessProfileId cannot update or delete the review document.
     * @principle Enforces document ownership for writes based on the googleMyBusinessProfileId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to internal feedback documents.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any signed-in user can create an internal feedback document.
     * @deny (create) Anonymous user cannot create an internal feedback document.
     * @allow (get, list) Anyone can read internal feedback documents.
     * @allow (update, delete) No one can update or delete an internal feedback document.
     * @principle Restricts write access to authenticated users for creating feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    /**
     * @description Allows access to automated post documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) User with matching googleMyBusinessProfileId can create an automated post document.
     * @deny (create) User with non-matching googleMyBusinessProfileId cannot create an automated post document.
     * @allow (get, list) Anyone can read automated post documents.
     * @allow (update, delete) User with matching googleMyBusinessProfileId can update or delete the automated post document.
     * @deny (update, delete) User with non-matching googleMyBusinessProfileId cannot update or delete the automated post document.
     * @principle Enforces document ownership for writes based on the googleMyBusinessProfileId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
        allow get, list: if true;
        allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to landing page documents.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) User with matching businessId can create a landing page document.
     * @deny (create) User with non-matching businessId cannot create a landing page document.
     * @allow (get, list) Anyone can read landing page documents.
     * @allow (update, delete) User with matching businessId can update or delete the landing page document.
     * @deny (update, delete) User with non-matching businessId cannot update or delete the landing page document.
     * @principle Enforces document ownership for writes based on the businessId.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to subscription documents.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Anyone can read subscription documents.
     * @deny (create, update, delete) No one can create, update, or delete subscription documents.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
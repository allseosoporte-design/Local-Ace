/**
 * @file Firebase Security Rules for Local Leap Platform
 *
 * @description This ruleset enforces a role-based access control system with super admins and business-level ownership.
 *
 * @dataStructure
 *  - /superAdmins/{superAdminId}: Stores super admin profiles. Super admins have full control over businesses and subscription plans.
 *  - /businesses/{businessId}: Stores business profiles, with a denormalized `superAdminId` field indicating ownership.
 *  - /businesses/{businessId}/reviews/{reviewId}: Stores reviews associated with businesses.
 *  - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages associated with businesses.
 *  - /subscriptionPlans/{planId}: Stores subscription plans, accessible to all for reading but manageable only by super admins.
 *
 * @keySecurityDecisions
 *  - Super admins (defined in /superAdmins) have full read and write access to all business data and subscription plans.
 *  - Businesses are owned by a super admin, enforced via the `superAdminId` field on the business document.
 *  - Only super admins can create, update, or delete subscription plans.
 *  - All writes require an authenticated user.
 *  - Listing of super admins is explicitly denied.
 *
 * @denormalizationForAuthorization
 *  - The `superAdminId` is denormalized into the `businesses` collection to avoid `get()` calls in the rules.
 *  - The `businessId` is denormalized into the `reviews` and `landingPages` collections to avoid `get()` calls in the rules.
 *
 * @structuralSegregation
 *  - Uses dedicated collections for different entities (superAdmins, businesses, reviews, landingPages, subscriptionPlans).
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to superAdmin documents.
     * @path /superAdmins/{superAdminId}
     * @allow (create) User with matching UID can create their superAdmin document.
     * @allow (get) Any authenticated user can read a superAdmin document.
     * @allow (list) Listing of superAdmin documents is denied.
     * @allow (update) User with matching UID can update their superAdmin document.
     * @allow (delete) User with matching UID can delete their superAdmin document.
     * @deny (create) User attempts to create a superAdmin document with a mismatched UID.
     * @principle Enforces document ownership for writes and prevents unauthorized listing.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(superAdminId) && request.resource.data.id == superAdminId;
      allow update: if isOwner(superAdminId) && request.resource.data.id == superAdminId;
      allow delete: if isOwner(superAdminId);
    }

    /**
     * @description Controls access to business documents.
     * @path /businesses/{businessId}
     * @allow (create) Super admin can create a business document.
     * @allow (get) Any authenticated user can read a business document.
     * @allow (list) Any authenticated user can list business documents.
     * @allow (update) Super admin who owns the business can update it.
     * @allow (delete) Super admin who owns the business can delete it.
     * @deny (create) Non-super admin attempts to create a business document.
     * @deny (update) Non-super admin attempts to update a business document they don't own.
     * @principle Enforces super admin ownership for business documents.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isSuperAdmin(superAdminId) {
        return exists(/databases/$(database)/documents/superAdmins/$(superAdminId));
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isSuperAdmin(request.resource.data.superAdminId);
      allow update: if isSignedIn() && request.auth.uid == resource.data.superAdminId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.superAdminId;
    }

    /**
     * @description Controls access to review documents.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) Any authenticated user can create a review for a business.
     * @allow (get) Any authenticated user can read a review.
     * @allow (list) Any authenticated user can list reviews for a business.
     * @allow (update) Only the super admin who owns the business can update the review.
     * @allow (delete) Only the super admin who owns the business can delete the review.
     * @deny (create) Review creation fails if businessId in path doesn't match businessId in the document.
     * @deny (update) Non-super admin attempts to update a review for a business they don't own.
     * @principle Enforces super admin ownership for reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isSuperAdminForBusiness(businessId) {
          return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == businessId;
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Controls access to landing page documents.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Any authenticated user can create a landing page for a business.
     * @allow (get) Any authenticated user can read a landing page.
     * @allow (list) Any authenticated user can list landing pages for a business.
     * @allow (update) Only the super admin who owns the business can update the landing page.
     * @allow (delete) Only the super admin who owns the business can delete the landing page.
     * @deny (create) Landing page creation fails if businessId in path doesn't match businessId in the document.
     * @deny (update) Non-super admin attempts to update a landing page for a business they don't own.
     * @principle Enforces super admin ownership for landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isSuperAdminForBusiness(businessId) {
          return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == businessId;
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Controls access to subscription plan documents.
     * @path /subscriptionPlans/{planId}
     * @allow (create) Only a super admin can create a subscription plan.
     * @allow (get) Any authenticated user can read a subscription plan.
     * @allow (list) Any authenticated user can list subscription plans.
     * @allow (update) Only a super admin can update a subscription plan.
     * @allow (delete) Only a super admin can delete a subscription plan.
     * @deny (create) Non-super admin attempts to create a subscription plan.
     * @deny (update) Non-super admin attempts to update a subscription plan.
     * @principle Enforces super admin control over subscription plans.
     */
    match /subscriptionPlans/{planId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isSuperAdminByEmail(email) {
          return get(/databases/$(database)/documents/superAdmins/$(email)).data.id == request.auth.uid;
        }
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isSuperAdminByEmail(request.auth.token.email);
        allow update: if isSignedIn() && isSuperAdminByEmail(request.auth.token.email);
        allow delete: if isSignedIn() && isSuperAdminByEmail(request.auth.token.email);
    }
  }
}
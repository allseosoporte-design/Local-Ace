/**
 * @fileoverview Firestore Security Rules for the Local Leap application.
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control (RBAC) model with super admins and an ownership model for businesses and their associated data. Super admins have full control over businesses and subscription plans. Businesses and their associated data (reviews, landing pages) are owned by a specific super admin.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin user profiles.
 * - /businesses/{businessId}: Stores business profiles, with a `superAdminId` field indicating the owner.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews associated with a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages associated with a business.
 * - /subscriptionPlans/{planId}: Stores subscription plans, managed by super admins.
 *
 * Key Security Decisions:
 * - Super admins have full CRUD access to businesses, reviews, landing pages, and subscription plans.
 * - Regular users (business admins) do not have direct access to Firestore.
 * - Data access is primarily controlled through server-side logic and these rules ensure data integrity.
 * - Listing of super admins is explicitly denied.
 *
 * Denormalization for Authorization:
 * The `Business` entity contains a `superAdminId` field, which is used to determine ownership and authorize access. This avoids the need for `get()` calls to the `/superAdmins` collection.
 *
 * Structural Segregation:
 * There is no explicit segregation of public vs. private data within a single collection. Publicly accessible data should be served through Cloud Functions or other backend services that can enforce appropriate access controls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to superAdmin documents.
     * @path /superAdmins/{superAdminId}
     * @allow (create) If the authenticated user's ID matches the superAdminId.
     * @allow (get) If the authenticated user's ID matches the superAdminId.
     * @allow (update) If the authenticated user's ID matches the superAdminId and the document exists.
     * @allow (delete) If the authenticated user's ID matches the superAdminId and the document exists.
     * @deny (list) Listing super admins is not allowed.
     * @deny (create) If the authenticated user's ID does not match the superAdminId.
     * @deny (get) If the authenticated user's ID does not match the superAdminId.
     * @deny (update) If the authenticated user's ID does not match the superAdminId or the document doesn't exist.
     * @deny (delete) If the authenticated user's ID does not match the superAdminId or the document doesn't exist.
     * @principle Enforces user-ownership for writes, restricts listing.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isExistingOwner(superAdminId);
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Controls access to business documents. Super admins can manage businesses.
     * @path /businesses/{businessId}
     * @allow (create) If the authenticated user is a super admin.
     * @allow (get) If the authenticated user is a super admin or the business is associated with the user.
     * @allow (update) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (delete) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (list) if isSignedIn()
     * @deny (create) If the authenticated user is not a super admin.
     * @deny (get) If the authenticated user is not a super admin or the business is not associated with the user.
     * @deny (update) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @deny (delete) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @principle Enforces super admin control over business accounts.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSuperAdmin();
      allow update: if isExistingSuperAdminOwner(resource.data.superAdminId);
      allow delete: if isExistingSuperAdminOwner(resource.data.superAdminId);
    }

    /**
     * @description Controls access to review documents. Only the super admin associated with the business can manage reviews.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) If the authenticated user is the super admin that owns the business.
     * @allow (get) If the authenticated user is the super admin that owns the business.
     * @allow (update) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (delete) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (list) if isSignedIn()
     * @deny (create) If the authenticated user is not the super admin that owns the business.
     * @deny (get) If the authenticated user is not the super admin that owns the business.
     * @deny (update) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @deny (delete) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @principle Enforces super admin control over reviews for their businesses.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSuperAdminForBusiness(businessId);
      allow update: if isExistingSuperAdminForBusiness(businessId);
      allow delete: if isExistingSuperAdminForBusiness(businessId);
    }

    /**
     * @description Controls access to landing page documents. Only the super admin associated with the business can manage landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) If the authenticated user is the super admin that owns the business.
     * @allow (get) If the authenticated user is the super admin that owns the business.
     * @allow (update) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (delete) If the authenticated user is the super admin that owns the business and the document exists.
     * @allow (list) if isSignedIn()
     * @deny (create) If the authenticated user is not the super admin that owns the business.
     * @deny (get) If the authenticated user is not the super admin that owns the business.
     * @deny (update) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @deny (delete) If the authenticated user is not the super admin that owns the business or the document doesn't exist.
     * @principle Enforces super admin control over landing pages for their businesses.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSuperAdminForBusiness(businessId);
      allow update: if isExistingSuperAdminForBusiness(businessId);
      allow delete: if isExistingSuperAdminForBusiness(businessId);
    }

     /**
      * @description Controls access to subscription plan documents. Only super admins can manage subscription plans.
      * @path /subscriptionPlans/{planId}
      * @allow (create) If the authenticated user is a super admin.
      * @allow (get) If true.
      * @allow (update) If the authenticated user is a super admin and the document exists.
      * @allow (delete) If the authenticated user is a super admin and the document exists.
      * @allow (list) if true
      * @deny (create) If the authenticated user is not a super admin.
      * @deny (update) If the authenticated user is not a super admin or the document doesn't exist.
      * @deny (delete) If the authenticated user is not a super admin or the document doesn't exist.
      * @principle Enforces super admin control over subscription plans.
      */
    match /subscriptionPlans/{planId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isSuperAdmin() {
      return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.id == request.auth.uid;
    }

    function isSuperAdminForBusiness(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid && isSuperAdmin();
    }

    function isExistingSuperAdminForBusiness(businessId) {
      return isSuperAdminForBusiness(businessId) && resource != null;
    }

    function isSuperAdminOwner(superAdminId) {
      return request.auth.uid == superAdminId && isSuperAdmin();
    }

    function isExistingSuperAdminOwner(superAdminId) {
        return isSuperAdminOwner(superAdminId) && resource != null;
    }
  }
}
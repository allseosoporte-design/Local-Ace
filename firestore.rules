/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a hierarchical data ownership model, where businesses own their associated reviews, Google Business Profiles, posts, landing pages, and contact forms.
 * All data is nested under the /businesses/{businessId} collection.
 * Key Security Decisions:
 *  - Explicitly denying listing of the root collections, enforcing access only through a known businessId.
 *  - Enforcing that a user must be signed in to perform any write operation.
 *  - Assuming that all write operations require business ownership.
 *  - Read access is generally open for prototyping purposes, but this should be tightened in production.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the business.
     * @param {string} businessId - The ID of the business.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(businessId) {
      return isSignedIn() && request.auth.uid == businessId;
    }

    /**
     * @description Checks if the business exists and the user is the owner of the business.
     * @param {string} businessId - The ID of the business.
     * @return {bool} True if the business exists and the user is the owner, false otherwise.
     */
    function isExistingOwner(businessId) {
      return isOwner(businessId) && resource != null;
    }
    
    match /{path=**}/businesses {
      allow list: if false;
    }

    /**
     * @description Manages access to Business documents.
     * @path /businesses/{businessId}
     * @allow (create) User with UID matching `businessId` can create a business document.
     * @deny (create) User with UID not matching `businessId` cannot create a business document.
     * @allow (get, list) Any signed-in user can read a business document.
     * @allow (update, delete) Only the owner of the business can update or delete the document.
     * @deny (update, delete) Non-owners cannot update or delete the document.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Manages access to Review documents under a Business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) Owner of the business can create a review.
     * @deny (create) Non-owners cannot create a review.
     * @allow (get, list) Any signed-in user can read a review.
     * @allow (update, delete) Only the owner of the business can update or delete the review.
     * @deny (update, delete) Non-owners cannot update or delete the review.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Manages access to GoogleBusinessProfile documents under a Business.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     * @allow (create) Owner of the business can create a Google Business Profile.
     * @deny (create) Non-owners cannot create a Google Business Profile.
     * @allow (get, list) Any signed-in user can read a Google Business Profile.
     * @allow (update, delete) Only the owner of the business can update or delete the Google Business Profile.
     * @deny (update, delete) Non-owners cannot update or delete the Google Business Profile.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Manages access to Post documents under a GoogleBusinessProfile.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     * @allow (create) Owner of the business can create a post.
     * @deny (create) Non-owners cannot create a post.
     * @allow (get, list) Any signed-in user can read a post.
     * @allow (update, delete) Only the owner of the business can update or delete the post.
     * @deny (update, delete) Non-owners cannot update or delete the post.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Manages access to LandingPage documents under a Business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Owner of the business can create a landing page.
     * @deny (create) Non-owners cannot create a landing page.
     * @allow (get, list) Any signed-in user can read a landing page.
     * @allow (update, delete) Only the owner of the business can update or delete the landing page.
     * @deny (update, delete) Non-owners cannot update or delete the landing page.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Manages access to ContactForm documents under a LandingPage.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     * @allow (create) Owner of the business can create a contact form.
     * @deny (create) Non-owners cannot create a contact form.
     * @allow (get, list) Any signed-in user can read a contact form.
     * @allow (update, delete) Only the owner of the business can update or delete the contact form.
     * @deny (update, delete) Non-owners cannot update or delete the contact form.
     * @principle Enforces document ownership for writes, open reads for prototyping.
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    match /subscriptionPlans {
      allow list: if false;
    }
    /**
     * @description Manages access to SubscriptionPlan documents.
     * @path /subscriptionPlans/{subscriptionPlanId}
     * @allow (get, list) Any signed-in user can read a subscription plan.
     * @allow (create, update, delete) No one can create, update, or delete a subscription plan.
     * @principle Restricts write access to SubscriptionPlans.
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
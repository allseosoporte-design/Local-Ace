/**
 * @fileoverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant security model based on SuperAdmins managing Businesses, with path-based ownership and authorization independence.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin accounts.
 * - /businesses/{businessId}: Stores business accounts, with `superAdminId` for ownership.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for businesses.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for businesses.
 *
 * Key Security Decisions:
 * - SuperAdmins have full access to their Businesses, Reviews, and LandingPages.
 * - Data consistency between paths and document fields is strictly enforced.
 * - List operations are restricted to owners where applicable, denying the ability to list all superAdmins.
 *
 * Denormalization for Authorization:
 * The `business` documents contain the `superAdminId` of their managing superAdmin. This avoids costly `get()` calls to the `/superAdmins` collection when authorizing access to businesses and their subcollections.
 *
 * Structural Segregation:
 * The data is segregated by path (e.g., /businesses/{businessId}/reviews/{reviewId}), which naturally limits access to a superAdmin's own data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Protects superAdmin accounts.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin account if the userId in the path matches their auth.uid.
     * @allow (get) - A superAdmin can get their own superAdmin account if the userId in the path matches their auth.uid.
     * @allow (update) - A superAdmin can update their own superAdmin account if the userId in the path matches their auth.uid.
     * @allow (delete) - A superAdmin can delete their own superAdmin account if the userId in the path matches their auth.uid.
     * @allow (list) - Denied to prevent listing all superAdmins.
     * @deny (create) - A user cannot create a superAdmin account with an ID that does not match their auth.uid.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(superAdminId) {
        return request.auth.uid == superAdminId;
      }

      function isExistingOwner(superAdminId) {
        return isOwner(superAdminId) && resource != null;
      }

      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isExistingOwner(superAdminId);
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Protects business accounts, ensuring only the associated superAdmin can manage them.
     * @path /businesses/{businessId}
     * @allow (create) - A superAdmin can create a business if the `superAdminId` in the document matches their `auth.uid`.
     * @allow (get) - A superAdmin can get a business if the `superAdminId` in the document matches their `auth.uid`.
     * @allow (update) - A superAdmin can update a business if the `superAdminId` in the document matches their `auth.uid`.
     * @allow (delete) - A superAdmin can delete a business if the `superAdminId` in the document matches their `auth.uid`.
     * @allow (list) - A superAdmin can list businesses if the `superAdminId` in the business document matches their `auth.uid`.
     * @deny (create) - A user cannot create a business with a `superAdminId` that doesn't match their own.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree, validates relational integrity between documents.
     */
    match /businesses/{businessId} {
      function isOwner(superAdminId) {
        return request.auth.uid == superAdminId;
      }

      function isExistingOwner(superAdminId) {
        return isOwner(superAdminId) && resource != null;
      }

      allow get: if resource.data.superAdminId == request.auth.uid;
      allow list: if true; // TODO: Revisa si es lo correcto
      allow create: if request.resource.data.superAdminId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.superAdminId);
      allow delete: if isExistingOwner(resource.data.superAdminId);
    }

    /**
     * @description Protects reviews associated with a specific business, ensuring only the associated superAdmin can manage them.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) - A superAdmin can create a review for a business they own.
     * @allow (get) - A superAdmin can get a review for a business they own.
     * @allow (update) - A superAdmin can update a review for a business they own.
     * @allow (delete) - A superAdmin can delete a review for a business they own.
     * @allow (list) - A superAdmin can list reviews for a business they own.
     * @deny (create) - A user cannot create a review for a business they don't own.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree, validates relational integrity between documents.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSuperAdminOfBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }

      function isExistingSuperAdminOfBusiness(businessId) {
        return isSuperAdminOfBusiness(businessId) && resource != null;
      }

      allow get: if isSuperAdminOfBusiness(businessId);
      allow list: if isSuperAdminOfBusiness(businessId);
      allow create: if isSuperAdminOfBusiness(businessId);
      allow update: if isExistingSuperAdminOfBusiness(businessId);
      allow delete: if isExistingSuperAdminOfBusiness(businessId);
    }

    /**
     * @description Protects landing pages associated with a specific business, ensuring only the associated superAdmin can manage them.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - A superAdmin can create a landing page for a business they own.
     * @allow (get) - A superAdmin can get a landing page for a business they own.
     * @allow (update) - A superAdmin can update a landing page for a business they own.
     * @allow (delete) - A superAdmin can delete a landing page for a business they own.
     * @allow (list) - A superAdmin can list landing pages for a business they own.
     * @deny (create) - A user cannot create a landing page for a business they don't own.
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree, validates relational integrity between documents.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSuperAdminOfBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }

      function isExistingSuperAdminOfBusiness(businessId) {
        return isSuperAdminOfBusiness(businessId) && resource != null;
      }

      allow get: if isSuperAdminOfBusiness(businessId);
      allow list: if isSuperAdminOfBusiness(businessId);
      allow create: if isSuperAdminOfBusiness(businessId);
      allow update: if isExistingSuperAdminOfBusiness(businessId);
      allow delete: if isExistingSuperAdminOfBusiness(businessId);
    }
  }
}
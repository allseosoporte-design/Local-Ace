/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict ownership model for businesses and their associated data.
 * All data is nested under business-specific paths (e.g., /businesses/{businessId}), ensuring that only
 * authenticated users can access and modify data related to their respective businesses.  Authorization
 * Independence is achieved by denormalizing the `businessId` from the `Business` entity to `GoogleMyBusinessProfile`, `LandingPage`,
 * `Review`, and `AutomatedPost` entities, and avoid doing `get()` calls in rules.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information, related to business via businessId.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Customer reviews for a GMB profile.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback collected from customers who left negative reviews.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts scheduled for a GMB profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages created for a business.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - All write operations require user authentication (`isSignedIn()`).
 * - All writes to business-owned data are restricted to the owner of the business (`isOwner(businessId)`).
 * - Public listing of any collection is disallowed.
 * - Relational integrity is enforced on create operations by validating the relationship between the data and the path.
 * - Immutability is enforced on update operations for critical relational fields.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to business documents.
     * @path /businesses/{businessId}
     * @allow (create) - Authenticated user can create a business document if the businessId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can access and modify a business document if they are the owner.
     * @deny (create) - Non-authenticated user cannot create a business document.
     * @deny (update, delete) - Authenticated user cannot modify a business document if they are not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isExistingOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId);
    }

    /**
     * @description Controls access to Google My Business profile documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - Authenticated user can create a profile if the businessId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can access and modify a profile if they are the owner.
     * @deny (create) - Non-authenticated user cannot create a profile.
     * @deny (update, delete) - Authenticated user cannot modify a profile if they are not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function getBusinessId() {
          return request.resource.data.businessId;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && isOwner(getBusinessId());
      allow update: if isSignedIn() && isExistingOwner(resource.data.businessId);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.businessId);
    }

    /**
     * @description Controls access to review documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - Authenticated user can create a review if the googleMyBusinessProfile's businessId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can access and modify a review if they are the owner.
     * @deny (create) - Non-authenticated user cannot create a review.
     * @deny (update, delete) - Authenticated user cannot modify a review if they are not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function getBusinessId() {
            return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        }

        function isOwner(businessId) {
            return request.auth.uid == businessId;
        }

        allow get: if false;
        allow list: if false;
        allow create: if isSignedIn() && isOwner(getBusinessId());
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Controls access to internal feedback documents.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) - Any authenticated user can create an internal feedback document.
     * @allow (get, list) - No read access granted
     * @deny (update, delete) - No update or delete access granted.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to automated post documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - Authenticated user can create a post if the googleMyBusinessProfile's businessId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can access and modify a post if they are the owner.
     * @deny (create) - Non-authenticated user cannot create a post.
     * @deny (update, delete) - Authenticated user cannot modify a post if they are not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
        function isSignedIn() {
            return request.auth != null;
        }

        function getBusinessId() {
            return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        }

        function isOwner(businessId) {
            return request.auth.uid == businessId;
        }

        allow get: if false;
        allow list: if false;
        allow create: if isSignedIn() && isOwner(getBusinessId());
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Controls access to landing page documents.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Authenticated user can create a landing page if the businessId matches their UID.
     * @allow (get, list, update, delete) - Authenticated user can access and modify a landing page if they are the owner.
     * @deny (create) - Non-authenticated user cannot create a landing page.
     * @deny (update, delete) - Authenticated user cannot modify a landing page if they are not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if false;
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isExistingOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId);
    }

    /**
     * @description Controls access to subscription documents.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Public read access to subscription information.
     * @deny (create, update, delete) - No write access granted.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
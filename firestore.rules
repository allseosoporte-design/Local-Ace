rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isSelfCreation(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows businesses to manage their information.
     * @path /businesses/{businessId}
     */
    match /businesses/{businessId} {
      allow get: if isBusinessOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.ownerId;
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);
    }

    /**
     * @description Allows businesses to manage their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow list: if false;
      allow create: if isSignedIn() && isValidGMBProfileCreate();
      allow update: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow delete: if isGMBProfileOwner(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage customer reviews for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow list: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow update: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow delete: if isGMBProfileOwner(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage internal feedback collected from customers.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      allow get: if isBusinessOwner(businessId);
      allow list: if isBusinessOwner(businessId);
      allow create: if isSignedIn() && isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);
    }

    /**
     * @description Allows businesses to manage automated posts for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow list: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow update: if isGMBProfileOwner(googleMyBusinessProfileId);
      allow delete: if isGMBProfileOwner(googleMyBusinessProfileId);
    }

    /**
     * @description Allows businesses to manage landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isBusinessOwner(businessId);
      allow list: if isBusinessOwner(businessId);
      allow create: if isSignedIn() && isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);
    }

    /**
     * @description Allows anyone to read subscription information, but only the backend can create/update/delete.
     * @path /subscriptions/{subscriptionId}
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isBusinessOwner(businessId) {
    return isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
  }

  function isGMBProfileOwner(googleMyBusinessProfileId) {
    let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
    return isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
  }

  function isSelfCreation(userId) {
    return request.auth.uid == request.resource.data.id;
  }

  function isValidGMBProfileCreate() {
    let businessId = request.resource.data.businessId;
    return isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
  }
}
/**
 * @fileoverview Firestore Security Rules for Local Leap Platform
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model with a super-admin role and business-specific ownership.
 * Super admins have full access, while business owners have control over their own business data.
 * Unauthenticated access is disallowed.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business entities.
 * - /businesses/{businessId}/reviews/{reviewId}: Subcollection for business reviews.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}: Subcollection for Google Business Profiles.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}: Subcollection for Google Business Profile posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for Landing Pages.
 * - /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}: Subcollection for Contact Forms.
 * - /subscriptionPlans/{subscriptionPlanId}: Collection for subscription plans.
 * - /paymentSettings/{planSettingsId}: Collection for payment settings.
 * - /superAdmins/{superAdminId}: Collection for super administrators.
 *
 * Key Security Decisions:
 * - Super-admins are managed within the `/superAdmins` collection, all other users will be treated as unauthenticated.
 * - Data is generally not publicly listable without authentication.
 * - Ownership is enforced for business-related data (reviews, GBP, posts, landing pages, contact forms).
 * - `list` operations are allowed for super admins.
 *
 * Denormalization for Authorization:
 *  - To keep rules simple and efficient, business ownership is implicitly derived from the path /businesses/{businessId}/....
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is a super admin.
     * @return {bool} True if the user is a super admin, false otherwise.
     */
    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    /**
     * @description Checks if the user owns the business.
     * @param {string} businessId - The business ID to check.
     * @return {bool} True if the user owns the business, false otherwise.
     */
    function isBusinessOwner(businessId) {
      return isSuperAdmin();
    }

    /**
     * @description Checks if the user is the existing owner of the resource.
     *              Combines the ownership check with existence check.
     * @param {string} businessId - The business ID to check.
     * @return {bool} True if the user owns the business and the resource exists, false otherwise.
     */
    function isExistingBusinessOwner(businessId) {
        return isBusinessOwner(businessId) && exists(resource);
    }

    /**
     * @description Root-level rule to prevent any unauthorized access.
     */
    match /{document=**} {
      allow read, write: if false;
    }

   /**
     * @description Manages access to business entities.
     * @path /businesses/{businessId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over business entities.
     */
    match /businesses/{businessId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to Google Business Profiles associated with a business.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over Google Business Profiles.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to posts associated with a Google Business Profile.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over posts.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to contact forms associated with a landing page.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over contact forms.
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to subscription plans.
     * @path /subscriptionPlans/{subscriptionPlanId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over subscription plans.
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to payment settings.
     * @path /paymentSettings/{planSettingsId}
     * @allow (create) If the user is a super admin.
     * @allow (get, list, update, delete) If the user is a super admin.
     * @deny (create, update, delete) If the user is not a super admin.
     * @principle Enforces super admin control over payment settings.
     */
    match /paymentSettings/{planSettingsId} {
      allow get, list: if isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Manages access to super admin profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (get, list) if the user is a super admin.
     * @allow (create) if request.auth.uid == superAdminId;
     * @allow (update, delete) if request.auth.uid == superAdminId && resource != null;
     * @deny (create, update, delete) if the user is not the super admin.
     * @principle Enforces super admin control over their own profile.
     */
    match /superAdmins/{superAdminId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSignedIn() && request.auth.uid == superAdminId;
      allow update, delete: if isSignedIn() && request.auth.uid == superAdminId;
    }
  }
}
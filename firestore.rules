/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a business-centric security model.  Users are associated with businesses via their UserProfile, and most data access is restricted to members of that business.
 * Strict ownership is enforced for user profiles, ensuring users can only manage their own profile data.
 * Data required for authorization (businessId) is denormalized onto documents to avoid costly `get()` operations in the rules.
 *
 * Data Structure:
 * - `/users/{userId}`: User profiles, linked to a business.
 * - `/businesses/{businessId}`: Business data. Root collection for business data.
 * - `/googleMyBusinessProfiles/{googleMyBusinessProfileId}`: Google My Business profile data.
 * - `/googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}`: Reviews for a Google My Business profile.
 * - `/internalFeedback/{internalFeedbackId}`: Internal feedback from customers.
 * - `/googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}`: Automated posts for a Google My Business profile.
 * - `/businesses/{businessId}/landingPages/{landingPageId}`: Landing pages for a business.
 * - `/subscriptions/{subscriptionId}`: Subscription plan data. Public read-only.
 *
 * Key Security Decisions:
 * - Users can only read/write their own profile.
 * - Most data is secured at the business level, with access granted to members of the business.
 * - Listing of user profiles is disallowed.
 * - Subscriptions are publicly readable, but only administrators (not implemented) can create/update/delete them.
 *
 * Denormalization for Authorization:
 * - The `UserProfile` includes the `businessId`, which is used to authorize access to business-related data.
 *
 * Structural Segregation:
 * - Internal feedback is stored in a separate root collection (`/internalFeedback/{internalFeedbackId}`) instead of a subcollection under `Review`.
 *   This is done to decouple authorization from the `GoogleMyBusinessProfile` and simplify access control for internal feedback, which may need different permissions.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their profile if request.auth.uid == 'user123' and request.resource.data.id == 'user123'.
     * @allow (get) User with UID 'user123' can read their own profile.
     * @allow (update) User with UID 'user123' can update their profile.
     * @deny (create) User with UID 'user456' cannot create a profile with ID 'user123'.
     * @deny (get) User with UID 'user456' cannot read the profile of user 'user123'.
     * @deny (update) User with UID 'user456' cannot update the profile of user 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource.data.id == userId;
      allow delete: if false;
    }

    /**
     * @description Allows read and write access to businesses for authorized users.
     * @path /businesses/{businessId}
     * @allow (create) User can create a business document with correct data.
     * @allow (get) User with access to a business can read the business document.
     * @allow (update) User with access can update the business document.
     * @deny (create) Unauthorized user cannot create a business document.
     * @deny (get) Unauthorized user cannot read a business document.
     * @deny (update) Unauthorized user cannot update a business document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /businesses/{businessId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if false;
    }

    /**
     * @description Allows read and write access to Google My Business profiles for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User can create a profile document with correct data.
     * @allow (get) User with access to a profile can read the profile document.
     * @allow (update) User with access can update the profile document.
     * @deny (create) Unauthorized user cannot create a profile document.
     * @deny (get) Unauthorized user cannot read a profile document.
     * @deny (update) Unauthorized user cannot update a profile document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if false;
    }

    /**
     * @description Allows read and write access to reviews for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) User can create a review document with correct data.
     * @allow (get) User with access to a review can read the review document.
     * @allow (update) User with access can update the review document.
     * @deny (create) Unauthorized user cannot create a review document.
     * @deny (get) Unauthorized user cannot read a review document.
     * @deny (update) Unauthorized user cannot update a review document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

   /**
     * @description Allows read and write access to internal feedback for authorized users.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) User can create a feedback document with correct data.
     * @allow (get) User with access to feedback can read the feedback document.
     * @allow (update) User with access can update the feedback document.
     * @deny (create) Unauthorized user cannot create a feedback document.
     * @deny (get) Unauthorized user cannot read a feedback document.
     * @deny (update) Unauthorized user cannot update a feedback document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /internalFeedback/{internalFeedbackId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if false;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if false;
    }

    /**
     * @description Allows read and write access to automated posts for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) User can create a post document with correct data.
     * @allow (get) User with access to a post can read the post document.
     * @allow (update) User with access can update the post document.
     * @deny (create) Unauthorized user cannot create a post document.
     * @deny (get) Unauthorized user cannot read a post document.
     * @deny (update) Unauthorized user cannot update a post document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows read and write access to landing pages for authorized users.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) User can create a landing page document with correct data.
     * @allow (get) User with access to a landing page can read the landing page document.
     * @allow (update) User with access can update the landing page document.
     * @deny (create) Unauthorized user cannot create a landing page document.
     * @deny (get) Unauthorized user cannot read a landing page document.
     * @deny (update) Unauthorized user cannot update a landing page document.
     * @principle Requires user to be authenticated to perform any operation.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource != null;
        allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Allows public read access to subscriptions, but restricts writes.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Any user can read subscription information.
     * @deny (create) No one can create a subscription.
     * @deny (update) No one can update a subscription.
     * @deny (delete) No one can delete a subscription.
     * @principle Provides public read access while restricting write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with super admins managing businesses, reviews, and landing pages.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Super admin profiles.
 * - /businesses/{businessId}: Business profiles, owned by a super admin (denoted by a denormalized superAdminId field).
 * - /businesses/{businessId}/reviews/{reviewId}: Reviews associated with a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages associated with a business.
 * - /subscriptionPlans/{planId}: Publicly readable subscription plans.
 *
 * Key Security Decisions:
 * - Super admins have full CRUD access to businesses, reviews, and landing pages associated with their businesses.
 * - Regular users (non-admins) are not explicitly defined, and thus have no access unless specified otherwise.
 * - Listing of super admins is denied.
 * - Subscription plans are publicly readable but only manageable by super admins.
 *
 * Denormalization for Authorization:
 * - The `Business` entity denormalizes the `superAdminId` to enable authorization checks without requiring `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages super admin profiles.  Super admins can only manage their own profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin profile if the ID matches their auth UID.
     * @allow (get, update, delete) - A superAdmin can only access or modify their own profile.
     * @deny (create) - A user cannot create a superAdmin profile with an ID that doesn't match their own auth UID.
     * @deny (list) - Listing super admins is not allowed.
     * @principle Enforces document ownership for super admin profiles.
     */
    match /superAdmins/{superAdminId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return resource.data.keys().hasAny(['']) && isOwner(userId);
      }

      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == superAdminId;
      allow update: if isSignedIn() && isExistingOwner(superAdminId);
      allow delete: if isSignedIn() && isExistingOwner(superAdminId);
    }

    /**
     * @description Manages business profiles. Super admins can CRUD businesses they own.
     * @path /businesses/{businessId}
     * @allow (create, update, delete) - A superAdmin can only modify business they own.
     * @allow (get, list) - Any user can view a business profile.
     * @deny (create, update, delete) - A non-superAdmin cannot modify any business.
     * @principle Enforces super admin ownership for business profiles.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(superAdminId) {
        return isSignedIn() && get(/databases/$(database)/documents/superAdmins/$(superAdminId)).data.id == request.auth.uid;
      }

       function isExistingOwner(superAdminId) {
          return resource.data.keys().hasAny(['superAdminId']) && resource.data.superAdminId == request.auth.uid;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.keys().hasAny(['superAdminId']) && request.resource.data.superAdminId == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(request.auth.uid);
      allow delete: if isSignedIn() && isExistingOwner(request.auth.uid);
    }

    /**
     * @description Manages reviews associated with a business. Super admins can CRUD reviews for businesses they own.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create, update, delete) - A superAdmin can only modify reviews for businesses they own.
     * @allow (get, list) - Any user can view a review.
     * @deny (create, update, delete) - A non-superAdmin cannot modify any review.
     * @principle Enforces super admin ownership for reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }

      function isExistingBusinessOwner(businessId) {
          return resource.data.keys().hasAny(['']) && isBusinessOwner(businessId);
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isBusinessOwner(businessId);
      allow update: if isSignedIn() && isExistingBusinessOwner(businessId);
      allow delete: if isSignedIn() && isExistingBusinessOwner(businessId);
    }

    /**
     * @description Manages landing pages associated with a business. Super admins can CRUD landing pages for businesses they own.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create, update, delete) - A superAdmin can only modify landing pages for businesses they own.
     * @allow (get, list) - Any user can view a landing page.
     * @deny (create, update, delete) - A non-superAdmin cannot modify any landing page.
     * @principle Enforces super admin ownership for landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }

      function isExistingBusinessOwner(businessId) {
          return resource.data.keys().hasAny(['']) && isBusinessOwner(businessId);
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isBusinessOwner(businessId);
      allow update: if isSignedIn() && isExistingBusinessOwner(businessId);
      allow delete: if isSignedIn() && isExistingBusinessOwner(businessId);
    }

    /**
     * @description Manages subscription plans. These are publicly readable, but only super admins can manage them.
     * @path /subscriptionPlans/{planId}
     * @allow (get, list) - Any user can view subscription plans.
     * @allow (create, update, delete) - Only super admins can manage subscription plans.
     * @principle Enforces super admin management for subscription plans.
     */
    match /subscriptionPlans/{planId} {
      function isSignedIn() {
        return request.auth != null;
      }

       function isSuperAdmin() {
          return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }

      function isValidCreate() {
        return request.resource.data.keys().hasAny(['']);
      }

      allow get, list: if true;
      allow create: if isSignedIn() && isValidCreate() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }
  }
}
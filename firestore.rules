/**
 * @description This ruleset enforces a strict authorization model for the Local Leap application.
 * Super admins have full control over businesses, reviews, and landing pages. Regular users (businesses)
 * have read-only access to subscription plans.
 * @dataStructure
 * - /superAdmins/{superAdminId}: Stores super admin profiles.
 * - /businesses/{businessId}: Stores business profiles, each with a denormalized `superAdminId` field.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for each business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for each business.
 * - /subscriptionPlans/{planId}: Stores subscription plans.
 * @keySecurityDecisions
 * - Super admins are authorized by the presence of their document in `/superAdmins/{superAdminId}`.
 * - Business ownership is determined by the `superAdminId` field within the business document.
 * - Only super admins can create, update, or delete businesses, reviews, and landing pages.
 * - Subscription plans are publicly readable but only manageable by super admins.
 * @denormalizationForAuthorization
 * - The `businesses` collection denormalizes the `superAdminId` to enable efficient security rules without extra `get()` operations.
 * @structuralSegregation N/A
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages super admin profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin profile if the auth UID matches the document ID.
     * @allow (get, list, update, delete) - Super admins can read, list, update, and delete their own profiles.
     * @deny (create) - A user cannot create a superAdmin profile with an ID that does not match their auth UID.
     * @principle Enforces document ownership and self-creation for super admin profiles.
     */
    match /superAdmins/{superAdminId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(superAdminId);
      allow list: if false; // Listing super admins is not permitted.
      allow create: if isSignedIn() && isOwner(superAdminId);
      allow update: if isSignedIn() && isExistingOwner(superAdminId);
      allow delete: if isSignedIn() && isExistingOwner(superAdminId);
    }

    /**
     * @description Manages business profiles. Only super admins can create, update, or delete businesses.
     * @path /businesses/{businessId}
     * @allow (create) - A super admin can create a business profile if the request includes a `superAdminId`.
     * @allow (get, list, update, delete) - Only super admins can perform get, list, update, or delete operations.
     * @deny (create) - Regular users cannot create business profiles.
     * @principle Enforces super admin control over business profiles.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isSuperAdmin() {
        return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }

      allow get: if isSignedIn() && isSuperAdmin();
      allow list: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }

    /**
     * @description Manages reviews associated with a specific business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) - A super admin can create a review for a business they manage.
     * @allow (get, list, update, delete) - Only super admins associated with the business can perform get, list, update, or delete operations.
     * @deny (create) - Regular users cannot create reviews.
     * @principle Enforces super admin control over reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isSuperAdminForBusiness(businessId) {
          return exists(/databases/$(database)/documents/businesses/$(businessId))
                 && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages landing pages associated with a specific business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - A super admin can create a landing page for a business they manage.
     * @allow (get, list, update, delete) - Only super admins associated with the business can perform get, list, update, or delete operations.
     * @deny (create) - Regular users cannot create landing pages.
     * @principle Enforces super admin control over landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isSuperAdminForBusiness(businessId) {
            return exists(/databases/$(database)/documents/businesses/$(businessId))
                   && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
        }
        allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
        allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
        allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
        allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
        allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages subscription plans. Subscription plans are publicly readable but only super admins can manage them.
     * @path /subscriptionPlans/{planId}
     * @allow (get, list) - Anyone can read subscription plans.
     * @allow (create, update, delete) - Only super admins can create, update, or delete subscription plans.
     * @deny (create, update, delete) - Regular users cannot manage subscription plans.
     * @principle Enforces read-only access for regular users and super admin control for management.
     */
    match /subscriptionPlans/{planId} {
        function isSignedIn() {
          return request.auth != null;
        }
        function isSuperAdmin() {
          return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
        }
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && isSuperAdmin();
        allow update: if isSignedIn() && isSuperAdmin();
        allow delete: if isSignedIn() && isSuperAdmin();
    }
  }
}
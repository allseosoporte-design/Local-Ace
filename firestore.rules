rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Función corregida - verifica que request.auth exista primero
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.token.isSuperAdmin == true || 
              request.auth.token.email == 'allseosoporte@gmail.com');
    }

    // SUBSCRIPTION PLANS - Acceso público para lectura
    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == businessId || isSuperAdmin());
      
      match /catalogConfig/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.uid == businessId || isSuperAdmin());
      }
      
      match /contactForm/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /contactSubmissions/{submissionId} {
        allow create: if true;
        allow read, delete: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /contactForms/{formId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /landingPages/{pageId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
    }
    
    match /globalAuditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /backups/{backupId} {
      allow read, write, delete: if isSuperAdmin();
    }
    
    match /chatbot/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
    }
    
    // Internal Feedback Collection
    match /internalFeedback/{feedbackId} {
      allow create: if true;
      allow get: if request.auth != null && (resource.data.businessId == request.auth.uid || isSuperAdmin());
      allow list: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.businessId == request.auth.uid || isSuperAdmin());
    }
    
    match /products/{productId} {
      allow read: if resource.data.businessId == 'DzH9Kc6eYqOih5Y705ebM0SzfZf2' || 
                     (request.auth != null && request.auth.uid == resource.data.businessId) || 
                     isSuperAdmin();
      allow write: if request.auth != null && (request.auth.uid == request.resource.data.businessId || isSuperAdmin());
    }

    match /pendingPayments/{paymentId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.empresaId || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read, write: if isSuperAdmin();
      allow create: if true;
    }
    
    match /paymentSettings/{userId} {
      allow read: if userId == 'DzH9Kc6eYqOih5Y705ebM0SzfZf2' || 
                     (request.auth != null && request.auth.uid == userId);
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }
  }
}

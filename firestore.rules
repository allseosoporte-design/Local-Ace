/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy: This ruleset enforces a strict user-ownership model for
 * business and user-related data. Businesses can only manage data associated
 * with their ID. Users can only read their own profile data. Public read access
 * is not granted to any collections.
 *
 * Data Structure: The Firestore data is organized as follows:
 * - /users/{userId}: Stores user profile information.
 * - /businesses/{businessId}: Stores business information and serves as the
 *   root for business-owned subcollections.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}:
 *   Stores customer reviews for a Google My Business profile.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback collected
 *   from customers who left negative reviews.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}:
 *   Stores automated posts scheduled for a Google My Business profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages
 *   created for a business.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Write operations are restricted to authenticated users.
 * - Strong ownership checks are enforced for all write operations to prevent
 *   unauthorized data modification.
 * - The /businesses/{businessId}/landingPages/{landingPageId} collection uses
 *   an ownership model to ensure that only the business that owns the landing
 *   page can modify it.
 *
 * Denormalization for Authorization:
 * - The GoogleMyBusinessProfile document includes the businessId to ensure
 *   authorization independence for access control. This avoids the need to
 *   query the /businesses collection for authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @example isSignedIn() == true if request.auth != null
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @example isOwner("user123") == true if request.auth.uid == "user123"
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the existing document.
     * @example isExistingOwner("user123") == true if request.auth.uid == resource.data.ownerId
     */
    function isExistingOwner(ownerId) {
        return isSignedIn() && request.auth.uid == ownerId && resource != null;
    }

    /**
     * @description Stores user profile information, linking auth ID to business ID. Users can read their own profile.
     * @path /users/{userId}
     * @allow (create) - User with UID "user123" creates a profile with document ID "user123".
     * @allow (get, list) - User with UID "user123" reads their own profile at /users/user123.
     * @deny (update) - User with UID "user456" attempts to update the profile at /users/user123.
     * @deny (delete) - User with UID "user123" attempts to delete the profile at /users/user123.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Stores business information. Root collection for all business-related data. Businesses can manage their Google My Business profiles, landing pages, etc.
     * @path /businesses/{businessId}
     * @allow (create) - Authenticated user creates a business profile with a specific businessId.
     * @allow (get, list) - Authenticated user retrieves a business profile with a specific businessId.
     * @deny (update) - Unauthorized user attempts to update a business profile.
     * @deny (delete) - Unauthorized user attempts to delete a business profile.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == businessId;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores Google My Business profile information. Includes the businessId to ensure authorization independence for access control.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - Authenticated user creates a GMB profile with a specific googleMyBusinessProfileId.
     * @allow (get, list) - Authenticated user retrieves a GMB profile with a specific googleMyBusinessProfileId.
     * @deny (update) - Unauthorized user attempts to update a GMB profile.
     * @deny (delete) - Unauthorized user attempts to delete a GMB profile.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores customer reviews for a Google My Business profile. Located as a subcollection to ensure efficient querying of reviews associated with a profile. Includes fields for filtering (isFiltered) and internal feedback.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - Authenticated user creates a review for a specific GMB profile.
     * @allow (get, list) - Authenticated user retrieves reviews for a specific GMB profile.
     * @deny (update) - Unauthorized user attempts to update a review.
     * @deny (delete) - Unauthorized user attempts to delete a review.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores internal feedback collected from customers who left negative reviews. This is stored at the root to avoid authorization dependency on GoogleMyBusinessProfile.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) - Authenticated user creates internal feedback with a specific internalFeedbackId.
     * @allow (get, list) - Authenticated user retrieves internal feedback with a specific internalFeedbackId.
     * @deny (update) - Unauthorized user attempts to update internal feedback.
     * @deny (delete) - Unauthorized user attempts to delete internal feedback.
     * @principle Enforces document ownership for writes.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores automated posts scheduled for a Google My Business profile. Located as a subcollection to ensure efficient querying of posts associated with a profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - Authenticated user creates an automated post for a specific GMB profile.
     * @allow (get, list) - Authenticated user retrieves automated posts for a specific GMB profile.
     * @deny (update) - Unauthorized user attempts to update an automated post.
     * @deny (delete) - Unauthorized user attempts to delete an automated post.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores landing pages created for a business. Located as a subcollection to ensure efficient querying of landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Authenticated user creates a landing page for a specific business.
     * @allow (get, list) - Authenticated user retrieves landing pages for a specific business.
     * @deny (update) - Unauthorized user attempts to update a landing page.
     * @deny (delete) - Unauthorized user attempts to delete a landing page.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Stores subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (create) - Authenticated user creates a subscription plan with a specific subscriptionId.
     * @allow (get, list) - Authenticated user retrieves a subscription plan with a specific subscriptionId.
     * @deny (update) - Unauthorized user attempts to update a subscription plan.
     * @deny (delete) - Unauthorized user attempts to delete a subscription plan.
     * @principle Enforces document ownership for writes.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
     /**
     * @description Stores landing pages created for a business. Located as a subcollection to ensure efficient querying of landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/hero
     * @allow (get) - public read
     * @principle public read for the hero landing page
     */
     match /businesses/{businessId}/landingPages/{landingPageId}/hero {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

  }
}
/**
 * @fileOverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model where SuperAdmins manage Businesses, Reviews, and Landing Pages.
 * Data is organized hierarchically to reflect ownership and relationships.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: SuperAdmin profiles.
 * - /businesses/{businessId}: Business profiles owned by a SuperAdmin. Contains `superAdminId`.
 * - /businesses/{businessId}/reviews/{reviewId}: Reviews for a specific business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for a specific business.
 *
 * Key Security Decisions:
 * - SuperAdmins can manage their Businesses, Reviews, and Landing Pages.
 * - Businesses and their associated subcollections are not publicly listable.
 * - Enforces SuperAdmin ownership of Businesses through the `superAdminId` field.
 * - Anonymous and Password Authentication are enabled.
 *
 * Denormalization for Authorization:
 * - The `Business` entity contains a `superAdminId` field to allow direct authorization checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to SuperAdmin profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - Authenticated user can create their own SuperAdmin profile if the ID matches their auth UID.
     * @allow (get, list, update, delete) - Only the SuperAdmin themselves can access their profile.
     * @deny (create) - An unauthenticated user cannot create a SuperAdmin profile.
     * @deny (update) - Another user cannot update a SuperAdmin profile.
     * @principle Enforces strict user-ownership and prevents unauthorized profile access.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(superAdminId) {
        return request.auth != null && request.auth.uid == superAdminId;
      }
      function isExistingOwner(superAdminId) {
        return isOwner(superAdminId) && resource != null;
      }

      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(superAdminId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Controls access to Business profiles.
     * @path /businesses/{businessId}
     * @allow (create) - SuperAdmin can create a business and must set the `superAdminId` field.
     * @allow (get, update, delete) - Only the owning SuperAdmin can access and modify the business profile.
     * @deny (create) - Unauthorized users can't create business profiles.
     * @deny (update, delete) - Other SuperAdmins cannot modify or delete the business.
     * @principle Enforces SuperAdmin ownership of Business profiles via the `superAdminId` field.
     */
    match /businesses/{businessId} {
      function isSuperAdminOwner(superAdminId) {
        return request.auth != null && request.auth.uid == superAdminId;
      }
      function isExistingSuperAdminOwner(superAdminId) {
        return isSuperAdminOwner(superAdminId) && resource != null;
      }

      allow get: if isSuperAdminOwner(resource.data.superAdminId);
      allow list: if false;
      allow create: if isSuperAdminOwner(request.resource.data.superAdminId);
      allow update: if isExistingSuperAdminOwner(resource.data.superAdminId) && request.resource.data.superAdminId == resource.data.superAdminId;
      allow delete: if isExistingSuperAdminOwner(resource.data.superAdminId);
    }

    /**
     * @description Controls access to Reviews for a specific business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) - The SuperAdmin who owns the Business can view the reviews.
     * @allow (create) - The SuperAdmin who owns the Business can create reviews.
     * @allow (update, delete) - Only the owning SuperAdmin can modify or delete reviews.
     * @deny (create, update, delete) - Other SuperAdmins cannot manage these reviews.
     * @principle Restricts access to Reviews based on the ownership of the parent Business.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
       function isSuperAdminOwnerOfBusiness(businessId) {
          return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
       }
        function isExistingSuperAdminOwnerOfBusiness(businessId) {
          return isSuperAdminOwnerOfBusiness(businessId) && resource != null;
        }

      allow get: if isSuperAdminOwnerOfBusiness(businessId);
      allow list: if isSuperAdminOwnerOfBusiness(businessId);
      allow create: if isSuperAdminOwnerOfBusiness(businessId);
      allow update: if isExistingSuperAdminOwnerOfBusiness(businessId);
      allow delete: if isExistingSuperAdminOwnerOfBusiness(businessId);
    }

    /**
     * @description Controls access to Landing Pages for a specific business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) - The SuperAdmin who owns the Business can view the landing pages.
     * @allow (create) - The SuperAdmin who owns the Business can create landing pages.
     * @allow (update, delete) - Only the owning SuperAdmin can modify or delete landing pages.
     * @deny (create, update, delete) - Other SuperAdmins cannot manage these landing pages.
     * @principle Restricts access to Landing Pages based on the ownership of the parent Business.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
       function isSuperAdminOwnerOfBusiness(businessId) {
          return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
       }
       function isExistingSuperAdminOwnerOfBusiness(businessId) {
          return isSuperAdminOwnerOfBusiness(businessId) && resource != null;
        }

      allow get: if isSuperAdminOwnerOfBusiness(businessId);
      allow list: if isSuperAdminOwnerOfBusiness(businessId);
      allow create: if isSuperAdminOwnerOfBusiness(businessId);
      allow update: if isExistingSuperAdminOwnerOfBusiness(businessId);
      allow delete: if isExistingSuperAdminOwnerOfBusiness(businessId);
    }
  }
}
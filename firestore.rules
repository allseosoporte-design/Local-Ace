
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    //------------------------------------------------------------------
    // Funciones de Ayuda Globales
    //------------------------------------------------------------------

    function isSuperAdmin() {
      return request.auth.uid != null && request.auth.token.isSuperAdmin == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Permite al Super Admin acceso total
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    //------------------------------------------------------------------
    // Colección de Usuarios
    //------------------------------------------------------------------
    match /users/{userId} {
      // Un usuario puede leer y escribir en su propio perfil
      allow read, write: if isOwner(userId);
    }
    
    //------------------------------------------------------------------
    // Colección de Negocios y Subcolecciones
    //------------------------------------------------------------------
    match /businesses/{businessId} {
      // El dueño del negocio puede leer/escribir su documento de negocio
      allow read, write: if isOwner(businessId);
      
      // Regla para la subcolección de landing pages
      match /landingPages/{pageId} {
        // Permitir lectura pública para la landing page del super admin 'allseosoporte'
        allow get: if businessId == 'allseosoporte';
        // El dueño del negocio puede gestionar sus propias landing pages
        allow read, write: if isOwner(businessId);
      }
    }

    //------------------------------------------------------------------
    // Reglas para Grupos de Colección (Collection Groups)
    //------------------------------------------------------------------

    // Regla para el grupo de colecciones 'internalFeedback'
    match /{path=**}/internalFeedback/{feedbackId} {
      // CUALQUIERA puede crear un feedback. Es una acción pública desde el embudo.
      allow create: if true;
      
      // SOLO el dueño del negocio puede LEER su propio feedback.
      // request.auth.uid es el ID del usuario que hace la petición.
      // resource.data.businessId es el campo guardado en el documento de feedback.
      allow get, list: if request.auth.uid == resource.data.businessId;
    }

    //------------------------------------------------------------------
    // Colecciones Públicas
    //------------------------------------------------------------------
    match /subscriptions/{subscriptionId} {
      // Cualquiera puede leer los planes de suscripción
      allow get, list: if true;
      // Nadie puede escribirlos directamente
      allow write: if false;
    }
  }
}

/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and businesses.
 * Businesses and associated entities can only be managed by authenticated users
 * who are linked to the business via their user profile. Public read access is not permitted
 * except for the subscriptions collection which is intended to be publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, linking auth ID to business ID.
 * - /businesses/{businessId}: Stores business information. Root collection for all business-related data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Stores internal feedback.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the authenticated user.
 * - Businesses and their associated data can only be created and managed by authenticated users.
 * - Subscriptions are publicly readable, but write access is restricted.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 * - The `businessId` is denormalized into the `UserProfile` to link a user's auth ID to a business.
 * - All subcollections under `/businesses/{businessId}` use the `businessId` in the path to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to user profiles based on ownership.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their own profile at /users/user123 with businessId set.
     * @allow (get, update, delete) User with UID 'user123' can read their own profile at /users/user123.
     * @deny (get, update, delete) User with UID 'user456' cannot read the profile at /users/user123.
     * @principle Enforces document ownership for reads and writes; self-creation allowed.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && resource != null && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Grants access to businesses based on ownership, using user profile link.
     * @path /businesses/{businessId}
     * @allow (create) User with UID 'user123' can create a business at /businesses/business123 if their profile links to it.
     * @allow (get, update, delete) User with UID 'user123' can read/write the business at /businesses/business123 if their profile links to it.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write the business at /businesses/business123 if their profile doesn't link to it.
     * @principle Enforces document ownership for reads and writes, validating against the user profile.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get: if isBusinessOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Grants access to Google My Business profiles based on business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User with UID 'user123' can create a profile at /googleMyBusinessProfiles/profile123 if they own the linked business.
     * @allow (get, update, delete) User with UID 'user123' can read/write the profile at /googleMyBusinessProfiles/profile123 if they own the linked business.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write the profile at /googleMyBusinessProfiles/profile123 if they don't own the linked business.
     * @principle Enforces document ownership for reads and writes, validating against the business ID.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
       function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
          return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      allow get: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if false;
      allow create: if isSignedIn() && isBusinessOwner(request.resource.data.businessId);
      allow update: if isSignedIn() && resource != null && isBusinessOwner(resource.data.businessId);
      allow delete: if isSignedIn() && resource != null && isBusinessOwner(resource.data.businessId);
    }

    /**
     * @description Grants access to reviews based on Google My Business profile ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) User with UID 'user123' can create a review at /googleMyBusinessProfiles/profile123/reviews/review123 if they own the linked profile.
     * @allow (get, update, delete) User with UID 'user123' can read/write the review at /googleMyBusinessProfiles/profile123/reviews/review123 if they own the linked profile.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write the review at /googleMyBusinessProfiles/profile123/reviews/review123 if they don't own the linked profile.
     * @principle Enforces document ownership for reads and writes, validating against the Google My Business profile ID.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
          return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      allow get: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow create: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && resource != null && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && resource != null && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
    }

    /**
     * @description Grants access to internal feedback based on business ownership.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (create) User with UID 'user123' can create feedback at /businesses/business123/internalFeedback/feedback123 if they own the business.
     * @allow (get, update, delete) User with UID 'user123' can read/write feedback at /businesses/business123/internalFeedback/feedback123 if they own the business.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write feedback at /businesses/business123/internalFeedback/feedback123 if they don't own the business.
     * @principle Enforces document ownership for reads and writes, validating against the business ID.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get: if isBusinessOwner(businessId);
      allow list: if isBusinessOwner(businessId);
      allow create: if isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Grants access to automated posts based on Google My Business profile ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) User with UID 'user123' can create a post at /googleMyBusinessProfiles/profile123/automatedPosts/post123 if they own the linked profile.
     * @allow (get, update, delete) User with UID 'user123' can read/write a post at /googleMyBusinessProfiles/profile123/automatedPosts/post123 if they own the linked profile.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write a post at /googleMyBusinessProfiles/profile123/automatedPosts/post123 if they don't own the linked profile.
     * @principle Enforces document ownership for reads and writes, validating against the Google My Business profile ID.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
          return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      allow get: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow create: if isSignedIn() && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && resource != null && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && resource != null && isBusinessOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
    }

    /**
     * @description Grants access to landing pages based on business ownership.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) User with UID 'user123' can create a page at /businesses/business123/landingPages/page123 if they own the business.
     * @allow (get, update, delete) User with UID 'user123' can read/write a page at /businesses/business123/landingPages/page123 if they own the business.
     * @deny (get, update, delete) User with UID 'user456' cannot read/write a page at /businesses/business123/landingPages/page123 if they don't own the business.
     * @principle Enforces document ownership for reads and writes, validating against the business ID.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      allow get: if isBusinessOwner(businessId);
      allow list: if isBusinessOwner(businessId);
      allow create: if isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Grants public read access to subscriptions, write access is denied.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Any user (signed in or not) can read subscription information.
     * @deny (create, update, delete) No user can create, update, or delete subscriptions.
     * @principle Allows public read access to subscription plans while restricting write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
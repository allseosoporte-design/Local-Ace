/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with super admins and business-level data segregation.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles.
 * - /businesses/{businessId}: Stores business profiles, owned by a super admin.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for a specific business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for a specific business.
 * - /subscriptionPlans/{planId}: Stores subscription plans, managed by super admins.
 *
 * Key Security Decisions:
 * - Super admins have full access to all business and review data.
 * - Businesses are owned by super admins, and only the owning super admin can modify business data.
 * - Read access to subscription plans is public, but write access is restricted to super admins.
 * - Listing of super admins is not permitted.
 *
 * Denormalization for Authorization:
 * - The `Business` entity contains a `superAdminId` field, which is used to directly authorize super admin access without requiring additional reads.
 *
 * Structural Segregation:
 * - Private data (business and review information) is stored under business-specific subcollections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the superAdmins collection, allowing only authenticated users to create their own document.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - Authenticated user creates their own superAdmin document.
     *    request.auth.uid = "user123"
     *    request.resource.data.id = "user123"
     * @deny (create) - Authenticated user tries to create a superAdmin document for another user.
     *    request.auth.uid = "user123"
     *    request.resource.data.id = "user456"
     * @deny (list) - Prevents listing of all superAdmin documents.
     * @principle Enforces strict user-ownership and prevents unauthorized data access.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSignedIn() && isOwner(superAdminId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(superAdminId) && request.resource.data.id == request.auth.uid;
      allow update: if isSignedIn() && isExistingOwner(superAdminId) && request.resource.data.id == resource.data.id;
      allow delete: if isSignedIn() && isExistingOwner(superAdminId);
    }

    /**
     * @description Secures the businesses collection, allowing only super admins to manage business data.
     * @path /businesses/{businessId}
     * @allow (create) - A super admin creates a new business.
     *    request.auth.uid = "superAdmin123"
     *    request.resource.data.superAdminId = "superAdmin123"
     * @allow (update) - A super admin updates a business they own.
     *    request.auth.uid = "superAdmin123"
     *    resource.data.superAdminId = "superAdmin123"
     * @deny (create) - A regular user tries to create a business.
     *    request.auth.uid = "user456"
     * @principle Restricts business management to authorized super admins.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.superAdminId == request.auth.uid;
      allow update: if isSignedIn() && isExistingSuperAdminForBusiness(businessId) && request.resource.data.superAdminId == resource.data.superAdminId;
      allow delete: if isSignedIn() && isExistingSuperAdminForBusiness(businessId);
    }

    /**
     * @description Secures the reviews subcollection, allowing only super admins to manage reviews for their businesses.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) - A super admin creates a review for their business.
     *    request.auth.uid = "superAdmin123"
     *    get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId = "superAdmin123"
     * @allow (update) - A super admin updates a review for their business.
     *    request.auth.uid = "superAdmin123"
     *    get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId = "superAdmin123"
     * @deny (create) - A regular user tries to create a review for a business.
     *    request.auth.uid = "user456"
     * @principle Restricts review management to the super admin of the associated business.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Secures the landingPages subcollection, allowing only super admins to manage landing pages for their businesses.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - A super admin creates a landing page for their business.
     *    request.auth.uid = "superAdmin123"
     *    get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId = "superAdmin123"
     * @allow (update) - A super admin updates a landing page for their business.
     *    request.auth.uid = "superAdmin123"
     *    get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId = "superAdmin123"
     * @deny (create) - A regular user tries to create a landing page for a business.
     *    request.auth.uid = "user456"
     * @principle Restricts landing page management to the super admin of the associated business.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Secures the subscriptionPlans collection, allowing public read access but restricting write access to super admins.
     * @path /subscriptionPlans/{planId}
     * @allow (get) - Any user can read subscription plan details.
     * @allow (create) - A super admin creates a new subscription plan.
     *    request.auth.uid = "superAdmin123"
     * @deny (create) - A regular user tries to create a subscription plan.
     *    request.auth.uid = "user456"
     * @principle Provides public read access to subscription plans while restricting management to authorized super admins.
     */
    match /subscriptionPlans/{planId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin() && resource != null;
      allow delete: if isSignedIn() && isSuperAdmin() && resource != null;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isSuperAdminForBusiness(businessId) {
      return isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
    }

     function isExistingSuperAdminForBusiness(businessId) {
        return isSuperAdminForBusiness(businessId) && resource != null;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a multi-tenant security model where access is primarily controlled at the business level.
 * Each user is associated with a business, and most data is nested under the /businesses/{businessId} path, ensuring data isolation.
 *
 * Data Structure:
 * - /users/{userId}: User profile data, linking users to businesses.
 * - /businesses/{businessId}: Business data, the root for business-specific resources.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profile data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Customer reviews for a Google My Business profile.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for Google My Business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages created for a business.
 * - /subscriptions/{subscriptionId}: Subscription plan data.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Data shape validation is relaxed in prototyping mode. Only authorization-critical fields are validated.
 * - The rules strongly emphasize ownership and business-level access control.
 *
 * Denormalization for Authorization:
 * The `businessId` field is present in multiple entities (UserProfile, GoogleMyBusinessProfile, LandingPage)
 * to avoid costly `get()` operations and enable simpler, more performant security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user_abc' can create their profile if their UID matches the {userId}. The data.id must equal their UID.
     * @allow (get, list) - User with UID 'user_abc' can read their profile data.
     * @allow (update, delete) - User with UID 'user_abc' can update their profile data.
     * @deny (create) - User with UID 'user_def' cannot create a profile with ID 'user_abc'.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows authorized access to business information.
     * @path /businesses/{businessId}
     * @allow (get, list) - Any authenticated user can read the business data.
     * @allow (create) - Any authenticated user can create a business. The data.id must equal the businessId.
     * @allow (update, delete) - Only the business admin (identified by adminEmail) can update or delete the business.
     * @deny (create) - User with UID 'user_def' cannot create a business with ID 'business_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /businesses/{businessId} {
      function isBusinessAdmin(businessId) {
        return request.auth.token.email == resource.data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == businessId && request.resource.data.adminEmail == request.auth.token.email;
      allow update: if isSignedIn() && isBusinessAdmin(businessId);
      allow delete: if isSignedIn() && isBusinessAdmin(businessId);
    }

    /**
     * @description Allows authorized access to Google My Business profile information.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) - Any authenticated user can read a Google My Business profile.
     * @allow (create) - Any authenticated user can create a Google My Business profile. The data.id must equal the googleMyBusinessProfileId.
     * @allow (update, delete) - Only the business admin can update or delete a Google My Business profile.
     * @deny (create) - User with UID 'user_def' cannot create a Google My Business profile with ID 'gmb_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isBusinessAdminForGMB(businessId) {
        return request.auth.token.email == get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
       allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == googleMyBusinessProfileId && request.resource.data.businessId is string;
      allow update: if isSignedIn() && isBusinessAdminForGMB(resource.data.businessId);
      allow delete: if isSignedIn() && isBusinessAdminForGMB(resource.data.businessId);
    }

    /**
     * @description Allows authorized access to customer reviews for a Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list) - Any authenticated user can read a review.
     * @allow (create) - Any authenticated user can create a review. The data.id must equal the reviewId.
     * @allow (update, delete) - Only the business admin can update or delete a review.
     * @deny (create) - User with UID 'user_def' cannot create a review with ID 'review_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isBusinessAdminForReview(businessId) {
        return request.auth.token.email == get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
       allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == reviewId;
      allow update: if isSignedIn() && isBusinessAdminForReview(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      allow delete: if isSignedIn() && isBusinessAdminForReview(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description Allows authorized access to internal feedback collected from customers.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Any authenticated user can read internal feedback.
     * @allow (create) - Any authenticated user can create internal feedback.  The data.id must equal the internalFeedbackId.
     * @allow (update, delete) - Only the business admin can update or delete internal feedback.
     * @deny (create) - User with UID 'user_def' cannot create internal feedback with ID 'feedback_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isBusinessAdmin(businessId) {
        return request.auth.token.email == get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == internalFeedbackId;
      allow update: if isSignedIn() && isBusinessAdmin(businessId);
      allow delete: if isSignedIn() && isBusinessAdmin(businessId);
    }

    /**
     * @description Allows authorized access to automated posts for a Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list) - Any authenticated user can read an automated post.
     * @allow (create) - Any authenticated user can create an automated post. The data.id must equal the automatedPostId.
     * @allow (update, delete) - Only the business admin can update or delete an automated post.
     * @deny (create) - User with UID 'user_def' cannot create an automated post with ID 'post_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isBusinessAdminForAutomatedPost(businessId) {
        return request.auth.token.email == get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
       allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == automatedPostId;
      allow update: if isSignedIn() && isBusinessAdminForAutomatedPost(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      allow delete: if isSignedIn() && isBusinessAdminForAutomatedPost(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description Allows authorized access to landing pages created for a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) - Any authenticated user can read a landing page.
     * @allow (create) - Any authenticated user can create a landing page. The data.id must equal the landingPageId.
     * @allow (update, delete) - Only the business admin can update or delete a landing page.
     * @deny (create) - User with UID 'user_def' cannot create a landing page with ID 'landing_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isBusinessAdmin(businessId) {
        return request.auth.token.email == get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail;
      }
      function isSignedIn() {
        return request.auth != null;
      }
       allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == landingPageId;
      allow update: if isSignedIn() && isBusinessAdmin(businessId);
      allow delete: if isSignedIn() && isBusinessAdmin(businessId);
    }

    /**
     * @description Allows authorized access to subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any authenticated user can read a subscription plan.
     * @allow (create) - Any authenticated user can create a subscription. The data.id must equal the subscriptionId.
     * @allow (update, delete) - No one can update or delete a subscription, effectively making them read-only after creation.
     * @deny (create) - User with UID 'user_def' cannot create a subscription with ID 'subscription_abc'.
     * @principle Enforces document ownership for writes and allows public read access.
     */
    match /subscriptions/{subscriptionId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == subscriptionId;
      allow update, delete: if false;
    }
  }
}
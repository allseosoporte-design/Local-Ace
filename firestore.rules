/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-association model.
 *
 * Data Structure:
 * - /products/{productId}: Products belonging to businesses.
 * - /users/{userId}: User profiles, linking users to businesses.
 * - /businesses/{businessId}: Business information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Reviews for Google My Business profiles.
 * - /internalFeedback/{internalFeedbackId}: Internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for Google My Business profiles.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for businesses.
 * - /subscriptions/{subscriptionId}: Subscription plans.
 * - /paymentSettings/{userId}: Payment settings for a user.
 *
 * Key Security Decisions:
 * - Strict ownership: Users can only access data associated with their business.
 * - No user listing: Listing users is disallowed for privacy.
 * - Public read-only: Subscriptions are publicly readable.
 *
 * Denormalization for Authorization:
 * - Products include `businessId` for authorization, avoiding `get()` calls to the `/businesses` collection.
 * - Reviews stored as subcollections of GoogleMyBusinessProfiles, and InternalFeedback includes businessId for independent authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows access to products, enforcing business ownership.
     * @path /products/{productId}
     * @allow (read) Any authenticated user can read any product.
     * @allow (create) Only authenticated users can create a product, and the `businessId` must match their own business.
     * @allow (update, delete) Only the business that owns the product can update or delete it.
     * @deny (create) An unauthenticated user cannot create a product.
     * @deny (update, delete) A user cannot update or delete a product they don't own.
     * @principle Enforces business ownership for product data.
     */
    match /products/{productId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdForUser();
      allow update: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
      allow delete: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
    }

    /**
     * @description Allows access to user profiles.
     * @path /users/{userId}
     * @allow (get) Only the user can read their own profile.
     * @allow (create) A user can create their own profile, but only if their auth UID matches the document ID.
     * @allow (update) A user can update their own profile.
     * @allow (delete) A user can delete their own profile.
     * @deny (get) A user cannot read another user's profile.
     * @deny (list) Listing all users is prohibited.
     * @deny (create) A user cannot create a profile for another user.
     * @deny (update, delete) A user cannot update or delete another user's profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.auth.uid == userId;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows access to business information.
     * @path /businesses/{businessId}
     * @allow (get) Any authenticated user can read business information.
     * @allow (create) Only authenticated user can create a business
     * @allow (update, delete) Only the authenticated admin can update or delete a business
     * @deny (create) An unauthenticated user cannot create a business.
     * @deny (update, delete) A user cannot update or delete a business that they are not the admin for.
     * @principle Enforces admin based access control for business data.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isBusinessAdmin(businessId);
      allow delete: if isSignedIn() && isBusinessAdmin(businessId);
    }

    /**
     * @description Allows access to Google My Business profiles, enforcing business association.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get) Any authenticated user can read a GMB profile.
     * @allow (create) Only authenticated users can create a GMB profile, and the `businessId` must match their own business.
     * @allow (update, delete) Only the business associated with the profile can update or delete it.
     * @deny (create) An unauthenticated user cannot create a GMB profile.
     * @deny (update, delete) A user cannot update or delete a GMB profile they don't own.
     * @principle Enforces business association for Google My Business profile data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdForUser();
      allow update: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
      allow delete: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
    }

    /**
     * @description Allows access to reviews for a Google My Business profile, enforcing business association.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list) Any authenticated user can read/list reviews for a GMB profile.
     * @allow (create) Only authenticated users can create a review, and the `businessId` of the parent GMB profile must match their own business.
     * @allow (update, delete) Only the business associated with the parent GMB profile can update or delete a review.
     * @deny (create) An unauthenticated user cannot create a review.
     * @deny (update, delete) A user cannot update or delete a review they don't own.
     * @principle Enforces business association for review data within a Google My Business profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
      allow update: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
      allow delete: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
    }

    /**
     * @description Allows access to internal feedback, enforcing business ownership.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get) Any authenticated user can read internal feedback.
     * @allow (create) Only authenticated users can create internal feedback, and the `businessId` must match their own business.
     * @allow (update, delete) Only the business that owns the internal feedback can update or delete it.
     * @deny (create) An unauthenticated user cannot create internal feedback.
     * @deny (update, delete) A user cannot update or delete internal feedback they don't own.
     * @principle Enforces business ownership for internal feedback data.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdForUser();
      allow update: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
      allow delete: if isSignedIn() && resource.data.businessId == getBusinessIdForUser();
    }

    /**
     * @description Allows access to automated posts for a Google My Business profile, enforcing business association.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list) Any authenticated user can read/list automated posts for a GMB profile.
     * @allow (create) Only authenticated users can create an automated post, and the `businessId` of the parent GMB profile must match their own business.
     * @allow (update, delete) Only the business associated with the parent GMB profile can update or delete an automated post.
     * @deny (create) An unauthenticated user cannot create an automated post.
     * @deny (update, delete) A user cannot update or delete an automated post they don't own.
     * @principle Enforces business association for automated post data within a Google My Business profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
      allow update: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
      allow delete: if isSignedIn() && getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) == getBusinessIdForUser();
    }

    /**
     * @description Allows access to landing pages for a business, enforcing business ownership.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) Any authenticated user can read/list landing pages for a business.
     * @allow (create) Only authenticated users can create a landing page, and the parent `businessId` must match their own business.
     * @allow (update, delete) Only the business that owns the landing page can update or delete it.
     * @deny (create) An unauthenticated user cannot create a landing page.
     * @deny (update, delete) A user cannot update or delete a landing page they don't own.
     * @principle Enforces business ownership for landing page data.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && getBusinessIdForUser() == businessId;
      allow update: if isSignedIn() && getBusinessIdForUser() == businessId;
      allow delete: if isSignedIn() && getBusinessIdForUser() == businessId;
    }

    /**
     * @description Allows public read access to subscription plans.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Any user can read subscription plan information.
     * @deny (create, update, delete) No user can create, update, or delete subscription plans.  These should be managed via a separate admin interface.
     * @principle Allows public read access to subscription plans.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false;
    }
    
    /**
     * @description Allows a user to read/write their own payment settings.
     * @path /paymentSettings/{userId}
     * @allow (get) Only the user can read their own payment settings.
     * @allow (create) A user can create their own payment settings, but only if their auth UID matches the document ID.
     * @allow (update) A user can update their own payment settings.
     * @allow (delete) A user can delete their own payment settings.
     * @deny (get) A user cannot read another user's payment settings.
     * @deny (list) Listing all payment settings is prohibited.
     * @deny (create) A user cannot create payment settings for another user.
     * @deny (update, delete) A user cannot update or delete another user's payment settings.
     * @principle Restricts access to a user's own payment settings.
     */
    match /paymentSettings/{userId} {
        allow get: if isSignedIn() && isOwner(userId);
        allow list: if false;
        allow create: if isSignedIn() && isOwner(userId) && request.auth.uid == userId;
        allow update: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(documentId, userId) {
        return isOwner(userId) && resource != null && resource.data.id == documentId;
    }

    function isBusinessAdmin(businessId) {
        // TODO: Implement logic to check if the user is an admin for the business.
        // This might involve checking a field in the business document or a separate admin role collection.
        // For now, deny all access.
        return false;
    }

    function getBusinessIdForUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    function getBusinessIdForGoogleMyBusinessProfile(googleMyBusinessProfileId) {
      return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
    }
  }
}
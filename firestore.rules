rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) - If the user's auth UID matches the userId.
     * @allow (get, update, delete) - If the user's auth UID matches the userId.
     * @deny (list) - Prevents listing all users.
     * @deny (create, update, delete) - If the user's auth UID does not match the userId.
     * @principle Enforces document ownership for writes and reads.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows businesses to manage their information.
     * @path /businesses/{businessId}
     * @allow (create) - If the user is authenticated.
     * @allow (get, list, update, delete) - If the user is authenticated.
     * @deny (create, update, delete) - If the user is not authenticated.
     * @principle Enforces authentication for all operations.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows businesses to manage their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - If the user is authenticated.
     * @allow (get, list, update, delete) - If the user is authenticated.
     * @deny (create, update, delete) - If the user is not authenticated.
     * @principle Enforces authentication for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows businesses to manage reviews for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - If the user is authenticated.
     * @allow (get, list, update, delete) - If the user is authenticated.
     * @deny (create, update, delete) - If the user is not authenticated.
     * @principle Enforces authentication for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows authenticated users to read internal feedback.
     * Security is enforced at query level in the application using where('businessId', '==', user.uid).
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Authenticated users can read feedback.
     * @deny (create, update, delete) - No user can create, update, or delete internal feedback through client.
     * @principle Client-side query filtering ensures users only see their own feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if request.auth != null;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows businesses to manage automated posts for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - If the user is authenticated.
     * @allow (get, list, update, delete) - If the user is authenticated.
     * @deny (create, update, delete) - If the user is not authenticated.
     * @principle Enforces authentication for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows businesses to manage landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - If the user is authenticated.
     * @allow (get, list, update, delete) - If the user is authenticated.
     * @deny (create, update, delete) - If the user is not authenticated.
     * @principle Enforces authentication for all operations.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows public read access to subscription information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - No user can create, update, or delete subscription data.
     * @principle Grants public read access.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model where superadmins, identified by a document in `/users/{userId}`, have elevated privileges.
 * Businesses and their related data (reviews, landing pages) are accessible only to superadmins.
 *
 * Data Structure:
 * - /users/{userId}: Stores user information, including roles (e.g., 'superadmin').
 * - /businesses/{businessId}: Stores business data; only accessible to superadmins.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for a business; only accessible to superadmins.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for a business; only accessible to superadmins.
 * - /subscriptionPlans/{planId}: Stores subscription plans; only accessible to superadmins.
 *
 * Key Security Decisions:
 * - Superadmin Role: Users with the 'superadmin' role in their `/users/{userId}` document are granted full read/write access to businesses, reviews, landing pages, and subscription plans.
 * - Read and write access is limited to authenticated users.
 * - No specific data validation is performed in this prototyping phase beyond authorization checks.
 *
 * Denormalization for Authorization:
 * - Relies on the `get()` function to fetch the user's role from the `/users/{userId}` document and enforces this role in the rules.
 *
 * Structural Segregation:
 * - No explicit segregation between public and private data is implemented.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants read and write access to users collection for authenticated users.
     * @path /users/{userId}
     * @allow (read, write): if request.auth != null
     * @deny (read, write): if request.auth == null
     * @principle Authenticated users only.
     */
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    /**
     * @description Allows superadmins to read and write business data.
     * @path /businesses/{businessId}
     * @allow (read, write): if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
     * @deny (read, write): if request.auth == null || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'superadmin'
     * @principle Superadmin access to business data.
     */
    match /businesses/{businessId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';

      /**
       * @description Allows superadmins to read and write subcollections under businesses.
       * @path /businesses/{businessId}/{document=**}
       * @allow (read, write): if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
       * @deny (read, write): if request.auth == null || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'superadmin'
       * @principle Superadmin access to business subcollections.
       */
      match /{document=**} {
        allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
      }
    }

    /**
     * @description Allows superadmins to read and write subscription plan data.
     * @path /subscriptionPlans/{planId}
     * @allow (read, write): if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin'
     * @deny (read, write): if request.auth == null || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'superadmin'
     * @principle Superadmin access to subscription plans.
     */
    match /subscriptionPlans/{planId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }
  }
}
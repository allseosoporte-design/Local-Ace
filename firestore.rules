/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset enforces a strict ownership model for most data,
 * with users only able to access data related to their business. Public read access
 * is granted for landing pages.
 *
 * @data_structure The data is organized hierarchically, with businesses as the root.
 * User profiles link users to businesses. Google My Business profiles, reviews,
 * automated posts, and landing pages are stored under their respective business.
 * Internal feedback is stored at the root to avoid authorization dependency.
 *
 * @key_security_decisions
 * - User listing is disallowed.
 * - Owner-only access is enforced for most write operations.
 * - Landing pages are publicly readable.
 * - De-normalization: The 'businessId' is present in user profiles and GoogleMyBusinessProfile documents to simplify authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their profile with businessId set.
     * @deny (create) User with UID 'user123' cannot create a profile with a mismatched userId.
     * @principle Enforces document ownership for writes and validates relational integrity.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is disallowed.
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isOwner(userId) && isSignedIn() && request.resource.data.id == userId; // Ensure userId cannot be changed.
      allow delete: if false;
    }

    /**
     * @description Allows authenticated users to read a landing page, and only allows the business owner to manage their own landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get) Any user can read the landing page.
     * @allow (create) User with UID 'user123' can create a landing page for their business if they are the owner.
     * @deny (create) User with UID 'user456' cannot create a landing page for another business.
     * @principle Public read with owner-only writes.  Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
        function isSignedIn() {
            return request.auth != null;
        }
    
        function isOwner(businessId) {
            return request.auth.uid == businessId;
        }

      allow get: if true;
      allow list: if true;
        allow create: if isSignedIn() && request.resource.data.businessId == businessId;
        allow update: if isSignedIn() && isOwner(businessId) && request.resource.data.businessId == businessId;
        allow delete: if isSignedIn() && isOwner(businessId) && request.resource.data.businessId == businessId;
    }
    
    /**
     * @description Allows the business owner to manage their own business data.
     * @path /businesses/{businessId}
     * @allow (create) User with UID 'user123' can create their business if they are the owner.
     * @deny (update) User with UID 'user456' cannot update another business's data.
     * @principle Enforces document ownership for all operations.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId) && request.resource.data.id == request.auth.uid;
      allow update: if isOwner(businessId) && isSignedIn();
      allow delete: if isOwner(businessId) && isSignedIn();
    }

    /**
     * @description Allows the business owner to manage their Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User with UID 'user123' can create a Google My Business profile for their business.
     * @deny (update) User with UID 'user456' cannot update another business's Google My Business profile.
     * @principle Enforces document ownership.  Business ID is stored to simplify authorization.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      allow get: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(request.resource.data.businessId);
      allow delete: if isSignedIn() && isOwner(request.resource.data.businessId);
    }

    /**
     * @description Allows the business owner to manage reviews for their Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) User with UID 'user123' can create a review for their Google My Business profile.
     * @deny (update) User with UID 'user456' cannot update reviews for another business's Google My Business profile.
     * @principle Enforces document ownership.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

     function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      allow get: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow list: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.googleMyBusinessProfileId == googleMyBusinessProfileId;
      allow update: if isSignedIn() && isOwner(request.resource.data.businessId);
      allow delete: if isSignedIn() && isOwner(request.resource.data.businessId);
    }

    /**
     * @description Allows only authenticated users to create internal feedback.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any signed in user can create an internal feedback.
     * @deny (get) Anonymous users cannot access InternalFeedback
     *
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows the business owner to manage automated posts for their Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) User with UID 'user123' can create an automated post for their Google My Business profile.
     * @deny (update) User with UID 'user456' cannot update automated posts for another business's Google My Business profile.
     * @principle Enforces document ownership.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      allow get: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow list: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.googleMyBusinessProfileId == googleMyBusinessProfileId;
      allow update: if isSignedIn() && isOwner(request.resource.data.businessId);
      allow delete: if isSignedIn() && isOwner(request.resource.data.businessId);
    }

    /**
     * @description Allows the owner to read a subscription plan.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Any user can read the subscription plan.
     * @deny (create) No user can create a subscription plan.
     * @principle Public read.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to all landing pages
     * @path /businesses/{businessId}/landingPages/{landingPageId}/hero
     * @allow (get) Any user can read the landing page.
     * @deny (create) Should not be possible because there is no rule for it.
     * @principle public read
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/hero {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
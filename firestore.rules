/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with superadmin privileges and ownership-based restrictions.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super administrator profiles. Superadmins have full access to all data.
 * - /businesses/{businessId}: Stores business profiles, accessible only to superadmins.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for businesses, accessible only to superadmins.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for businesses, accessible only to superadmins.
 * - /subscriptionPlans/{planId}: Stores subscription plans, accessible only to superadmins.
 *
 * Key Security Decisions:
 * - Superadmins are granted full read/write access to all collections.  The existence of a superadmin document grants admin privileges.
 * - Regular users (business users) are not explicitly modeled and have no access under these rules.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 * - The `businesses` collection could potentially contain a `superAdminId` field, although not explicitly defined.
 *
 * Structural Segregation:
 * - Superadmins and business data are stored in separate top-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by a super admin.
     * @details Checks if the user is authenticated and if a corresponding document exists in the /superAdmins collection.
     * @returns {boolean} True if the user is a super admin, false otherwise.
     */
    function isSuperAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    /**
     * @description Rules for the /superAdmins collection.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A super admin can create their own document if their auth UID matches the document ID.
     * @allow (get, list) - Any authenticated user can read a super admin profile.
     * @allow (update, delete) - Only the super admin themselves can update or delete their profile.
     * @deny (create) - Any user attempting to create a super admin document with an ID that doesn't match their auth UID.
     * @principle Enforces document ownership and restricts access to a user's own data tree.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if request.auth.uid == superAdminId;
      allow update: if request.auth.uid == superAdminId && resource != null;
      allow delete: if request.auth.uid == superAdminId && resource != null;
    }

    /**
     * @description Rules for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (create) - Only a super admin can create a business.
     * @allow (get, list) - Any authenticated user can read businesses.
     * @allow (update, delete) - Only a super admin can update or delete a business.
     * @deny (create) - Non-superadmins cannot create business documents.
     * @principle Enforces superadmin-only access for managing businesses.
     */
    match /businesses/{businessId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    /**
     * @description Rules for the /businesses/{businessId}/reviews collection.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) - Only a super admin can create a review for a business.
     * @allow (get, list) - Any authenticated user can read reviews for a business.
     * @allow (update, delete) - Only a super admin can update or delete a review.
     * @deny (create) - Non-superadmins cannot create review documents.
     * @principle Enforces superadmin-only access for managing reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Only a super admin can create a landing page for a business.
     * @allow (get, list) - Any authenticated user can read landing pages for a business.
     * @allow (update, delete) - Only a super admin can update or delete a landing page.
     * @deny (create) - Non-superadmins cannot create landing page documents.
     * @principle Enforces superadmin-only access for managing landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    /**
     * @description Rules for the /subscriptionPlans collection.
     * @path /subscriptionPlans/{planId}
     * @allow (create) - Only a super admin can create a subscription plan.
     * @allow (get, list) - Any authenticated user can read subscription plans.
     * @allow (update, delete) - Only a super admin can update or delete a subscription plan.
     * @deny (create) - Non-superadmins cannot create subscription plan documents.
     * @principle Enforces superadmin-only access for managing subscription plans.
     */
    match /subscriptionPlans/{planId} {
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    /**
     * @description Catches any other documents that are not explicitly defined.
     * @path /{document=**}
     * @deny (get, list, create, update, delete) - Denies all access.
     * @principle Default deny for all other paths.
     */
    match /{document=**} {
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Checks if the user is signed in.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
/**
 * @file Firebase Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model with super-admin privileges.
 * Super admins, identified by their presence in the `/superAdmins` collection, have broad access.
 * Data is primarily organized hierarchically under `/businesses/{businessId}`, and ownership is
 * enforced using denormalized `superAdminId` fields on business documents to avoid costly `get()` calls.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles.  Existence implies admin privileges.
 * - /businesses/{businessId}: Stores business profiles, with a `superAdminId` field indicating ownership.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for a business.
 *
 * Key Security Decisions:
 * - Super admins have full CRUD access to businesses, reviews, and landing pages.
 * - Listing businesses is restricted to super admins.
 * - The ruleset trusts the `superAdminId` field on the business document for authorization.
 *
 * Denormalization for Authorization:
 * - The `superAdminId` field is denormalized onto the `Business` document. This allows rules to quickly check
 *   if the requesting user is the owner of the business without needing to perform additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows super admins to manage their profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (get, create, update, delete) if the user is the owner.
     * @deny (get, create, update, delete) if the user is not the owner.
     * @principle Enforces document ownership for all operations.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(superAdminId) {
        return request.auth != null && request.auth.uid == superAdminId;
      }
      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isOwner(superAdminId);
      allow delete: if isOwner(superAdminId);
    }

    /**
     * @description Allows super admins to manage businesses.
     * @path /businesses/{businessId}
     * @allow (get, list, create, update, delete) if the user is a super admin.
     * @deny (get, list, create, update, delete) if the user is not a super admin.
     * @principle Super admins can manage all businesses.
     */
    match /businesses/{businessId} {
      function isSuperAdmin() {
        return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }
      allow get, list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() && resource != null;
      allow delete: if isSuperAdmin() && resource != null;
    }

    /**
     * @description Allows super admins to manage reviews for a specific business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list, create, update, delete) if the user is the super admin of the business.
     * @deny (get, list, create, update, delete) if the user is not the super admin of the business.
     * @principle Super admins can manage reviews for businesses they own.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSuperAdminForBusiness(businessId) {
        return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid))
               && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get, list: if isSuperAdminForBusiness(businessId);
      allow create: if isSuperAdminForBusiness(businessId);
      allow update: if isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Allows super admins to manage landing pages for a specific business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list, create, update, delete) if the user is the super admin of the business.
     * @deny (get, list, create, update, delete) if the user is not the super admin of the business.
     * @principle Super admins can manage landing pages for businesses they own.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSuperAdminForBusiness(businessId) {
        return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid))
               && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get, list: if isSuperAdminForBusiness(businessId);
      allow create: if isSuperAdminForBusiness(businessId);
      allow update: if isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSuperAdminForBusiness(businessId) && resource != null;
    }
  }
}
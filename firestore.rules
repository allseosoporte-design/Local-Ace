/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for business-related data,
 * while also allowing public read access to certain collections like Subscriptions and Landing Pages.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data, owned by the user with matching UID.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores profiles, linked to businesses via the businessId field.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Subcollection for reviews, accessible to the business owner.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback, publicly writable.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Subcollection for automated posts, accessible to the business owner.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for landing pages, publicly readable but owner-writable.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information, publicly readable.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Public read access is granted to the /subscriptions and /businesses/{businessId}/landingPages collections.
 * - The rules enforce ownership for all write operations on business-related data.
 * - Reviews of a GMB profile are accessible only to the business that owns the GMB profile.
 *
 * Denormalization for Authorization:
 * - The `businessId` is denormalized into the `GoogleMyBusinessProfile` document to allow
 *   authorization checks without additional `get()` calls.
 *
 * Structural Segregation:
 * - Internal feedback is stored in a separate root collection (/internalFeedback) to allow public write access
 *   without compromising the security of business-owned data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(businessId) {
      return request.auth.uid == businessId;
    }

    function isExistingOwner(businessId) {
      return isOwner(businessId) && resource != null;
    }

    /**
     * @description Rules for the /subscriptions collection.  Allows public read access.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Any user can read subscription information.
     * @deny (create, update, delete) No user can create, update, or delete subscriptions.
     * @principle Grants public read access to subscription data.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rules for the /businesses collection. Enforces owner-only access.
     * @path /businesses/{businessId}
     * @allow (get, list) The user with the matching UID can read the business document.
     * @allow (create) The user with the matching UID can create the business document.
     * @deny (update, delete) Only the owner can update or delete the business document.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      /**
       * @description Rules for the /businesses/{businessId}/landingPages collection. Allows public read, owner write.
       * @path /businesses/{businessId}/landingPages/{landingPageId}
       * @allow (get, list) Any user can read landing page information.
       * @allow (create, update, delete) Only the owner can create, update, or delete landing pages.
       * @deny (create) Request must have valid data.
       * @principle Grants public read access to landing pages, enforces ownership for writes.
       */
      match /landingPages/{landingPageId} {
        allow get, list: if true;
        allow create: if isOwner(businessId);
        allow update: if isOwner(businessId);
        allow delete: if isOwner(businessId);
      }
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles collection. Enforces owner-only access based on the businessId field.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) The user with the matching UID can read the profile if they own the business.
     * @allow (create) The user with the matching UID can create the profile if they own the business. The businessId in the request data must match the user's UID.
     * @deny (update, delete) Only the owner can update or delete the profile, and the businessId cannot be changed.
     * @principle Enforces document ownership and validates relational integrity.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if request.auth.uid == resource.data.businessId;
      allow create: if request.auth.uid == request.resource.data.businessId;
      allow update: if request.auth.uid == resource.data.businessId && resource != null;
      allow delete: if request.auth.uid == resource.data.businessId && resource != null;

      /**
       * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection. Enforces owner-only access based on the businessId field in the parent document.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       * @allow (get, list) The user with the matching UID can read the review if they own the business associated with the profile.
       * @allow (create) The user with the matching UID can create the review if they own the business associated with the profile.
       * @deny (update, delete) Only the owner can update or delete the review.
       * @principle Enforces document ownership for writes.
       */
      match /reviews/{reviewId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }

      /**
       * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection. Enforces owner-only access based on the businessId field in the parent document.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * @allow (get, list) The user with the matching UID can read the post if they own the business associated with the profile.
       * @allow (create) The user with the matching UID can create the post if they own the business associated with the profile.
       * @deny (update, delete) Only the owner can update or delete the post.
       * @principle Enforces document ownership for writes.
       */
      match /automatedPosts/{automatedPostId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }
    }

    /**
     * @description Rules for the /internalFeedback collection.  Allows public write access for collecting feedback.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) Any user can read internal feedback.
     * @allow (create) Any signed-in user can create internal feedback.
     * @deny (update, delete) No user can update or delete internal feedback.
     * @principle Grants public write access for collecting feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
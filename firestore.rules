/**
 * @fileoverview Firestore Security Rules for the Local Leap application.
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control (RBAC) model with super admins and an ownership model for businesses and their associated data. Super admins have broad access, while businesses primarily have read access, and the super admin of a business has write access.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles. Super admins can manage businesses and subscription plans.
 * - /businesses/{businessId}: Stores business profiles, including a denormalized superAdminId for simpler authorization.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews associated with a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages associated with a business.
 * - /subscriptionPlans/{planId}: Stores subscription plans.
 *
 * Key Security Decisions:
 * - Super admins are granted database-wide admin privileges based on their existence in the `/superAdmins` collection.
 * - Read access to subscription plans is public.
 * - Strict ownership is enforced for businesses, reviews, and landing pages, with the super admin controlling write access.
 * - Listing of super admins is disallowed for security reasons.
 *
 * Denormalization for Authorization:
 * - Business documents include a `superAdminId` field to avoid needing to perform `get()` operations to determine the owner. This enables fast, simple rules based on the `superAdminId`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rule for super admin accounts. Only the super admin can read/write their own document. Listing is denied.
     * @path /superAdmins/{superAdminId}
     * @allow (create, get, update, delete) if the user is signed in and their UID matches the superAdminId.
     * @deny (create, get, update, delete) if the user is not signed in or their UID does not match the superAdminId.
     * @principle Enforces user-ownership for super admin profiles.
     */
    match /superAdmins/{superAdminId} {
      // Only allow authenticated users
      allow create: if isSignedIn() && request.auth.uid == superAdminId;
      allow get: if isSignedIn() && request.auth.uid == superAdminId;
      allow update: if isSignedIn() && isExistingOwner(superAdminId);
      allow delete: if isSignedIn() && isExistingOwner(superAdminId);
      allow list: if false; // Listing super admins is not permitted.
    }

    /**
     * @description Rule for business accounts. Super admins can create, read, update, and delete businesses.
     * @path /businesses/{businessId}
     * @allow (create) if the user is a super admin and the request data contains a valid 'superAdminId'.
     * @allow (get, list) if the user is a super admin.
     * @allow (update, delete) if the user is a super admin and owns the business.
     * @deny (create, get, update, delete) if the user is not a super admin.
     * @principle Enforces super admin control over business profiles.
     */
    match /businesses/{businessId} {
      allow create: if isSignedIn() && isSuperAdmin() && request.resource.data.superAdminId == request.auth.uid;
      allow get, list: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin() && isExistingOwner(resource.data.superAdminId);
      allow delete: if isSignedIn() && isSuperAdmin() && isExistingOwner(resource.data.superAdminId);
    }

    /**
     * @description Rule for reviews associated with a business. Only super admins can create, read, update, and delete reviews for their businesses.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) if the user is a super admin and owns the business.
     * @allow (get, list) if the user is a super admin and owns the business.
     * @allow (update, delete) if the user is a super admin and owns the business.
     * @deny (create, get, update, delete) if the user is not a super admin or does not own the business.
     * @principle Enforces super admin control over reviews for their businesses.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow get, list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Rule for landing pages associated with a business. Only super admins can create, read, update, and delete landing pages for their businesses.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) if the user is a super admin and owns the business.
     * @allow (get, list) if the user is a super admin and owns the business.
     * @allow (update, delete) if the user is a super admin and owns the business.
     * @deny (create, get, update, delete) if the user is not a super admin or does not own the business.
     * @principle Enforces super admin control over landing pages for their businesses.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow get, list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Rule for subscription plans.  Super admins can create, read, update and delete plans.  Other users can read plans.
     * @path /subscriptionPlans/{planId}
     * @allow (create, update, delete) if the user is a super admin.
     * @allow (get, list) if true (public read).
     * @deny (create, update, delete) if the user is not a super admin.
     * @principle Enforces super admin control over subscription plans, with public read access.
     */
    match /subscriptionPlans/{planId} {
      allow create: if isSignedIn() && isSuperAdmin();
      allow get, list: if true;
      allow update: if isSignedIn() && isSuperAdmin() && resource != null;
      allow delete: if isSignedIn() && isSuperAdmin() && resource != null;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isSuperAdmin() {
        return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isSuperAdminForBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      // Check for the custom claim instead of document existence.
      return request.auth != null && request.auth.token.isSuperAdmin == true;
    }
    
    match /superAdmins/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }

    match /adminConfig/{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Allow read access for everyone, and write access for super admins
    match /subscriptionPlans/{planId} {
      allow list, get: if true;
      allow write: if isSuperAdmin();
    }
    
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == businessId || isSuperAdmin());
      
      match /catalogConfig/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.uid == businessId || isSuperAdmin());
      }
      
      match /contactForm/{document=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /contactSubmissions/{submissionId} {
        allow create: if true;
        allow read, delete: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /contactForms/{formId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
      
      match /landingPages/{pageId} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.uid == businessId || isSuperAdmin());
      }
    }
    
    match /googleMyBusinessProfiles/{profileId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == profileId || isSuperAdmin());
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if request.auth != null && (request.auth.uid == profileId || isSuperAdmin());
      }
    }
    
    match /globalAuditLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }
    
    match /backups/{backupId} {
      allow read, write, delete: if isSuperAdmin();
    }
    
    match /chatbot/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
    
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
    }
    
    // Internal Feedback Collection: Allow public creation, but only owner/admin can read/delete
    match /internalFeedback/{feedbackId} {
      allow create: if true;
      allow read, delete: if request.auth != null && (resource.data.businessId == request.auth.uid || isSuperAdmin());
      allow list: if request.auth != null; // Allow listing only if authenticated
    }
    
    match /products/{productId} {
      allow read: if resource.data.businessId == 'DzH9Kc6eYqOih5Y705ebM0SzfZf2' || 
                     (request.auth != null && request.auth.uid == resource.data.businessId) || 
                     isSuperAdmin();
      allow write: if request.auth != null && (request.auth.uid == request.resource.data.businessId || isSuperAdmin());
    }

    match /pendingPayments/{paymentId} {
      // Allow superadmins to read and write
      allow read, write: if isSuperAdmin();
    }
    
    match /subscriptions/{subscriptionId} {
      // Superadmins can do anything. Users can read their own subscriptions.
      allow read: if isSuperAdmin() || (request.auth != null && resource.data.empresaId == request.auth.uid);
      allow write: if isSuperAdmin();
    }

    match /supportTickets/{ticketId} {
      allow read, write: if isSuperAdmin();
      allow create: if true;
    }
    
    match /paymentSettings/{userId} {
      allow read: if userId == 'DzH9Kc6eYqOih5Y705ebM0SzfZf2' || 
                     (request.auth != null && request.auth.uid == userId) ||
                     isSuperAdmin();
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
    }

    match /automatedPosts/{postId} {
      allow get: if request.auth != null && resource.data.businessId == request.auth.uid;
      allow list: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.businessId == request.auth.uid;
    }
  }
}

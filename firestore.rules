rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to business documents. Only the business owner can create, update, or delete a business.
     * @path /businesses/{businessId}
     */
    match /businesses/{businessId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == resource.data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Controls access to review documents. Only the business owner can create, update, or delete a review.
     * @path /businesses/{businessId}/reviews/{reviewId}
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    /**
     * @description Controls access to Google Business Profile documents. Only the business owner can create, update, or delete a profile.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    /**
     * @description Controls access to post documents. Only the business owner can create, update, or delete a post.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    /**
     * @description Controls access to landing page documents. Only the business owner can create, update, or delete a landing page.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    /**
     * @description Controls access to contact form documents. Only the business owner can create, update, or delete a contact form.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      // Helper function to check if the user is signed in.
      function isSignedIn() {
        return request.auth != null;
      }

      // Helper function to check if the user is the owner of the business.
      function isOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      // Helper function to check if the user is the owner of an existing business.
      function isExistingOwner(businessId) {
        return request.auth.uid == get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update, delete: if isOwner(businessId);
    }

    /**
     * @description Controls access to subscription plan documents. Subscription plans are publicly readable but not writable.
     * @path /subscriptionPlans/{subscriptionPlanId}
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for business-related data,
 * and public read access for subscription data. It prioritizes authorization
 * independence using denormalization to avoid costly `get()` calls.
 *
 * Data Structure:
 * - /subscriptions/{subscriptionId}: Publicly readable subscription plan information.
 * - /businesses/{businessId}: Business information, accessible only to the owner.
 *   - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for a business,
 *     accessible only to the business owner.
 *   - /businesses/{businessId}/privateFeedback/{feedbackId}: Private feedback for a business,
 *     accessible only to the business owner, creation is public.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profile information,
 *   accessible only to the associated business owner.
 *   - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Reviews for a
 *     Google My Business profile, accessible only to the associated business owner.
 *   - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}:
 *     Automated posts for a Google My Business profile, accessible only to the associated
 *     business owner.
 * - /internalFeedback/{internalFeedbackId}: Internal feedback, publicly writable, but not listable.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Read-only collections (subscriptions) are publicly readable.
 * - The default security posture for ambiguous relationships is strict owner-only access.
 * - Denormalization is used to avoid `get()` calls in rules, improving performance and security.
 *
 * Denormalization for Authorization:
 * - The `businessId` field is present on `GoogleMyBusinessProfile` documents to allow
 *   authorization checks without needing to fetch the `Business` document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} resourceId - The ID of the resource owner.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(resourceId) {
      return request.auth.uid == resourceId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource.
     * @param {string} resourceId - The ID of the resource owner.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(resourceId) {
      return isOwner(resourceId) && resource != null;
    }

    /**
     * @description Security rules for the /subscriptions collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Public read access.
     * @deny (create, update, delete) No write access.
     * @principle Public read-only collection.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Security rules for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (get, list) Owner can read.
     * @allow (create) Owner can create.
     * @allow (update) Owner can update.
     * @allow (delete) Owner can delete.
     * @deny Non-owner cannot read, create, update, or delete.
     * @principle Enforces document ownership for all operations.
     */
    match /businesses/{businessId} {
      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      /**
       * @description Security rules for the /businesses/{businessId}/landingPages collection.
       * @path /businesses/{businessId}/landingPages/{landingPageId}
       * @allow (get, list) Owner can read.
       * @allow (create) Owner can create.
       * @allow (update) Owner can update.
       * @allow (delete) Owner can delete.
       * @deny Non-owner cannot read, create, update, or delete.
       * @principle Enforces document ownership for all operations.
       */
      match /landingPages/{landingPageId} {
        allow get, list: if isOwner(businessId);
        allow create: if isOwner(businessId);
        allow update: if isExistingOwner(businessId);
        allow delete: if isExistingOwner(businessId);
      }

      /**
       * @description Security rules for the /businesses/{businessId}/privateFeedback collection.
       * @path /businesses/{businessId}/privateFeedback/{feedbackId}
       * @allow (get, list) Owner can read.
       * @allow (create) Public can create.
       * @allow (update) Owner can update.
       * @allow (delete) Owner can delete.
       * @deny Non-owner cannot read, update, or delete.
       * @principle Allows public creation of feedback, but restricts other operations to the owner.
       */
      match /privateFeedback/{feedbackId} {
        allow get, list: if isOwner(businessId);
        allow create: if true;
        allow update: if isExistingOwner(businessId);
        allow delete: if isExistingOwner(businessId);
      }
    }

    /**
     * @description Security rules for the /googleMyBusinessProfiles collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) Owner can read.
     * @allow (create) Owner can create.
     * @allow (update) Owner can update.
     * @allow (delete) Owner can delete.
     * @deny Non-owner cannot read, create, update, or delete.
     * @principle Enforces document ownership for all operations.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if request.auth.uid == resource.data.businessId;
      allow create: if request.auth.uid == request.resource.data.businessId;
      allow update: if request.auth.uid == resource.data.businessId && resource != null;
      allow delete: if request.auth.uid == resource.data.businessId && resource != null;

      /**
       * @description Security rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       * @allow (get, list) Owner can read.
       * @allow (create) Owner can create.
       * @allow (update) Owner can update.
       * @allow (delete) Owner can delete.
       * @deny Non-owner cannot read, create, update, or delete.
       * @principle Enforces document ownership for all operations.
       */
      match /reviews/{reviewId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }

      /**
       * @description Security rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * @allow (get, list) Owner can read.
       * @allow (create) Owner can create.
       * @allow (update) Owner can update.
       * @allow (delete) Owner can delete.
       * @deny Non-owner cannot read, create, update, or delete.
       * @principle Enforces document ownership for all operations.
       */
      match /automatedPosts/{automatedPostId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }
    }

    /**
     * @description Security rules for the /internalFeedback collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) Public read access.
     * @allow (create) Signed-in user can create.
     * @deny (update, delete) No update or delete access.
     * @principle Allows public feedback submission from signed-in users, but no modifications.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
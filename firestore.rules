/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and businesses.
 * Businesses and associated entities can only be managed by authenticated users
 * who are linked to the business via their user profile. Public read access is not permitted
 * except for the subscriptions collection which is intended to be publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, linking auth ID to business ID.
 * - /businesses/{businessId}: Stores business information. Root collection for all business-related data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback from the funnel.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the authenticated user.
 * - Businesses and their associated data can only be created and managed by authenticated users.
 * - Subscriptions are publicly readable, but write access is restricted.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 * - The `businessId` is denormalized into the `UserProfile` to link a user's auth ID to a business.
 * - All subcollections under `/businesses/{businessId}` use the `businessId` in the path to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.isSuperAdmin == true;
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    // A user can only access their own user profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Businesses can be read by anyone, but only written to by the owner or super admin
    match /businesses/{businessId} {
      allow read: if true;
      allow write: if (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId) || isSuperAdmin();
    }
    
    // Landing pages for the main company (allseosoporte) are public
    match /businesses/allseosoporte/landingPages/{pageId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Internal feedback can be created by anyone, but only read by the business owner
    match /businesses/{businessId}/internalFeedback/{feedbackId} {
        allow create: if true; // Anyone can submit feedback
        allow read, update, delete: if (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId) || isSuperAdmin();
    }
    
    match /internalFeedback/{feedbackId} {
      // Allow anyone to create feedback, as long as they provide a businessId.
      // This is for the public funnel form.
      allow create: if request.resource.data.businessId != null;

      // Allow authenticated users to read/list feedback only if it belongs to them.
      // The query from the client MUST include a `where('businessId', '==', request.auth.uid)` clause.
      allow list, get: if isSignedIn() && request.auth.uid == resource.data.businessId;

      // Only the business owner can update or delete their feedback.
      allow update, delete: if isSignedIn() && resource.data.businessId == request.auth.uid;
    }

    // Allow super admin to manage everything else
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}

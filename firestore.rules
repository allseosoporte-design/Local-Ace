/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict ownership model for businesses and their associated data.
 * All data is nested under /businesses/{businessId}, with subcollections for related entities.
 * Key Security Decisions:
 * - All write operations are restricted to authenticated users.
 * - Listing of collections is generally allowed only for owners.
 * - The /internalFeedback collection allows public reads, assuming all data within is public and non-sensitive.
 * - Denormalization is used to avoid get() calls, with businessId copied to subcollections for efficient authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to Business documents.
     * @path /businesses/{businessId}
     * @allow (create) - Authenticated user can create a business if the businessId matches their UID.
     * @deny (create) - Unauthenticated user attempts to create a business.
     * @allow (get, list) - Authenticated user can read a business document.
     * @allow (update, delete) - Authenticated user can update/delete if they own the business.
     * @deny (update, delete) - Unauthenticated user attempts to update/delete a business.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == businessId;
      allow update: if isSignedIn() && request.auth.uid == businessId;
      allow delete: if isSignedIn() && request.auth.uid == businessId;
    }

    /**
     * @description Controls access to GoogleMyBusinessProfile documents.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - Authenticated user can create a profile if they own the associated business. The businessId must match the user's UID.
     * @deny (create) - Unauthenticated user or a user creating a profile for a business they don't own.
     * @allow (get, list) - Authenticated user can read a profile if they own the associated business.
     * @allow (update, delete) - Authenticated user can update/delete if they own the associated business.
     * @deny (update, delete) - Unauthenticated user or a user attempting to modify a profile for a business they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.businessId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.businessId == request.auth.uid;
    }

    /**
     * @description Controls access to Review documents within a GoogleMyBusinessProfile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - Authenticated user can create a review if they own the associated GoogleMyBusinessProfile.
     * @deny (create) - Unauthenticated user or a user creating a review for a profile they don't own.
     * @allow (get, list) - Authenticated user can read a review if they own the associated GoogleMyBusinessProfile.
     * @allow (update, delete) - Authenticated user can update/delete if they own the associated GoogleMyBusinessProfile.
     * @deny (update, delete) - Unauthenticated user or a user attempting to modify a review for a profile they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }
       function getBusinessIdFromProfile() {
          return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
       }
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
        allow update: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
        allow delete: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
    }

    /**
     * @description Controls access to InternalFeedback documents.  Allows public read access.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Any user can read internal feedback.
     * @allow (create) - Authenticated user can create.
     * @deny (update, delete) - No one can update or delete.
     * @principle Allows public read access for non-sensitive data.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to AutomatedPost documents within a GoogleMyBusinessProfile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - Authenticated user can create a post if they own the associated GoogleMyBusinessProfile.
     * @deny (create) - Unauthenticated user or a user creating a post for a profile they don't own.
     * @allow (get, list) - Authenticated user can read a post if they own the associated GoogleMyBusinessProfile.
     * @allow (update, delete) - Authenticated user can update/delete if they own the associated GoogleMyBusinessProfile.
     * @deny (update, delete) - Unauthenticated user or a user attempting to modify a post for a profile they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }
       function getBusinessIdFromProfile() {
          return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
       }
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
      allow update: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
      allow delete: if isSignedIn() && getBusinessIdFromProfile() == request.auth.uid;
    }

    /**
     * @description Controls access to LandingPage documents within a Business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Authenticated user can create a landing page if they own the associated business.
     * @deny (create) - Unauthenticated user or a user creating a landing page for a business they don't own.
     * @allow (get, list) - Authenticated user can read a landing page if they own the associated business.
     * @allow (update, delete) - Authenticated user can update/delete if they own the associated business.
     * @deny (update, delete) - Unauthenticated user or a user attempting to modify a landing page for a business they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get, list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isOwner(businessId);
      allow delete: if isSignedIn() && isOwner(businessId);
    }

    /**
     * @description Controls access to Subscription documents.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription information.
     * @deny (create, update, delete) - No one can create, update, or delete subscriptions through the client; only through the backend.
     * @principle Restricts write access to the backend.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for super admin role
    function isSuperAdmin() {
      return request.auth.token.email == 'allseosoporte@gmail.com' || get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.isSuperAdmin == true;
    }
    
    // Global read access for super admins for safety
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
    
    // User profile is only readable/writable by the user themselves or a super admin
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isSuperAdmin();
    }
    
    // Subscription plans are public to read for pricing pages, but only admin can write
    match /subscriptions/{subscriptionId} {
        allow read: if true;
        allow write: if isSuperAdmin();
    }
    
    // Businesses can be read/written by their owner or super admin
    match /businesses/{businessId} {
        allow read, write: if request.auth.uid == businessId || isSuperAdmin();
    }
    
    // Landing pages for the main business are public
    match /businesses/allseosoporte/landingPages/{pageId} {
      allow read: if true;
    }
    
    // Landing pages for other businesses are managed by their owner
    match /businesses/{businessId}/landingPages/{pageId} {
        allow read, write: if request.auth.uid == businessId || isSuperAdmin();
    }

    // This is the CRITICAL rule for the feedback system.
    // It targets the collection group 'internalFeedback'.
    match /{path=**}/internalFeedback/{feedbackId} {
      // ANYONE can create a feedback entry. This is required for the public funnel page.
      allow create: if true;
      
      // ONLY the authenticated owner of the business can read the feedback.
      // This rule is checked during the 'list' operation from the dashboard.
      // 'resource.data.businessId' refers to the field within the document being read.
      allow read: if request.auth != null && request.auth.uid == resource.data.businessId;
      
      // Allow super admins to read any feedback
      allow read: if isSuperAdmin();
    }
  }
}

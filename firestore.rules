/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and business data.
 * Businesses can manage their own data, and users can only access their own profiles.
 * Google My Business profiles and related data (reviews, automated posts) are also secured by business ownership.
 * Subscriptions are publicly readable but not writable through the client.
 *
 * Data Structure:
 * - /users/{userId}: User profile data, linked to the Firebase Auth UID.
 * - /businesses/{businessId}: Business information.  The root for all business-related data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Customer reviews for a Google My Business profile.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Internal feedback collected from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for a Google My Business profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages created for a business.
 * - /subscriptions/{subscriptionId}: Subscription plan information.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user profile.
 * - Businesses can manage their own Google My Business profiles, landing pages, and other related data.
 * - Subscriptions are publicly readable.
 * - Listing of users is disallowed.
 *
 * Denormalization for Authorization:
 * - Each document requiring ownership-based access control includes a field that references the owner's ID.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId The user ID to compare with the authenticated user's ID.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource.
     * @param {string} userId The user ID to compare with the authenticated user's ID.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }


    /**
     * @description Security rules for user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' creates their profile.
     *   - request.auth.uid: 'user123'
     *   - request.resource.data.id: 'user123'
     * @deny (create) User 'user123' tries to create a profile for 'user456'.
     *   - request.auth.uid: 'user123'
     *   - request.resource.data.id: 'user456'
     * @principle Enforces user ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.businessId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.businessId == resource.data.businessId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Security rules for businesses.
     * @path /businesses/{businessId}
     * @allow (create) User creates a business with ID 'business123'.
     *   - request.auth.uid: 'user123' (who will be the business admin)
     *   - request.resource.data.id: 'business123'
     * @deny (update) User tries to update a business they don't own.
     *   - request.auth.uid: 'user456'
     *   - resource.data.id: 'business123'
     * @principle Enforces business ownership for business data.
     */
    match /businesses/{businessId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId && request.resource.data.id == businessId;
      allow delete: if false;
    }

    /**
     * @description Security rules for Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) Business 'business123' creates a GMB profile.
     *   - request.auth.uid: 'user123' (who is the business admin)
     *   - request.resource.data.businessId: 'business123'
     * @deny (update) User tries to update a GMB profile for a business they don't own.
     *   - request.auth.uid: 'user456'
     *   - request.resource.data.businessId: 'business123'
     * @principle Enforces business ownership for Google My Business profile data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if true;
      allow list: if false;
      allow create: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == request.resource.data.businessId;
      allow update: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId;
      allow delete: if false;
    }

    /**
     * @description Security rules for reviews under Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list) Publicly accessible to read reviews.
     * @deny (create, update, delete) No direct creation, updates, or deletes allowed. Reviews are managed via external sources/APIs.
     * @principle Public read access, no write access.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Security rules for internal feedback under businesses.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (create) Business 'business123' creates internal feedback.
     *   - request.auth.uid: 'user123' (who is the business admin)
     * @deny (update) User tries to update internal feedback for a business they don't own.
     *   - request.auth.uid: 'user456'
     * @principle Enforces business ownership for internal feedback data.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      allow get: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow list: if false;
      allow create: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow update: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow delete: if false;
    }

    /**
     * @description Security rules for automated posts under Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) Business 'business123' creates an automated post.
     *   - request.auth.uid: 'user123' (who is the business admin)
     * @deny (update) User tries to update an automated post for a business they don't own.
     *   - request.auth.uid: 'user456'
     * @principle Enforces business ownership for automated post data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if true;
      allow list: if false;
      allow create: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      allow update: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      allow delete: if false;
    }

    /**
     * @description Security rules for landing pages under businesses.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Business 'business123' creates a landing page.
     *   - request.auth.uid: 'user123' (who is the business admin)
     * @deny (update) User tries to update a landing page for a business they don't own.
     *   - request.auth.uid: 'user456'
     * @principle Enforces business ownership for landing page data.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow list: if false;
      allow create: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow update: if exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      allow delete: if false;
    }

    /**
     * @description Security rules for subscriptions.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Publicly accessible to read subscription plans.
     * @deny (create, update, delete) No direct creation, updates, or deletes allowed. Subscriptions are managed via external admin panel.
     * @principle Public read access, no write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Businesses can only access their own data, and users must be authenticated to perform any actions.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription information.
 *
 * Key Security Decisions:
 * - Explicitly deny listing of subscriptions to prevent unauthorized access to pricing information.
 * - Public read access is NOT granted to any collection.
 * - All write operations are strictly controlled via ownership checks based on businessId or related IDs.
 *
 * Denormalization for Authorization:
 * - The `googleMyBusinessProfileId` is used as the root for reviews and automated posts, instead of the businessId
 *   to ensure authorization independence. A malicious user cannot create a googleMyBusinessProfile under a business to attempt
 *   to gain authorization to create automated posts or reviews.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided businessId.
     */
    function isOwner(businessId) {
      return isSignedIn() && request.auth.uid == businessId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document.
     */
    function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
    }

    /**
     * @description Rule for the /businesses/{businessId} collection.
     * @path /businesses/{businessId}
     * @allow (create) Authenticated user creates a business document where the businessId matches their UID.
     * @deny (create) Authenticated user attempts to create a business document where the businessId does not match their UID.
     * @allow (get) Authenticated user gets their business document.
     * @deny (get) Authenticated user attempts to get a business document that is not theirs.
     * @allow (update) Authenticated user updates their business document.
     * @deny (update) Authenticated user attempts to update a business document that is not theirs.
     * @allow (delete) Authenticated user deletes their business document.
     * @deny (delete) Authenticated user attempts to delete a business document that is not theirs.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /businesses/{businessId} {
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isOwner(businessId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(businessId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rule for the /googleMyBusinessProfiles/{googleMyBusinessProfileId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) Authenticated user creates a Google My Business profile where the businessId matches their UID.
     * @deny (create) Authenticated user attempts to create a Google My Business profile where the businessId does not match their UID.
     * @allow (get) Authenticated user gets a Google My Business profile associated with their business.
     * @deny (get) Authenticated user attempts to get a Google My Business profile that is not associated with their business.
     * @allow (update) Authenticated user updates a Google My Business profile associated with their business.
     * @deny (update) Authenticated user attempts to update a Google My Business profile that is not associated with their business.
     * @allow (delete) Authenticated user deletes a Google My Business profile associated with their business.
     * @deny (delete) Authenticated user attempts to delete a Google My Business profile that is not associated with their business.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(resource.data.businessId));
      allow list: if false;
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(resource.data.businessId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(resource.data.businessId));
    }

    /**
     * @description Rule for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) Authenticated user creates a review under their Google My Business profile.
     * @deny (create) Authenticated user attempts to create a review under someone else's Google My Business profile.
     * @allow (get) Authenticated user gets a review under their Google My Business profile.
     * @deny (get) Authenticated user attempts to get a review under someone else's Google My Business profile.
     * @allow (update) Authenticated user updates a review under their Google My Business profile.
     * @deny (update) Authenticated user attempts to update a review under someone else's Google My Business profile.
     * @allow (delete) Authenticated user deletes a review under their Google My Business profile.
     * @deny (delete) Authenticated user attempts to delete a review under someone else's Google My Business profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
    }

    /**
     * @description Rule for the /internalFeedback/{internalFeedbackId} collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any authenticated user can create internal feedback.
     * @deny (create) An unauthenticated user attempts to create internal feedback.
     * @allow (get) Any authenticated user can get internal feedback.
     * @deny (get) An unauthenticated user attempts to get internal feedback.
     * @allow (update) No one can update internal feedback.
     * @deny (update) Any user attempts to update internal feedback.
     * @allow (delete) No one can delete internal feedback.
     * @deny (delete) Any user attempts to delete internal feedback.
     * @principle Allows open reads and creates for internal feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) Authenticated user creates an automated post under their Google My Business profile.
     * @deny (create) Authenticated user attempts to create an automated post under someone else's Google My Business profile.
     * @allow (get) Authenticated user gets an automated post under their Google My Business profile.
     * @deny (get) Authenticated user attempts to get an automated post under someone else's Google My Business profile.
     * @allow (update) Authenticated user updates an automated post under their Google My Business profile.
     * @deny (update) Authenticated user attempts to update an automated post under someone else's Google My Business profile.
     * @allow (delete) Authenticated user deletes an automated post under their Google My Business profile.
     * @deny (delete) Authenticated user attempts to delete an automated post under someone else's Google My Business profile.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
    }

    /**
     * @description Rule for the /businesses/{businessId}/landingPages/{landingPageId} collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Authenticated user creates a landing page under their business.
     * @deny (create) Authenticated user attempts to create a landing page under someone else's business.
     * @allow (get) Authenticated user gets a landing page under their business.
     * @deny (get) Authenticated user attempts to get a landing page under someone else's business.
     * @allow (update) Authenticated user updates a landing page under their business.
     * @deny (update) Authenticated user attempts to update a landing page under someone else's business.
     * @allow (delete) Authenticated user deletes a landing page under their business.
     * @deny (delete) Authenticated user attempts to delete a landing page under someone else's business.
     * @principle Enforces document ownership for writes and restricts access to a user's own data tree.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isOwner(businessId);
      allow list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isOwner(businessId);
      allow delete: if isOwner(businessId);
    }

    /**
     * @description Rule for the /subscriptions/{subscriptionId} collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Anyone can read subscription information.
     * @deny (get) N/A
     * @allow (list) No one can list subscriptions.
     * @deny (list) N/A
     * @allow (create) No one can create subscriptions.
     * @deny (create) N/A
     * @allow (update) No one can update subscriptions.
     * @deny (update) N/A
     * @allow (delete) No one can delete subscriptions.
     * @deny (delete) N/A
     * @principle Restricts access to subscription information.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
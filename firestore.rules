/**
 * @fileOverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Access to resources is generally restricted to authenticated users.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User listing is disabled.
 * - Authorization independence is achieved by denormalizing the `businessId` to `GoogleMyBusinessProfile` documents.
 * - Reviews are stored as a subcollection of GoogleMyBusinessProfile for efficient querying.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId - The user ID to compare against the authenticated user ID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of an existing document.
     * @param {string} userId - The user ID to compare against the authenticated user ID.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (create) Authenticated user can create a business document if the businessId matches their UID.
     * @allow (get, list) Authenticated user can get or list business documents if the businessId matches their UID.
     * @allow (update, delete) Authenticated user can update or delete a business document if the businessId matches their UID and the document exists.
     * @deny (create) Authenticated user cannot create a business document if the businessId does not match their UID.
     * @deny (get, list) Unauthenticated user cannot get or list business documents.
     * @deny (update, delete) Authenticated user cannot update or delete a business document if the businessId does not match their UID.
     * @principle Enforces document ownership for writes, requires authentication for all access.
     */
    match /businesses/{businessId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(businessId) && request.resource.data.id == businessId;
      allow update: if isExistingOwner(businessId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) Authenticated user can create a profile if they own the associated business.
     * @allow (get, list) Authenticated user can get or list profiles.
     * @allow (update, delete) Authenticated user can update or delete a profile if they own the associated business and the document exists.
     * @deny (create) Authenticated user cannot create a profile if they don't own the business.
     * @deny (get, list) Unauthenticated user cannot get or list profiles.
     * @deny (update, delete) Authenticated user cannot update or delete a profile if they don't own the associated business.
     * @principle Enforces document ownership for writes, requires authentication for all access, authorization independence by checking businessId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(request.resource.data.businessId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(resource.data.businessId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/businesses/$(resource.data.businessId));
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) Authenticated user can create a review if they own the associated GMB profile.
     * @allow (get, list) Authenticated user can get or list reviews.
     * @allow (update, delete) Authenticated user can update or delete a review if they own the associated GMB profile and the document exists.
     * @deny (create) Authenticated user cannot create a review if they don't own the GMB profile.
     * @deny (get, list) Unauthenticated user cannot get or list reviews.
     * @deny (update, delete) Authenticated user cannot update or delete a review if they don't own the associated GMB profile.
     * @principle Enforces document ownership for writes, requires authentication for all access, authorization independence by checking businessId on parent GMB profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
    }

    /**
     * @description Rules for the /internalFeedback collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Authenticated user can create an internal feedback document.
     * @allow (get, list) Authenticated user can get or list internal feedback documents.
     * @allow (update, delete) Authenticated user can update or delete an internal feedback document if the document exists.
     * @deny (create) Unauthenticated user cannot create an internal feedback document.
     * @deny (get, list) Unauthenticated user cannot get or list internal feedback documents.
     * @deny (update, delete) Unauthenticated user cannot update or delete an internal feedback document.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) Authenticated user can create an automated post if they own the associated GMB profile.
     * @allow (get, list) Authenticated user can get or list automated posts.
     * @allow (update, delete) Authenticated user can update or delete an automated post if they own the associated GMB profile and the document exists.
     * @deny (create) Authenticated user cannot create an automated post if they don't own the GMB profile.
     * @deny (get, list) Unauthenticated user cannot get or list automated posts.
     * @deny (update, delete) Authenticated user cannot update or delete an automated post if they don't own the associated GMB profile.
     * @principle Enforces document ownership for writes, requires authentication for all access, authorization independence by checking businessId on parent GMB profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow update: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && exists(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId));
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Authenticated user can create a landing page if they own the associated business.
     * @allow (get, list) Authenticated user can get or list landing pages.
     * @allow (update, delete) Authenticated user can update or delete a landing page if they own the associated business and the document exists.
     * @deny (create) Authenticated user cannot create a landing page if they don't own the business.
     * @deny (get, list) Unauthenticated user cannot get or list landing pages.
     * @deny (update, delete) Authenticated user cannot update or delete a landing page if they don't own the associated business.
     * @principle Enforces document ownership for writes, requires authentication for all access.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(businessId) && exists(/databases/$(database)/documents/businesses/$(businessId));
      allow update: if isOwner(businessId) && exists(/databases/$(database)/documents/businesses/$(businessId));
      allow delete: if isOwner(businessId) && exists(/databases/$(database)/documents/businesses/$(businessId));
    }

    /**
     * @description Rules for the /subscriptions collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (create) Authenticated user can create a subscription document.
     * @allow (get, list) Authenticated user can get or list subscription documents.
     * @allow (update, delete) Authenticated user can update or delete a subscription document if the document exists.
     * @deny (create) Unauthenticated user cannot create a subscription document.
     * @deny (get, list) Unauthenticated user cannot get or list subscription documents.
     * @deny (update, delete) Unauthenticated user cannot update or delete a subscription document.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}
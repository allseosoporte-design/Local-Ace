/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Businesses can only manage their own Google My Business profiles, landing pages, and automated posts.
 * Reviews and internal feedback are accessible based on association with a Google My Business profile or exist at the root, respectively.
 * Subscriptions are publicly readable but not writable via the client.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Subcollection for customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback collected from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Subcollection for automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - Users cannot list all businesses or Google My Business profiles. List operations are only allowed within the context of a specific business or profile.
 * - Subscriptions are publicly readable to allow clients to fetch subscription details, but create, update, and delete operations are disallowed to prevent unauthorized modification.
 * - The `businessId` is used in the `GoogleMyBusinessProfile` to ensure authorization independence and avoid costly `get()` calls.
 * - Root-level `internalFeedback` is kept separate from GoogleMyBusinessProfile to avoid an authorization dependency between entities.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description: Controls access to business documents.
     * @path: /businesses/{businessId}
     * @allow: User with ID 'business123' can (create) a business document with id: 'business123'.
     * @deny: User with ID 'user456' cannot (create) a business document with id: 'business123'.
     * @principle: Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      // Utility function to check if the user is the owner of the business
      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      // Utility function to check if the business exists and the user is the owner
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      // Allow a business to read their own document
      allow get: if isOwner(businessId);
      // Prevent listing all businesses
      allow list: if false;
      // Allow a business to create their own document if the businessId matches their UID
      allow create: if isOwner(businessId) && request.resource.data.id == businessId;
      // Allow a business to update their own document
      allow update: if isExistingOwner(businessId) && request.resource.data.id == resource.data.id;
      // Allow a business to delete their own document
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description: Controls access to Google My Business profile documents.
     * @path: /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow: User with ID 'business123' can (create) a Google My Business profile document with businessId: 'business123'.
     * @deny: User with ID 'user456' cannot (create) a Google My Business profile document with businessId: 'business123'.
     * @principle: Enforces document ownership for writes, leveraging businessId for authorization.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      // Utility function to check if the user is the owner of the Google My Business profile
      function isBusinessOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      // Utility function to check if the Google My Business profile exists and the user is the owner
      function isExistingBusinessOwner(businessId) {
        return isBusinessOwner(businessId) && resource != null;
      }

      // Allow a business to read their own Google My Business profile
      allow get: if isBusinessOwner(resource.data.businessId);
      // Prevent listing all Google My Business profiles
      allow list: if false;
      // Allow a business to create a Google My Business profile if the businessId matches their UID
      allow create: if isBusinessOwner(request.resource.data.businessId);
      // Allow a business to update their own Google My Business profile
      allow update: if isExistingBusinessOwner(resource.data.businessId) && request.resource.data.businessId == resource.data.businessId;
      // Allow a business to delete their own Google My Business profile
      allow delete: if isExistingBusinessOwner(resource.data.businessId);
    }

    /**
     * @description: Controls access to Review documents within a Google My Business profile.
     * @path: /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow: User with ID 'business123' can (create) a review document under the Google My Business profile they own.
     * @deny: User with ID 'user456' cannot (create) a review document under the Google My Business profile owned by 'business123'.
     * @principle: Enforces document ownership for writes, inheriting authorization from the parent Google My Business profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
        // Utility function to check if the user is the owner of the parent Google My Business profile
        function isBusinessOwner(businessId) {
          return request.auth != null && request.auth.uid == businessId;
        }

        // Utility function to check if the Google My Business profile exists and the user is the owner
        function isExistingBusinessOwner(businessId) {
          return isBusinessOwner(businessId) && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == businessId && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)) != null;
        }

        // Allow a business to read a review under their Google My Business profile
        allow get: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        // Allow a business to list reviews under their Google My Business profile
        allow list: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        // Allow a business to create a review under their Google My Business profile
        allow create: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        // Allow a business to update a review under their Google My Business profile
        allow update: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        // Allow a business to delete a review under their Google My Business profile
        allow delete: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description: Controls access to internal feedback documents.
     * @path: /internalFeedback/{internalFeedbackId}
     * @allow: No authenticated access is allowed to InternalFeedback.
     * @deny: Any create, update or delete operation.
     * @principle: Internal feedback is not accessible to authenticated users.
     */
    match /internalFeedback/{internalFeedbackId} {
      // Internal feedback is not accessible to authenticated users
      allow get: if false;
      allow list: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description: Controls access to automated post documents within a Google My Business profile.
     * @path: /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow: User with ID 'business123' can (create) an automated post document under the Google My Business profile they own.
     * @deny: User with ID 'user456' cannot (create) an automated post document under the Google My Business profile owned by 'business123'.
     * @principle: Enforces document ownership for writes, inheriting authorization from the parent Google My Business profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      // Utility function to check if the user is the owner of the parent Google My Business profile
      function isBusinessOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      // Utility function to check if the Google My Business profile exists and the user is the owner
      function isExistingBusinessOwner(businessId) {
        return isBusinessOwner(businessId) && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == businessId && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)) != null;
      }

      // Allow a business to read an automated post under their Google My Business profile
      allow get: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      // Allow a business to list automated posts under their Google My Business profile
      allow list: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      // Allow a business to create an automated post under their Google My Business profile
      allow create: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      // Allow a business to update an automated post under their Google My Business profile
      allow update: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      // Allow a business to delete an automated post under their Google My Business profile
      allow delete: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description: Controls access to landing page documents within a business.
     * @path: /businesses/{businessId}/landingPages/{landingPageId}
     * @allow: User with ID 'business123' can (create) a landing page document under their business.
     * @deny: User with ID 'user456' cannot (create) a landing page document under the business owned by 'business123'.
     * @principle: Enforces document ownership for writes, inheriting authorization from the parent business.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      // Utility function to check if the user is the owner of the parent business
      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }

      // Utility function to check if the business exists and the user is the owner
      function isExistingOwner(businessId) {
        return isOwner(businessId) && get(/databases/$(database)/documents/businesses/$(businessId)) != null;
      }

      // Allow a business to read a landing page under their business
      allow get: if isOwner(businessId);
      // Allow a business to list landing pages under their business
      allow list: if isOwner(businessId);
      // Allow a business to create a landing page under their business
      allow create: if isExistingOwner(businessId);
      // Allow a business to update a landing page under their business
      allow update: if isExistingOwner(businessId);
      // Allow a business to delete a landing page under their business
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description: Controls access to subscription documents.
     * @path: /subscriptions/{subscriptionId}
     * @allow: Anyone can read subscription information.
     * @deny: No one can create, update, or delete subscription information through the client.
     * @principle: Allows public read access for subscription information, but restricts write access.
     */
    match /subscriptions/{subscriptionId} {
      // Allow anyone to read subscription information
      allow get, list: if true;
      // Prevent creating, updating, or deleting subscription information through the client
      allow create, update, delete: if false;
    }
  }
}
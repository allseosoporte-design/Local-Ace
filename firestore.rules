/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-association model.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, linking auth ID to business ID.
 * - /businesses/{businessId}: Stores core business information and acts as the root for business-owned data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile details.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews for a GMB profile.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback, decoupled from GMB profile for security.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts for a GMB profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages created for a business.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information (globally accessible).
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the authenticated user.
 * - Business-related data is generally restricted to users associated with that business.
 * - Subscriptions are publicly readable.
 *
 * Denormalization for Authorization:
 * - GoogleMyBusinessProfile includes businessId, enabling independent authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if request.auth.uid == userId
     * @deny (get, list, create, update, delete) if request.auth.uid != userId
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows access to business information for authorized users.
     * @path /businesses/{businessId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if request.auth.uid == resource.data.adminEmail
     * @deny (create, update, delete) if request.auth.uid != resource.data.adminEmail
     * @principle Enforces business-level access control.
     */
    match /businesses/{businessId} {
      function isAdminEmail(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.adminEmail == request.auth.uid;
      }
      allow get, list: if true;
      allow create: if request.resource.data.adminEmail == request.auth.uid;
      allow update: if isAdminEmail(businessId);
      allow delete: if isAdminEmail(businessId);
    }

    /**
     * @description Allows access to Google My Business profile information for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if resource.data.businessId is managed by the requesting user
     * @deny (create, update, delete) if resource.data.businessId is not managed by the requesting user
     * @principle Enforces business-level access control for GMB profiles.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isBusinessAdmin(businessId) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if true;
      allow create: if isBusinessAdmin(request.resource.data.businessId);
      allow update: if isBusinessAdmin(resource.data.businessId);
      allow delete: if isBusinessAdmin(resource.data.businessId);
    }

    /**
     * @description Allows access to customer reviews for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if the parent GoogleMyBusinessProfile is managed by the requesting user
     * @deny (create, update, delete) if the parent GoogleMyBusinessProfile is not managed by the requesting user
     * @principle Enforces business-level access control for customer reviews.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isBusinessAdminForGMBProfile(googleMyBusinessProfileId) {
        let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if true;
      allow create: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
      allow update: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
      allow delete: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
    }

    /**
     * @description Allows access to internal feedback for authorized users.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if the feedback is associated with a review for a business managed by the requesting user
     * @deny (create, update, delete) if the feedback is not associated with a review for a business managed by the requesting user
     * @principle Enforces business-level access control for internal feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isBusinessAdminForInternalFeedback(internalFeedbackId) {
        let reviewId = get(/databases/$(database)/documents/internalFeedback/$(internalFeedbackId)).data.reviewId;
        let googleMyBusinessProfileId = get(/databases/$(database)/documents/reviews/$(reviewId)).data.googleMyBusinessProfileId;
        let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;

        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if true;
      allow create: if isBusinessAdminForInternalFeedback(internalFeedbackId);
      allow update: if isBusinessAdminForInternalFeedback(internalFeedbackId);
      allow delete: if isBusinessAdminForInternalFeedback(internalFeedbackId);
    }

    /**
     * @description Allows access to automated posts for authorized users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if the parent GoogleMyBusinessProfile is managed by the requesting user
     * @deny (create, update, delete) if the parent GoogleMyBusinessProfile is not managed by the requesting user
     * @principle Enforces business-level access control for automated posts.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isBusinessAdminForGMBProfile(googleMyBusinessProfileId) {
        let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if true;
      allow create: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
      allow update: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
      allow delete: if isBusinessAdminForGMBProfile(googleMyBusinessProfileId);
    }

    /**
     * @description Allows access to landing pages for authorized users.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) if true
     * @allow (create, update, delete) if the parent business is managed by the requesting user
     * @deny (create, update, delete) if the parent business is not managed by the requesting user
     * @principle Enforces business-level access control for landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isBusinessAdmin(businessId) {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if true;
      allow create: if isBusinessAdmin(businessId);
      allow update: if isBusinessAdmin(businessId);
      allow delete: if isBusinessAdmin(businessId);
    }

    /**
     * @description Allows public read access to subscription information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) if true
     * @deny (create, update, delete) always
     * @principle Allows public access to subscription information.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
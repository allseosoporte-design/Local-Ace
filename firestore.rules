/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict ownership model for businesses and their associated data.
 *
 * Core Philosophy:
 * This ruleset prioritizes securing data by strictly enforcing ownership. Businesses can only access their own data, and users are associated with a single business.
 * Data is segregated into collections based on entity type (Businesses, GoogleMyBusinessProfiles, etc.).
 *
 * Data Structure:
 * /users/{userId}: Stores user profile information, linking their auth UID to their business ID.
 * /businesses/{businessId}: Stores business information and acts as a root collection for business-related data.
 * /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information, associated with a business.
 * /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Subcollection of reviews for a GMB profile.
 * /internalFeedback/{internalFeedbackId}: Stores internal feedback, kept separate for simpler access control.
 * /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Subcollection of automated posts for a GMB profile.
 * /businesses/{businessId}/landingPages/{landingPageId}: Subcollection of landing pages for a business.
 * /subscriptions/{subscriptionId}: Stores subscription plan information (publicly readable).
 *
 * Key Security Decisions:
 *  - Listing of users is disallowed for privacy.
 *  - Subscriptions are publicly readable, but not writable.
 *  - All write operations require authentication.
 *  - Reviews and AutomatedPosts are subcollections of GoogleMyBusinessProfiles, inheriting businessId ownership.
 *
 * Denormalization for Authorization:
 *   - GoogleMyBusinessProfile documents have a businessId field, enabling direct ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @returns {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided business ID.
     * @param {string} businessId - The business ID to compare against the user's UID.
     * @returns {bool} True if the user is the owner of the business, false otherwise.
     * @example
     * // Allow access if the user's UID matches the businessId
     * allow read: if isOwner(businessId);
     */
    function isOwner(businessId) {
      return request.auth.uid == businessId;
    }

    /**
     * @description Checks if the authenticated user is the owner of an existing document.
     * @param {string} businessId - The business ID to compare against the user's UID.
     * @returns {bool} True if the user is the owner of the business and the document exists, false otherwise.
     */
    function isExistingOwner(businessId) {
      return isOwner(businessId) && resource != null;
    }

    /**
     * @description Rule for the /subscriptions collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription details.
     * @deny (create, update, delete) - No one can modify or create subscriptions through the client.
     * @principle Allows public read access to subscriptions, but restricts writes.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (get, list) - The business owner can read their own business document.
     * @allow (create) - The business owner can create their own business document.
     * @allow (update) - The business owner can update their own business document.
     * @allow (delete) - The business owner can delete their own business document.
     * @deny (get, list, create, update, delete) - Any other user cannot access this data.
     * @principle Enforces strict ownership for business documents.
     */
    match /businesses/{businessId} {
      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      /**
       * @description Rule for the /businesses/{businessId}/landingPages collection.
       * @path /businesses/{businessId}/landingPages/{landingPageId}
       * @allow (get, list, create, update, delete) - The business owner can manage their own landing pages.
       * @deny (get, list, create, update, delete) - Any other user cannot access this data.
       * @principle Enforces ownership for landing pages by checking the businessId.
       */
      match /landingPages/{landingPageId} {
        allow get, list: if isOwner(businessId);
        allow create: if isOwner(businessId);
        allow update: if isExistingOwner(businessId);
        allow delete: if isExistingOwner(businessId);
      }
    }

    /**
     * @description Rule for the /googleMyBusinessProfiles collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) - The business owner can read their own GMB profile.
     * @allow (create) - The business owner can create a GMB profile for their business.
     * @allow (update) - The business owner can update their own GMB profile.
     * @allow (delete) - The business owner can delete their own GMB profile.
     * @deny (get, list, create, update, delete) - Any other user cannot access this data.
     * @principle Enforces ownership for GMB profiles by checking the businessId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if isSignedIn() && request.auth.uid == resource.data.businessId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.businessId;
      allow update: if isSignedIn() && request.auth.uid == resource.data.businessId && resource != null;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.businessId && resource != null;

      /**
       * @description Rule for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       * @allow (get, list, create, update, delete) - The business owner can manage reviews for their GMB profile.
       * @deny (get, list, create, update, delete) - Any other user cannot access this data.
       * @principle Enforces ownership for reviews by checking the businessId in the parent document.
       */
      match /reviews/{reviewId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }

      /**
       * @description Rule for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * @allow (get, list, create, update, delete) - The business owner can manage automated posts for their GMB profile.
       * @deny (get, list, create, update, delete) - Any other user cannot access this data.
       * @principle Enforces ownership for automated posts by checking the businessId in the parent document.
       */
      match /automatedPosts/{automatedPostId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }
    }

    /**
     * @description Rule for the /internalFeedback collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Public can view internal feedback.
     * @allow (create) - Any signed-in user can create internal feedback.
     * @deny (update, delete) - No one can update or delete internal feedback.
     * @principle Allows public read access and signed-in user write access for feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for the /users collection.
     * @path /users/{userId}
     * @allow create - Allows a user to create their own profile.
     * @allow get - Allows a user to get their own profile.
     * @deny list, update, delete - Listing all users and any other operations are prohibited.
     * @principle Enforces strict ownership: users can only create or read their own profile.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if false;
      allow delete: if false;
    }
  }
}
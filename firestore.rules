/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-ownership model for all data.
 *
 * Data Structure:
 * - /products/{productId}: Stores products, secured by businessId.
 * - /users/{userId}: Stores user profiles, linking auth ID to business ID.
 * - /businesses/{businessId}: Stores business information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores reviews for GMB profiles.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback, secured by businessId.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts for GMB profiles.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for businesses.
 * - /subscriptions/{subscriptionId}: Stores subscription plans (public read).
 * - /paymentSettings/{userId}: Stores payment settings, secured by userId.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Read-only collections: Subscriptions are publicly readable.
 * - Default security posture: Strict ownership is enforced unless explicitly stated otherwise.
 *
 * Denormalization for Authorization:
 * - Products contain a `businessId` field to allow direct association with a business.
 * - Reviews contain a `googleMyBusinessProfileId` field for association with a GMB profile.
 * - InternalFeedback contains a `businessId` field to allow direct association with a business.
 * - LandingPages contain a `businessId` field to allow direct association with a business.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a business to manage its products.
     * @path /products/{productId}
     * @allow (create) - Authenticated user creates a new product with `businessId` matching their business.
     * @allow (update) - Authenticated user updates a product with `businessId` matching their business.
     * @allow (delete) - Authenticated user deletes a product with `businessId` matching their business.
     * @deny (create) - User attempts to create a product with a `businessId` that doesn't match their own.
     * @deny (update) - User attempts to update a product with a `businessId` that doesn't match their own.
     * @deny (delete) - User attempts to delete a product with a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for product data.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow update: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow delete: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
    }

    /**
     * @description Allows a user to manage their own profile.
     * @path /users/{userId}
     * @allow (create) - Authenticated user creates their own profile.
     * @allow (get) - Authenticated user gets their own profile.
     * @allow (update) - Authenticated user updates their own profile.
     * @deny (create) - User attempts to create a profile for another user.
     * @deny (get) - User attempts to get another user's profile.
     * @deny (list) - Listing all users is not permitted.
     * @deny (update) - User attempts to update another user's profile.
     * @deny (delete) - User attempts to delete another user's profile.
     * @principle Enforces user ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if false;
    }

    /**
     * @description Allows a business to manage its business information.
     * @path /businesses/{businessId}
     * @allow (get) - Any authenticated user can retrieve business information.
     * @allow (create) - An authenticated user can create their business profile.
     * @allow (update) - Authenticated user updates their own business information.
     * @allow (delete) - Authenticated user can delete their own business (rare, but possible).
     * @deny (create) - User attempts to create a business profile for another businessId
     * @deny (update) - User attempts to update another business's information.
     * @deny (delete) - User attempts to delete another business's information.
     * @principle Enforces business ownership for business data.
     */
    match /businesses/{businessId} {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() && request.auth.uid == businessId;
      allow update: if isSignedIn() && request.auth.uid == businessId;
      allow delete: if isSignedIn() && request.auth.uid == businessId;
    }

    /**
     * @description Allows a business to manage its Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - Authenticated user creates a new GMB profile associated with their business.
     * @allow (get) - Any authenticated user can retrieve the GMB profile.
     * @allow (update) - Authenticated user updates a GMB profile associated with their business.
     * @allow (delete) - Authenticated user deletes a GMB profile associated with their business.
     * @deny (create) - User attempts to create a GMB profile for a `businessId` that doesn't match their own.
     * @deny (update) - User attempts to update a GMB profile with a `businessId` that doesn't match their own.
     * @deny (delete) - User attempts to delete a GMB profile with a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for Google My Business profile data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow update: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow delete: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);

       /**
        * @description Allows a business to manage reviews for its Google My Business profiles.
        * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
        * @allow (create) - Authenticated user creates a new review associated with their GMB profile.
        * @allow (get) - Any authenticated user can retrieve the review.
        * @allow (update) - Authenticated user updates a review associated with their GMB profile.
        * @allow (delete) - Authenticated user deletes a review associated with their GMB profile.
        * @deny (create) - User attempts to create a review for a `googleMyBusinessProfileId` that doesn't belong to their business.
        * @deny (update) - User attempts to update a review for a `googleMyBusinessProfileId` that doesn't belong to their business.
        * @deny (delete) - User attempts to delete a review for a `googleMyBusinessProfileId` that doesn't belong to their business.
        * @principle Enforces business ownership for review data.
        */
      match /reviews/{reviewId} {
          allow get: if true;
          allow list: if true;
          allow create: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
          allow update: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
          allow delete: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
        }

      /**
       * @description Allows a business to manage automated posts for its Google My Business profiles.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * @allow (create) - Authenticated user creates a new automated post associated with their GMB profile.
       * @allow (get) - Any authenticated user can retrieve the automated post.
       * @allow (update) - Authenticated user updates an automated post associated with their GMB profile.
       * @allow (delete) - Authenticated user deletes an automated post associated with their GMB profile.
       * @deny (create) - User attempts to create an automated post for a `googleMyBusinessProfileId` that doesn't belong to their business.
       * @deny (update) - User attempts to update an automated post for a `googleMyBusinessProfileId` that doesn't belong to their business.
       * @deny (delete) - User attempts to delete an automated post for a `googleMyBusinessProfileId` that doesn't belong to their business.
       * @principle Enforces business ownership for automated post data.
       */
      match /automatedPosts/{automatedPostId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
        allow update: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
        allow delete: if isSignedIn() && getBusinessIdFromGMBProfileId(getGMBProfileId()) == getBusinessIdFromUserId(request.auth.uid);
      }
    }

    /**
     * @description Allows access to internal feedback.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) - Any authenticated user can create internal feedback.
     * @allow (get) - Any authenticated user can retrieve internal feedback.
     * @allow (update) - Authenticated user updates their own internal feedback.
     * @allow (delete) - Authenticated user can delete their own feedback (rare, but possible).
     * @deny (update) - User attempts to update another business's feedback.
     * @deny (delete) - User attempts to delete another business's feedback.
     * @principle Enforces business ownership for internal feedback data.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow update: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
      allow delete: if isSignedIn() && request.resource.data.businessId == getBusinessIdFromUserId(request.auth.uid);
    }

    /**
     * @description Allows a business to manage its landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Authenticated user creates a new landing page associated with their business.
     * @allow (get) - Any authenticated user can retrieve the landing page.
     * @allow (update) - Authenticated user updates a landing page associated with their business.
     * @allow (delete) - Authenticated user deletes a landing page associated with their business.
     * @deny (create) - User attempts to create a landing page for a `businessId` that doesn't match their own.
     * @deny (update) - User attempts to update a landing page for a `businessId` that doesn't match their own.
     * @deny (delete) - User attempts to delete a landing page for a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for landing page data.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && getBusinessIdFromUserId(request.auth.uid) == businessId;
      allow update: if isSignedIn() && getBusinessIdFromUserId(request.auth.uid) == businessId;
      allow delete: if isSignedIn() && getBusinessIdFromUserId(request.auth.uid) == businessId;
    }

    /**
     * @description Allows public read access to subscription plans.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) - Any user can read a subscription plan.
     * @allow (list) - Any user can list subscription plans.
     * @deny (create) - No one can create subscription plans through the client.
     * @deny (update) - No one can update subscription plans through the client.
     * @deny (delete) - No one can delete subscription plans through the client.
     * @principle Allows public read access to subscription plans, while restricting write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows a user to manage their payment settings.
     * @path /paymentSettings/{userId}
     * @allow (get) - Authenticated user gets their own payment settings.
     * @allow (create) - Authenticated user creates their own payment settings.
     * @allow (update) - Authenticated user updates their own payment settings.
     * @deny (create) - User attempts to create payment settings for another user.
     * @deny (get) - User attempts to get another user's payment settings.
     * @deny (list) - Listing all payment settings is not permitted.
     * @deny (update) - User attempts to update another user's payment settings.
     * @deny (delete) - User attempts to delete another user's payment settings.
     * @principle Enforces user ownership for payment settings data.
     */
    match /paymentSettings/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && isSignedIn();
      allow update: if isOwner(userId) && isSignedIn();
      allow delete: if false;
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  function isExistingOwner(ownerId, requestOwnerId) {
    return resource.data.businessId == requestOwnerId;
  }

    // Function to get the business ID from the user profile
  function getBusinessIdFromUserId(userId) {
    return get(/databases/$(database)/documents/users/$(userId)).data.businessId;
  }

  // Function to get the business ID from the Google My Business profile ID
  function getBusinessIdFromGMBProfileId(googleMyBusinessProfileId) {
    return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
  }

  function getGMBProfileId() {
      return getSelf().path.split("/")[6];
  }
}
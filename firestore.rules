/**
 * @fileoverview Firestore Security Rules for Local Leap platform.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure access control based on clearly defined ownership.
 * SuperAdmins are granted elevated privileges.  Schema validation is relaxed for rapid prototyping.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for businesses.
 * - /businesses/{businessId}/reviews/{reviewId}: Subcollection for business reviews.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}: Subcollection for Google Business Profiles.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}: Subcollection for GBP posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for Landing Pages.
 * - /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}: Subcollection for Contact Forms.
 * - /subscriptionPlans/{subscriptionPlanId}: Root collection for Subscription Plans.
 * - /paymentSettings/{planSettingsId}: Root collection for Payment Settings.
 * - /superAdmins/{superAdminId}: Root collection for Super Admins.
 * - /pendingPayments/{paymentId}: Root collection for Pending Payments.
 * - /subscriptions/{subscriptionId}: Root collection for Subscriptions.
 * - /activityLogs/{logId}: Root collection for Activity Logs.
 *
 * Key Security Decisions:
 * - SuperAdmins have full read/write access to all collections.
 * - Businesses and their subcollections (reviews, GBP, posts, landingPages, contactForms) are generally not listable publicly without authentication.
 * - Owner-only write access is enforced for many collections, relying on ID matching between the path and document data.
 * - Public read access is enabled only where explicitly intended (e.g., subscriptionPlans).
 *
 * Denormalization for Authorization:
 * - For simplicity and performance, the rules assume that relevant ownership information (e.g., businessId) is present within documents,
 *   rather than relying on complex `get()` operations to related documents.
 *
 * Structural Segregation:
 * - Private data (e.g., superAdmin profiles) and public data (e.g., subscription plans) are stored in separate root-level collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows SuperAdmins full access.
     */
    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    /**
     * @description Checks if the user is signed in.
     * @allow (read, write) Signed-in users.
     * @deny (read, write) Anonymous users.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId - The user ID to compare against.
     * @return {boolean} True if the authenticated user ID matches the provided user ID, false otherwise.
     * @allow (read, write) User with matching ID.
     * @deny (read, write) User with non-matching ID.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

     /**
      * @description Checks if the authenticated user is the owner of an existing document.
      * It combines the ownership check with the existence check, ensuring the document exists.
      * @param {string} userId - The user ID to compare against.
      * @return {boolean} True if the authenticated user is the owner of the existing document, false otherwise.
      */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (create) User with auth.uid matching the businessId in the request data.
     * @deny (create) User with mismatched auth.uid and businessId.
     * @allow (get) Any authenticated user can get a business.
     * @deny (get) Unauthenticated users.
     * @principle Owner-only write, authenticated read.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.id == businessId && request.auth.uid == request.resource.data.ownerId;
      allow update: if isSuperAdmin() || (isSignedIn() && request.auth.uid == resource.data.ownerId);
      allow delete: if isSuperAdmin() || (isSignedIn() && request.auth.uid == resource.data.ownerId);
    }

    /**
     * @description Rules for the /businesses/{businessId}/reviews collection.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (create) Any signed-in user can create a review for a business.
     * @deny (create) Anonymous users cannot create reviews.
     * @allow (read) Any signed-in user can read reviews.
     * @deny (read) Unauthenticated users.
     * @principle Authenticated read, authenticated write.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /businesses/{businessId}/googleBusinessProfiles collection.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     * @allow (create) Business owner (matching businessId) can create a Google Business Profile.
     * @deny (create) Users who are not owners of the business.
     * @principle Owner-only write, authenticated read.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    /**
     * @description Rules for the /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts collection.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     * @allow (create) Business owner (matching businessId) can create a post.
     * @deny (create) Users who are not owners of the business.
     * @principle Owner-only write, authenticated read.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) Business owner (matching businessId) can create a landing page.
     * @deny (create) Users who are not owners of the business.
     * @principle Owner-only write, authenticated read.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages/{landingPageId}/contactForms collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     * @allow (create) Business owner (matching businessId) can create a contact form.
     * @deny (create) Users who are not owners of the business.
     * @principle Owner-only write, authenticated read.
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      allow update: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
      allow delete: if isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid);
    }

    /**
     * @description Rules for the /subscriptionPlans collection.
     * @path /subscriptionPlans/{subscriptionPlanId}
     * @allow (read) Public read access for all users.
     * @allow (write) Only SuperAdmins can modify subscription plans.
     * @principle Public read, SuperAdmin write.
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /paymentSettings collection.
     * @path /paymentSettings/{planSettingsId}
     * @allow (read) Public read access for all users.
     * @allow (write) Only SuperAdmins can modify payment settings.
     * @principle Public read, SuperAdmin write.
     */
    match /paymentSettings/{planSettingsId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /superAdmins collection.
     * @path /superAdmins/{superAdminId}
     * @allow (create) Only allow creation if the user ID matches the superAdminId
     * @deny (create) If the user ID does not match the superAdminId
     * @allow (read, write) Only SuperAdmins can access this collection.
     * @principle SuperAdmin-only access.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSuperAdmin() || isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /pendingPayments collection.
     * @path /pendingPayments/{paymentId}
     * @allow (read, write) Only SuperAdmins can access this collection.
     */
    match /pendingPayments/{paymentId} {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /subscriptions collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (read, write) Only SuperAdmins can access this collection.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    /**
     * @description Rules for the /activityLogs collection.
     * @path /activityLogs/{logId}
     * @allow (read, write) Only SuperAdmins can access this collection.
     */
    match /activityLogs/{logId} {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
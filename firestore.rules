/**
 * @file Overview
 * This ruleset enforces a role-based access control model with a focus on super-admin management of businesses, reviews and landing pages.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super administrator accounts.
 * - /businesses/{businessId}: Stores business accounts, owned by a super admin (denormalized superAdminId).
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for a business.
 * - /subscriptionPlans/{planId}: Stores subscription plans available to businesses.
 *
 * Key Security Decisions:
 * - Super admins have full CRUD access to businesses, reviews and landing pages.
 * - Regular users (businesses) do not have write access to any data.
 * - Public read access is granted to subscription plans.
 * - Data consistency is enforced for ownership fields (e.g., businessId in reviews).
 * - Listing of businesses, reviews, and landing pages is only allowed by the owning super admin.
 *
 * Denormalization for Authorization:
 * - The `Business` entity contains a denormalized `superAdminId` to avoid `get()` calls in rules for business and related data.
 *
 * Structural Segregation:
 * - There are no private and public data within the same collection. Private business data is stored under `/businesses/{businessId}`, while public subscription plans are stored in `/subscriptionPlans/{planId}`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the current user is the owner of the resource, where the resource has the user ID as `id`.
     * @param {string} userId - The user ID to check against the resource's `id` field.
     * @return {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

     /**
     * @description Checks if the current user is the owner of the resource and the resource exists.
     * @param {string} userId - The user ID to check against the resource's `id` field.
     * @return {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }


    /**
     * @description Rules for superAdmin accounts.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin document if the authenticated user ID matches the document ID.
     * @allow (get, update, delete) - Only the superAdmin can access their own document.
     * @deny (create) - A user cannot create a superAdmin document if the authenticated user ID does not match the document ID.
     * @deny (update, delete) - A user cannot update or delete another superAdmin's document.
     * @principle Enforces document ownership for writes.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isOwner(superAdminId);
      allow list: if false; // Super admins are not listable.

      allow create: if isOwner(superAdminId) && request.resource.data.id == superAdminId;
      allow update: if isExistingOwner(superAdminId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Rules for business accounts.
     * @path /businesses/{businessId}
     * @allow (create) - A superAdmin can create a business account.
     * @allow (get, update, delete) - Only the superAdmin who owns the business can access and modify it.
     * @deny (create) - A user cannot create a business if they are not a superAdmin or the superAdminId does not match.
     * @deny (update, delete) - A user cannot modify or delete a business they do not own.
     * @principle Enforces superAdmin ownership for business management.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if false;

      allow create: if isSignedIn(); // TODO: Add superAdmin validation logic.
      allow update: if isSignedIn();  // TODO: Add superAdmin validation logic.
      allow delete: if isSignedIn();  // TODO: Add superAdmin validation logic.
    }

    /**
     * @description Rules for reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) - Anyone can read reviews for a business.
     * @allow (create, update, delete) - Only the superAdmin who owns the business can manage the reviews.
     * @deny (create, update, delete) - A user cannot create, modify, or delete reviews for a business they do not manage.
     * @principle Enforces superAdmin ownership for review management.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn(); // TODO: Add superAdmin validation logic.
      allow update: if isSignedIn();  // TODO: Add superAdmin validation logic.
      allow delete: if isSignedIn();  // TODO: Add superAdmin validation logic.
    }

    /**
     * @description Rules for landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) - Anyone can read landing pages for a business.
     * @allow (create, update, delete) - Only the superAdmin who owns the business can manage the landing pages.
     * @deny (create, update, delete) - A user cannot create, modify, or delete landing pages for a business they do not manage.
     * @principle Enforces superAdmin ownership for landing page management.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();

      allow create: if isSignedIn(); // TODO: Add superAdmin validation logic.
      allow update: if isSignedIn();  // TODO: Add superAdmin validation logic.
      allow delete: if isSignedIn();  // TODO: Add superAdmin validation logic.
    }

     /**
     * @description Rules for subscription plans.
     * @path /subscriptionPlans/{planId}
     * @allow (get, list) - Anyone can read subscription plans.
     * @deny (create, update, delete) - No one can create, update, or delete subscription plans except through backend functions.
     * @principle Subscription plans are publicly readable but not writable from the client.
     */
    match /subscriptionPlans/{planId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
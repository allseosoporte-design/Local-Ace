/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a business-centric data model.  Each business controls access to its own data,
 * with user authentication required for most operations. It's designed to secure access to business-related
 * resources and user profiles.
 *
 * Data Structure:
 * - /users/{userId}: Stores individual user profiles, linked to a business.
 * - /businesses/{businessId}: Stores core business data, acting as the root for business-specific subcollections.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores profiles, referenced by reviews and automated posts.
 * - Subcollections under /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Reviews and AutomatedPosts.
 * - Subcollections under /businesses/{businessId}: InternalFeedback and LandingPages.
 * - /subscriptions/{subscriptionId}: Stores subscription plans.
 *
 * Key Security Decisions:
 * - User listing is forbidden to protect privacy.
 * - Write access (create, update, delete) is strictly controlled based on ownership and authentication.
 * - Data validation is limited to authorization-critical fields (e.g., businessId) for rapid iteration.
 * - The `internalFeedback` subcollection under `businesses` implements a public-create, owner-read strategy, allowing anyone to submit feedback, but only the business owner can view it.
 *
 * Denormalization for Authorization:
 * The `businessId` is denormalized on `LandingPage` documents. This avoids costly `get()` calls to the parent `business` document for authorization.
 *
 * Structural Segregation:
 * Private user data is stored under `/users/{userId}`, separate from potentially public business information.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the user's UID matches the userId.
     * @deny (get, create, update, delete) if the user's UID does not match the userId.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Manages business information and its subcollections, ensuring only the business owner can access it.
     * @path /businesses/{businessId}
     * @allow (get) if the user is the business owner.
     * @allow (create) if the user is signed in and the businessId matches the user's UID.
     * @allow (update, delete) if the user is the existing business owner.
     * @deny (list) to prevent unauthorized listing of businesses.
     * @principle Enforces business ownership for all operations.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      // Documento principal
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      /**
       * @description Implements a public-create, owner-read strategy for internal feedback.
       * @path /businesses/{businessId}/internalFeedback/{feedbackId}
       * @allow (create) Anyone can create internal feedback.
       * @allow (get) Only the business owner can read specific feedback.
       * @allow (list) Only the business owner can list all feedback.
       * @deny (update, delete) No one can update or delete feedback.
       * @principle Allows public feedback submission while restricting access to the business owner.
       */
      match /internalFeedback/{feedbackId} {
        // ✅ Cualquiera puede crear SI el businessId en los datos coincide con la ruta
        allow create: if request.resource.data.businessId is string;

        // ✅ Solo el dueño puede leer - verificar contra el documento
        allow get: if request.auth != null &&
                      resource.data.businessId == request.auth.uid;

        // ✅ Para LIST, permitir si está autenticado (el filtro where lo maneja el cliente)
        allow list: if request.auth != null;

        // ❌ Nadie puede actualizar/eliminar
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Manages landing pages, ensuring only the business owner can access them.
       * @path /businesses/{businessId}/landingPages/{landingPageId}
       * @allow (get, list) if the user is signed in and the business owner.
       * @allow (create) if the user is signed in and the businessId matches the businessId in the landing page data.
       * @allow (update, delete) if the user is signed in and the existing business owner.
       * @principle Enforces business ownership for all landing page operations.
       */
      match /landingPages/{landingPageId} {
        allow get: if isSignedIn() && isOwner(businessId);
        allow list: if isSignedIn() && isOwner(businessId);
        allow create: if isSignedIn() && request.resource.data.businessId == businessId;
        allow update: if isSignedIn() && isExistingOwner(businessId);
        allow delete: if isSignedIn() && isExistingOwner(businessId);
      }
    }

    /**
     * @description Manages Google My Business profile information.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * // TODO: Add owner validation once the schema is updated with an ownership field.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Manages reviews for a Google My Business profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       * // TODO: Add owner validation once the schema is updated with an ownership field.
       */
      match /reviews/{reviewId} {
        allow get: if true;
        allow list: if true;
        allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }

      /**
       * @description Manages automated posts for a Google My Business profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * // TODO: Add owner validation once the schema is updated with an ownership field.
       */
      match /automatedPosts/{automatedPostId} {
        allow get: if true;
        allow list: if true;
        allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }
    }

    /**
     * @description Manages subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * // TODO: Add owner validation once the schema is updated with an ownership field.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}
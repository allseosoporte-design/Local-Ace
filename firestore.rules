/**
 * @fileoverview Firestore Security Rules for Local Leap platform.
 *
 * Core Philosophy:
 * This ruleset implements a role-based access control model with a 'superAdmin' role, and ownership-based access where appropriate.
 *
 * Data Structure:
 * - Businesses and related data (reviews, Google Business Profiles, landing pages) are stored under the `/businesses/{businessId}` path.
 * - Subscription plans and payment settings are stored in top-level collections.
 * - Super admins are stored under the `/superAdmins/{superAdminId}` path.
 * - Pending payments, subscriptions and activity logs are stored in top-level collections.
 *
 * Key Security Decisions:
 * - Only super admins can list businesses.
 * - Super admins have full access to businesses.
 * - Other collections are generally readable by anyone, but only super admins can create, update, or delete them.
 * - All write operations require an authenticated user.
 *
 * Denormalization for Authorization:
 *  None.
 *
 * Structural Segregation:
 *  No explicit segregation; assumes all data within a given collection has the same access requirements.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows super admins to manage business entities.
     * @path /businesses/{businessId}
     * @allow (list, create) if request.auth.uid is a super admin.
     * @allow (read, update, delete) if request.auth.uid is a super admin.
     * @deny (list, create) if request.auth.uid is not a super admin.
     * @deny (read, update, delete) if request.auth.uid is not a super admin.
     * @principle Enforces super admin role for business management.
     */
    match /businesses/{businessId} {
      allow list, create: if isSuperAdmin();
      allow read, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage reviews under a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage Google Business Profiles for a business.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage posts under a Google Business Profile.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage landing pages for a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage contact forms for a landing page.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows public read access to subscription plans, and super admin write access.
     * @path /subscriptionPlans/{subscriptionPlanId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows public read access to payment settings, and super admin write access.
     * @path /paymentSettings/{planSettingsId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /paymentSettings/{planSettingsId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows access control for super admins. Only super admins can manage super admin profiles.
     * @path /superAdmins/{superAdminId}
     * @allow get: if isSuperAdmin();
     * @allow list: if false;
     * @allow create: if isSuperAdmin();
     * @allow update: if isSuperAdmin();
     * @allow delete: if isSuperAdmin();
     * @deny list: if true;
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Restricts super admin management to other super admins.
     */
    match /superAdmins/{superAdminId} {
        allow get: if isSuperAdmin();
        allow list: if false;
        allow create: if isSuperAdmin();
        allow update: if isSuperAdmin();
        allow delete: if isSuperAdmin();
    }

     /**
      * @description Allows super admins to manage pending payments.
      * @path /pendingPayments/{paymentId}
      * @allow get, list: if true;
      * @allow create, update, delete: if isSuperAdmin();
      * @deny create, update, delete: if !isSuperAdmin();
      * @principle Open read access, super admin only writes.
      */
    match /pendingPayments/{paymentId} {
        allow get, list: if true;
        allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage subscriptions.
     * @path /subscriptions/{subscriptionId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /subscriptions/{subscriptionId} {
        allow get, list: if true;
        allow create, update, delete: if isSuperAdmin();
    }

    /**
     * @description Allows super admins to manage activity logs.
     * @path /activityLogs/{logId}
     * @allow get, list: if true;
     * @allow create, update, delete: if isSuperAdmin();
     * @deny create, update, delete: if !isSuperAdmin();
     * @principle Open read access, super admin only writes.
     */
    match /activityLogs/{logId} {
        allow get, list: if true;
        allow create, update, delete: if isSuperAdmin();
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }
  }
}
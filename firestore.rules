/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model. Public read access is not permitted
 * except for specific collections like subscriptions.
 *
 * Data Structure:
 * - /users/{userId}: Links auth ID to business ID.
 * - /businesses/{businessId}: Core business information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: GMB profiles.
 * - /internalFeedback/{internalFeedbackId}: Feedback from the funnel, now a root collection.
 * - /subscriptions/{subscriptionId}: Publicly readable subscription plans.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.email == 'allseosoporte@gmail.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isBusinessOwner(businessId) {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
    }

    // User profiles are private
    match /users/{userId} {
      allow read, update, delete: if isOwner(userId) || isSuperAdmin();
      allow create: if request.auth != null; // Any authenticated user can create their own profile
    }

    // Businesses are private to their owners
    match /businesses/{businessId} {
      allow read, write: if isBusinessOwner(businessId) || isSuperAdmin();
      
      // Landing pages subcollection
      match /landingPages/{pageId} {
        allow read, write: if isBusinessOwner(businessId) || isSuperAdmin();
      }
    }
    
    // GMB Profiles are private to business owners
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
        allow read, write: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId) || isSuperAdmin();

        // Subcollections of GMB profiles
        match /{subcollection}/{docId} {
           allow read, write: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId) || isSuperAdmin();
        }
    }
    
    // Subscriptions are public to read
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow write: if isSuperAdmin();
    }

    // NEW RULES FOR ROOT internalFeedback collection
    // This allows anyone to submit feedback (create)
    // but only the business owner can read it (get, list).
    match /internalFeedback/{feedbackId} {
      allow create: if true;
      allow read, list: if request.auth != null && resource.data.businessId == request.auth.uid;
      allow update, delete: if (isBusinessOwner(resource.data.businessId) || isSuperAdmin()) && resource != null;
    }

    // Global Collections for Super Admin
    match /globalAuditLogs/{logId} {
        allow read, write: if isSuperAdmin();
    }
    match /backups/{backupId} {
        allow read, write: if isSuperAdmin();
    }
     match /paymentSettings/{planId} {
        allow read, write: if isSuperAdmin();
    }
     match /pendingPayments/{paymentId} {
        allow read, write: if isSuperAdmin();
    }
     match /supportTickets/{ticketId} {
        allow read, write: if isSuperAdmin();
    }
     match /reminderRules/{ruleId} {
        allow read, write: if isSuperAdmin();
    }
    match /reminderTemplates/{templateId} {
        allow read, write: if isSuperAdmin();
    }
     match /reminderLogs/{logId} {
        allow read, write: if isSuperAdmin();
    }
    match /superAdmins/{adminId} {
        allow read, write: if isSuperAdmin();
    }
    match /subscriptionPlans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}

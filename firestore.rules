/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and businesses.
 * Businesses and associated entities can only be managed by authenticated users
 * who are linked to the business via their user profile. Public read access is not permitted
 * except for the subscriptions collection which is intended to be publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profile information, linking auth ID to business ID.
 * - /businesses/{businessId}: Stores business information. Root collection for all business-related data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback from the review funnel (root collection).
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User profiles are private and only accessible to the authenticated user.
 * - Businesses and their associated data can only be created and managed by authenticated users.
 * - Subscriptions are publicly readable, but write access is restricted.
 * - `internalFeedback` can be created by anyone but only read by the business owner.
 * - No user listing is allowed.
 *
 * Denormalization for Authorization:
 * - The `businessId` is denormalized into the `UserProfile` to link a user's auth ID to a business.
 * - The `businessId` is also a field in documents within `internalFeedback` to enforce read ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants access to user profiles based on ownership.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId) && request.resource.data.businessId == userId;
    }

    /**
     * @description Grants access to businesses and their subcollections based on ownership.
     */
    match /businesses/{businessId} {
      function isBusinessOwner() {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      allow read, update, delete: if isBusinessOwner();
      allow create: if request.auth != null;

      match /landingPages/{pageId} {
        allow read, write: if isBusinessOwner();
      }
    }
    
    /**
     * @description Grants access to internal feedback (root collection) based on business ownership.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isBusinessOwner(businessId) {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function getBusinessIdFromFeedback(internalFeedbackId) {
        return get(/databases/$(database)/documents/internalFeedback/$(internalFeedbackId)).data.businessId;
      }
      
      function userHasBusinessId() {
        return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
               && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId != null;
      }

      allow get: if isSignedIn() && isBusinessOwner(getBusinessIdFromFeedback(internalFeedbackId));
      allow list: if userHasBusinessId();
      // Allow anyone to create feedback, as long as they provide a businessId
      allow create: if request.resource.data.businessId != null;
      allow update: if isSignedIn() && resource != null && isBusinessOwner(resource.data.businessId);
      allow delete: if isSignedIn() && resource != null && isBusinessOwner(resource.data.businessId);
    }

    /**
     * @description Grants access to GMB profiles and their subcollections.
     */
    match /googleMyBusinessProfiles/{gmbProfileId} {
      function isGmbProfileOwner() {
          return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == resource.data.businessId;
      }
       function userHasBusinessId() {
        return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
               && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId != null;
      }

      allow read, update, delete: if isGmbProfileOwner();
      allow create: if request.auth != null && request.resource.data.businessId != null;
      allow list: if userHasBusinessId();

      match /reviews/{reviewId} {
        allow read, write: if isGmbProfileOwner();
      }

      match /automatedPosts/{postId} {
        allow read, write: if isGmbProfileOwner();
      }
    }

    /**
     * @description Grants public read access to subscriptions.
     */
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow write: if false; // Write access should be handled by a backend/admin role
    }
  }
}

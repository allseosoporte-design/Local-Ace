/**
 * @file Firebase Security Rules for Local Leap.
 *
 * @core_philosophy This ruleset implements a role-based access control system where SuperAdmins, identified by their presence in the `/superAdmins` collection, have elevated privileges.
 * All other access is strictly controlled based on resource ownership (e.g., a SuperAdmin managing a specific Business). Data validation is minimal during this prototyping phase.
 *
 * @data_structure
 *   - `/superAdmins/{superAdminId}`: Stores SuperAdmin profiles. Existence implies admin privileges.
 *   - `/businesses/{businessId}`: Stores Business profiles. Each Business has a `superAdminId` field indicating the owning SuperAdmin.
 *   - `/businesses/{businessId}/reviews/{reviewId}`: Stores Reviews for a Business.
 *   - `/businesses/{businessId}/landingPages/{landingPageId}`: Stores LandingPages for a Business.
 *
 * @key_security_decisions
 *   - SuperAdmin status is determined by the existence of a document in `/superAdmins/{superAdminId}`.
 *   - Listing of Businesses is restricted to SuperAdmins.
 *   - SuperAdmins have full CRUD access to Businesses they own (as indicated by the `superAdminId` field).
 *   - Reviews and Landing Pages are accessible only by the SuperAdmin associated with the parent Business.
 *   - Data validation is relaxed in this prototype phase, focusing on authorization and relationship integrity.
 *   - No public listing of data is permitted, except where explicitly allowed.
 *
 * @denormalization_for_authorization
 *   - The `businesses` documents include a `superAdminId` field that explicitly defines which `superAdmin` owns this business.  This avoids the need for complex queries or `get()` calls to determine ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants SuperAdmins full access to their profile data.
     * @path /superAdmins/{superAdminId}
     * @allow (get, create, update, delete) if isSignedIn() && isOwner(superAdminId)
     * @deny (create, update, delete) if !isSignedIn()
     * @deny (get) if false
     * @principle Enforces user-ownership for profile management.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSignedIn() && isOwner(superAdminId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(superAdminId);
      allow update: if isSignedIn() && isExistingOwner(superAdminId);
      allow delete: if isSignedIn() && isExistingOwner(superAdminId);
    }

    /**
     * @description Controls access to business profiles. SuperAdmins can create, read, update, and delete businesses that they own.
     * @path /businesses/{businessId}
     * @allow (create, update, delete) if isSignedIn() && isSuperAdminForBusiness(businessId)
     * @allow (get, list) if isSignedIn() && isSuperAdmin()
     * @deny (create, update, delete) if !isSignedIn()
     * @deny (create) if request.resource.data.superAdminId != request.auth.uid
     * @principle Enforces role-based access control for business management.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn() && isSuperAdmin();
      allow list: if isSignedIn() && isSuperAdmin();
      allow create: if isSignedIn() && isSuperAdmin() && request.resource.data.superAdminId == request.auth.uid;
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Controls access to reviews. Only the SuperAdmin who manages the business can access its reviews.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) if isSignedIn() && isSuperAdminForBusiness(businessId)
     * @allow (create, update, delete) if isSignedIn() && isSuperAdminForBusiness(businessId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces hierarchical ownership for reviews.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    /**
     * @description Controls access to landing pages. Only the SuperAdmin who manages the business can access its landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) if isSignedIn() && isSuperAdminForBusiness(businessId)
     * @allow (create, update, delete) if isSignedIn() && isSuperAdminForBusiness(businessId)
     * @deny (create, update, delete) if !isSignedIn()
     * @principle Enforces hierarchical ownership for landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId) && resource != null;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    function isSuperAdmin() {
      return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
    }

    function isSuperAdminForBusiness(businessId) {
      return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
    }
  }
}
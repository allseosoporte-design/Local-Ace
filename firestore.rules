rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @file Firestore Security Rules
     * @description This ruleset enforces a strict business-ownership model, ensuring that businesses can only access their own data.
     *
     * Data Structure:
     * - /products/{productId}: Publicly readable, but only businesses can create, update, or delete their own products. Each product contains a `businessId` field.
     * - /users/{userId}: Stores user profile information, linking their auth ID to their business ID.
     * - /businesses/{businessId}: Stores business information. Root collection for all business-related data.
     * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
     * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews for a Google My Business profile.
     * - /internalFeedback/{internalFeedbackId}: Stores internal feedback collected from customers who left negative reviews.
     * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts scheduled for a Google My Business profile.
     * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages created for a business.
     * - /subscriptions/{subscriptionId}: Stores subscription plan information.
     *
     * Key Security Decisions:
     * - Public read access to products.
     * - Strict business-ownership model for all other data.
     * - All write operations are validated against the authenticated user's business ID.
     * - No user listing is allowed.
     *
     * Denormalization for Authorization:
     * - The `Product` entity includes a `businessId` field, enabling direct authorization checks for product ownership without additional `get()` calls.
     */

    /**
     * @description Allows public read access to products, but restricts write access to the owning business.
     * @path /products/{productId}
     * @allow (get, list) - Any user can read product information.
     * @allow (create) - A business can create a product if the `businessId` matches their own.
     * @allow (update, delete) - A business can update/delete a product if the `businessId` matches their own.
     * @deny (create) - A user attempts to create a product with a `businessId` that doesn't match their own.
     * @deny (update, delete) - A user attempts to update/delete a product they don't own.
     * @principle Public read, owner-only writes. Enforces business ownership for product management.
     */
    match /products/{productId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessId();
      allow update: if isSignedIn() && request.resource.data.businessId == getBusinessId();
      allow delete: if isSignedIn() && request.resource.data.businessId == getBusinessId();
    }

    /**
     * @description Allows a user to read and write their own user profile.
     * @path /users/{userId}
     * @allow (get) - A user can read their own profile.
     * @allow (create) - A user can create their own profile if the `userId` matches their auth UID.
     * @allow (update) - A user can update their own profile.
     * @allow (delete) - A user can delete their own profile.
     * @deny (get) - A user attempts to read another user's profile.
     * @deny (create) - A user attempts to create a profile with a `userId` that doesn't match their auth UID.
     * @principle Enforces user ownership for profile management.
     */
    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isSelfCreate(userId) && request.resource.data.businessId == getBusinessId();
      allow update: if isSignedIn() && isOwner(userId) && request.resource.data.businessId == getBusinessId();
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows a business to manage its own business information.
     * @path /businesses/{businessId}
     * @allow (get) - A business can read its own information.
     * @allow (create) - A business can create their own information if the `businessId` matches their own.
     * @allow (update) - A business can update their own information.
     * @allow (delete) - A business can delete their own information.
     * @deny (get) - A user attempts to read another business's information.
     * @deny (create) - A user attempts to create a business with a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for business information management.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isSelfCreate(businessId);
      allow update: if isSignedIn() && isOwner(businessId);
      allow delete: if isSignedIn() && isOwner(businessId);
    }

    /**
     * @description Allows a business to manage its Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get) - A business can read its own Google My Business profile.
     * @allow (create) - A business can create a Google My Business profile if the associated `businessId` matches their own.
     * @allow (update) - A business can update its own Google My Business profile.
     * @allow (delete) - A business can delete its own Google My Business profile.
     * @deny (get) - A user attempts to read another business's Google My Business profile.
     * @deny (create) - A user attempts to create a Google My Business profile with a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for Google My Business profile management.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn() && isBusinessOwner(resource.data.businessId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessId();
      allow update: if isSignedIn() && isBusinessOwner(resource.data.businessId);
      allow delete: if isSignedIn() && isBusinessOwner(resource.data.businessId);
    }

    /**
     * @description Allows a business to manage customer reviews for their Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get) - A business can read reviews for their Google My Business profile.
     * @allow (list) - A business can list reviews for their Google My Business profile.
     * @allow (create) - A business can create a review if the `googleMyBusinessProfileId` matches their own Google My Business profile.
     * @allow (update) - A business can update a review for their Google My Business profile.
     * @allow (delete) - A business can delete a review for their Google My Business profile.
     * @deny (get) - A user attempts to read reviews for another business's Google My Business profile.
     * @deny (create) - A user attempts to create a review with a `googleMyBusinessProfileId` that doesn't match their own.
     * @principle Enforces business ownership for Google My Business review management.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow list: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow update: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow delete: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
    }

    /**
     * @description Allows a business to manage internal feedback received from customers.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get) - A business can read internal feedback associated with their business.
     * @allow (create) - A business can create internal feedback associated with their business.
     * @allow (update) - A business can update internal feedback associated with their business.
     * @allow (delete) - A business can delete internal feedback associated with their business.
     * @deny (get) - A user attempts to read internal feedback not associated with their business.
     * @deny (create) - A user attempts to create internal feedback not associated with their business.
     * @principle Enforces business ownership for internal feedback management.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn() && isBusinessOwner(resource.data.businessId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.businessId == getBusinessId();
      allow update: if isSignedIn() && isBusinessOwner(resource.data.businessId);
      allow delete: if isSignedIn() && isBusinessOwner(resource.data.businessId);
    }

    /**
     * @description Allows a business to manage automated posts for their Google My Business profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get) - A business can read automated posts for their Google My Business profile.
     * @allow (list) - A business can list automated posts for their Google My Business profile.
     * @allow (create) - A business can create an automated post if the `googleMyBusinessProfileId` matches their own Google My Business profile.
     * @allow (update) - A business can update an automated post for their Google My Business profile.
     * @allow (delete) - A business can delete an automated post for their Google My Business profile.
     * @deny (get) - A user attempts to read automated posts for another business's Google My Business profile.
     * @deny (create) - A user attempts to create an automated post with a `googleMyBusinessProfileId` that doesn't match their own.
     * @principle Enforces business ownership for Google My Business automated post management.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow list: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow create: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow update: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
      allow delete: if isSignedIn() && isGMBProfileOwner(googleMyBusinessProfileId);
    }

    /**
     * @description Allows a business to manage landing pages for their business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get) - A business can read landing pages for their business.
     * @allow (list) - A business can list landing pages for their business.
     * @allow (create) - A business can create a landing page if the `businessId` matches their own.
     * @allow (update) - A business can update a landing page for their business.
     * @allow (delete) - A business can delete a landing page for their business.
     * @deny (get) - A user attempts to read landing pages for another business.
     * @deny (create) - A user attempts to create a landing page with a `businessId` that doesn't match their own.
     * @principle Enforces business ownership for landing page management.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isOwner(businessId);
      allow delete: if isSignedIn() && isOwner(businessId);
    }

    /**
     * @description Allows anyone to read subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) - Anyone can read subscription plan information.
     * @allow (list) - Anyone can list subscription plan information.
     * @deny (create, update, delete) - No one is allowed to create, update, or delete subscription plans through client-side rules.
     * @principle Public read, restricted writes.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(documentId) {
        return request.auth.uid == documentId;
    }

    function isSelfCreate(documentId) {
        return request.auth.uid == documentId;
    }

    function getBusinessId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
    }

    function isBusinessOwner(businessId) {
      return getBusinessId() == businessId;
    }

    function isGMBProfileOwner(googleMyBusinessProfileId) {
      return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == getBusinessId();
    }
  }
}
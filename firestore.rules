/**
 * @file Firebase Security Rules for Local Leap SaaS Platform
 *
 * @corePhilosophy This ruleset enforces a strict ownership model for businesses
 * and their associated data, ensuring that only authenticated users can access
 * and modify data related to their businesses.  GoogleMyBusinessProfiles, Reviews,
 * and AutomatedPosts are secured by checking the parent Business ID. InternalFeedback
 * is accessible only to authenticated users. Subscriptions are publicly readable,
 * but only authorized users can modify them.
 *
 * @dataStructure The data is organized into top-level collections for
 * businesses, Google My Business profiles, internal feedback, and subscriptions.
 * Business-owned data (landing pages, reviews, automated posts) is stored in
 * subcollections under the respective business or profile documents. This
 * structure enables efficient querying and enforces ownership.
 *
 * @keySecurityDecisions
 *  - User listing is disallowed.
 *  - Reviews and AutomatedPosts are subcollections of GoogleMyBusinessProfiles and are secured by businessId.
 *  - InternalFeedback is a root-level collection accessible to authenticated users.
 *  - Subscriptions are readable by everyone, but writable only by authorized users (TODO).
 *
 * @denormalization This ruleset relies on denormalization to avoid costly `get()`
 *  calls in the security rules. Specifically, the `businessId` is present on
 *  GoogleMyBusinessProfile documents and is used to control access to the profile
 *  and its subcollections (reviews, automated posts).
 *
 * @structuralSegregation Private business data is stored under the `/businesses/{businessId}`
 *  path, while subscriptions are stored in a top-level collection with public
 *  read access. This segregation allows for different access control policies
 *  for private and public data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is made by an authenticated user.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document.
     * @param {string} userId The user ID to compare against the authenticated user's ID.
     * @return {bool} True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Security rules for the /businesses/{businessId} collection.
     * @path /businesses/{businessId}
     * @allow (create) If the authenticated user's ID matches the businessId.
     * @deny (create) If the authenticated user's ID does not match the businessId.
     * @allow (get) If the authenticated user's ID matches the businessId.
     * @deny (get) If the authenticated user's ID does not match the businessId.
     * @allow (update) If the authenticated user's ID matches the businessId and the document exists.
     * @deny (update) If the authenticated user's ID does not match the businessId or the document does not exist.
     * @allow (delete) If the authenticated user's ID matches the businessId and the document exists.
     * @deny (delete) If the authenticated user's ID does not match the businessId or the document does not exist.
     * @principle Enforces document ownership for all operations.
     */
    match /businesses/{businessId} {
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Security rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) If the authenticated user's ID matches the businessId in the request.resource.data.
     * @deny (create) If the authenticated user's ID does not match the businessId in the request.resource.data.
     * @allow (get) If the authenticated user's ID matches the businessId in the resource.data.
     * @deny (get) If the authenticated user's ID does not match the businessId in the resource.data.
     * @allow (update) If the authenticated user's ID matches the businessId in the resource.data and the document exists.
     * @deny (update) If the authenticated user's ID does not match the businessId in the resource.data or the document does not exist.
     * @allow (delete) If the authenticated user's ID matches the businessId in the resource.data and the document exists.
     * @deny (delete) If the authenticated user's ID does not match the businessId in the resource.data or the document does not exist.
     * @principle Enforces document ownership based on the businessId field.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn() && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.id == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow update: if isSignedIn() && resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.id == request.auth.uid;
      allow delete: if isSignedIn() && resource != null && get(/databases/$(database)/documents/businesses/$(resource.data.businessId)).data.id == request.auth.uid;
    }

    /**
     * @description Security rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document.
     * @deny (create) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document.
     * @allow (get) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document.
     * @deny (get) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document.
     * @allow (update) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document and the document exists.
     * @deny (update) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document or the document does not exist.
     * @allow (delete) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document and the document exists.
     * @deny (delete) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document or the document does not exist.
     * @principle Enforces document ownership based on the businessId of the parent document.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
       allow get: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
       allow list: if false;
       allow create: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
       allow update: if isSignedIn() && resource != null && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
       allow delete: if isSignedIn() && resource != null && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
    }

    /**
     * @description Security rules for the /internalFeedback/{internalFeedbackId} collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) If the user is signed in.
     * @deny (create) If the user is not signed in.
     * @allow (get) If the user is signed in.
     * @deny (get) If the user is not signed in.
     * @allow (update) If the user is signed in and the document exists.
     * @deny (update) If the user is not signed in or the document does not exist.
     * @allow (delete) If the user is signed in and the document exists.
     * @deny (delete) If the user is not signed in or the document does not exist.
     * @principle Requires authentication for all operations.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    /**
     * @description Security rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document.
     * @deny (create) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document.
     * @allow (get) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document.
     * @deny (get) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document.
     * @allow (update) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document and the document exists.
     * @deny (update) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document or the document does not exist.
     * @allow (delete) If the authenticated user's ID matches the businessId in the parent GoogleMyBusinessProfile document and the document exists.
     * @deny (delete) If the authenticated user's ID does not match the businessId in the parent GoogleMyBusinessProfile document or the document does not exist.
     * @principle Enforces document ownership based on the businessId of the parent document.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
      allow list: if false;
      allow create: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
      allow update: if isSignedIn() && resource != null && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
      allow delete: if isSignedIn() && resource != null && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
    }

    /**
     * @description Security rules for the /businesses/{businessId}/landingPages/{landingPageId} collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) If the authenticated user's ID matches the businessId in the path.
     * @deny (create) If the authenticated user's ID does not match the businessId in the path.
     * @allow (get) If the authenticated user's ID matches the businessId in the path.
     * @deny (get) If the authenticated user's ID does not match the businessId in the path.
     * @allow (update) If the authenticated user's ID matches the businessId in the path and the document exists.
     * @deny (update) If the authenticated user's ID does not match the businessId in the path or the document does not exist.
     * @allow (delete) If the authenticated user's ID matches the businessId in the path and the document exists.
     * @deny (delete) If the authenticated user's ID does not match the businessId in the path or the document does not exist.
     * @principle Enforces document ownership based on the businessId in the path.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isOwner(businessId);
      allow list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Security rules for the /subscriptions/{subscriptionId} collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Public read access.
     * @allow (list) Public list access.
     * @deny (create) No public create access.
     * @deny (update) No public update access.
     * @deny (delete) No public delete access.
     * // TODO: Add admin-only writes
     * @principle Public read access with restricted writes.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;  // TODO: Add admin-only writes
      allow update: if false;  // TODO: Add admin-only writes
      allow delete: if false;  // TODO: Add admin-only writes
    }
  }
}
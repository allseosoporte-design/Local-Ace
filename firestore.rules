/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and businesses.
 * Businesses and Users can only create/read/update/delete their own data.
 * All subcollections inherit the authorization context from their parent documents,
 * and access is controlled by validating relationships.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, linked to a business.
 * - /businesses/{businessId}: Stores business details, the root for business-owned data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores customer reviews for a GMB profile.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback for negative reviews.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts for GMB profiles.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for businesses.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information (publicly readable).
 *
 * Key Security Decisions:
 * - User profiles are owner-readable and writable.
 * - Businesses are owner-creatable and writable.
 * - Subscriptions are publicly readable.
 * - Other collections follow the ownership model based on businessId or googleMyBusinessProfileId.
 * - InternalFeedback is publicly writable.
 * - Data validation is relaxed to allow rapid prototyping.
 *
 * Denormalization for Authorization:
 * The googleMyBusinessProfile documents contain the businessId of the parent business, to enforce independent authorization rules.
 * The Review documents do not contain the businessId of the parent business.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own user profile.
     * @path /users/{userId}
     * @allow (read, write) User with matching UID.
     * @deny (read, write) User with non-matching UID.
     * @principle Enforces user-ownership for profile access.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows businesses to create, read, update, and delete their own business information.
     * @path /businesses/{businessId}
     * @allow (create) Authenticated user creating a business with matching ID.
     * @allow (read, update, delete) Authenticated user accessing their own business.
     * @deny (create, read, update, delete) Authenticated user accessing a different business.
     * @principle Enforces business-ownership for data access.
     */
    match /businesses/{businessId} {
      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && exists(/databases/$(database)/documents/businesses/$(businessId));
      }

      allow get: if isExistingOwner(businessId);
      allow list: if false;
      allow create: if request.auth.uid == businessId;
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Allows access to Google My Business profiles based on business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (read) Any authenticated user.
     * @allow (create, update, delete) Owner of the associated business.
     * @deny (create, update, delete) Non-owner of the associated business.
     * @principle Enforces business-ownership for GMB profile management.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function getBusinessId() {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }
      function isBusinessOwner() {
        return getBusinessId() == request.auth.uid;
      }
      allow get: if true;
      allow list: if false;
      allow create: if request.auth.uid != null;
      allow update: if isBusinessOwner();
      allow delete: if isBusinessOwner();
    }

    /**
     * @description Allows access to reviews associated with a Google My Business profile based on ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (read, list) Any authenticated user.
     * @allow (create, update, delete) Owner of the associated Google My Business profile.
     * @deny (create, update, delete) Non-owner of the associated Google My Business profile.
     * @principle Enforces business-ownership for review management.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function getBusinessId() {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }
      function isBusinessOwner() {
        return getBusinessId() == request.auth.uid;
      }
      allow get: if true;
      allow list: if false;
      allow create: if request.auth.uid != null;
      allow update: if isBusinessOwner();
      allow delete: if isBusinessOwner();
    }

    /**
     * @description Allows anyone to create internal feedback. Other operations are denied.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any authenticated user.
     * @deny (read, update, delete) All requests.
     * @principle Allows anonymous feedback submission.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if false;
      allow list: if false;
      allow create: if true;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows access to automated posts associated with a Google My Business profile based on ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (read, list) Any authenticated user.
     * @allow (create, update, delete) Owner of the associated Google My Business profile.
     * @deny (create, update, delete) Non-owner of the associated Google My Business profile.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function getBusinessId() {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }
      function isBusinessOwner() {
        return getBusinessId() == request.auth.uid;
      }
      allow get: if true;
      allow list: if false;
      allow create: if request.auth.uid != null;
      allow update: if isBusinessOwner();
      allow delete: if isBusinessOwner();
    }

    /**
     * @description Allows access to landing pages associated with a business based on ownership.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (read, list) Any authenticated user.
     * @allow (create, update, delete) Owner of the associated business.
     * @deny (create, update, delete) Non-owner of the associated business.
     * @principle Enforces business-ownership for landing page management.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isBusinessOwner(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.id == request.auth.uid;
      }
      allow get: if true;
      allow list: if false;
      allow create: if request.auth.uid != null;
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);
    }

    /**
     * @description Allows anyone to read subscription information, but no one can create, update, or delete.
     * @path /subscriptions/{subscriptionId}
     * @allow (read, list) Any user.
     * @deny (create, update, delete) All requests.
     * @principle Allows public access to subscription plans.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict ownership model for businesses and their associated data.
 * Data related to a business is secured to only be accessible by the authenticated user who owns the business.
 * Public read access is granted to specific collections like `Subscriptions` and `LandingPages`, while write access remains restricted to authorized users.
 *
 * @dataStructure
 * - /subscriptions/{subscriptionId}: Publicly readable subscription data.
 * - /businesses/{businessId}: Business data, accessible only by the business owner.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages associated with a business, publicly readable but only writable by the business owner.
 * - /businesses/{businessId}/privateFeedback/{feedbackId}: Private feedback associated with a business, accessible and updatable only by the business owner, but creatable by anyone.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profile data, accessible only by the business owner.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Reviews for a Google My Business profile, accessible only by the business owner.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for a Google My Business profile, accessible only by the business owner.
 * - /internalFeedback/{internalFeedbackId}: Internal feedback data, publicly readable and writable by any signed-in user.
 *
 * @keySecurityDecisions
 * - Strict ownership enforced for business data and associated subcollections.
 * - Public read access granted to Subscriptions and Landing Pages for wider accessibility.
 * - Public write access (create) for Internal Feedback, only for authenticated users.
 * - Listing of documents is generally restricted to the owner, except for public collections.
 * - No user listing is allowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(businessId) {
      return request.auth.uid == businessId;
    }

    function isExistingOwner(businessId) {
      return isOwner(businessId) && resource != null;
    }

    /**
     * @description Allows public read access to subscription data. Write access is denied.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription data.
     * @deny (create, update, delete) - No user can create, update, or delete subscription data.
     * @principle Allows public read access for subscription information.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Enforces owner-only access for businesses. Only the authenticated user with a matching businessId can read, create, update, or delete business data.
     * @path /businesses/{businessId}
     * @allow (get, list, create) - Authenticated user with matching businessId can read and create.
     * @allow (update, delete) - Authenticated user with matching businessId can update and delete if the document exists.
     * @deny (get, list, create, update, delete) - Any other user cannot perform these operations.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      allow get, list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      /**
       * @description Allows public read access to landing pages associated with a business. Only the business owner can create, update, or delete landing pages.
       * @path /businesses/{businessId}/landingPages/{landingPageId}
       * @allow (get, list) - Any user can read landing page data.
       * @allow (create, update, delete) - Authenticated user with matching businessId can create, update, and delete landing pages.
       * @deny (create, update, delete) - Any other user cannot perform these operations.
       * @principle Allows public read access while enforcing document ownership for writes.
       */
      match /landingPages/{landingPageId} {
        allow get, list: if true;
        allow create: if isOwner(businessId);
        allow update: if isOwner(businessId);
        allow delete: if isOwner(businessId);
      }

      /**
       * @description Allows public creation of private feedback associated with a business. Only the business owner can read, update, or delete the feedback.
       * @path /businesses/{businessId}/privateFeedback/{feedbackId}
       * @allow (get, list, update, delete) - Authenticated user with matching businessId can read, update, and delete private feedback.
       * @allow (create) - Any user can create private feedback.
       * @deny (get, list, update, delete) - Any other user cannot perform these operations.
       * @principle Allows public submission of feedback, but restricts management to the business owner.
       */
      match /privateFeedback/{feedbackId} {
        allow get, list: if isOwner(businessId);
        allow create: if true;
        allow update: if isOwner(businessId);
        allow delete: if isOwner(businessId);
      }
    }

    /**
     * @description Enforces owner-only access for Google My Business profiles. The authenticated user's UID must match the businessId stored in the document.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list, update, delete) - Authenticated user with matching businessId in the document can perform these operations if the document exists.
     * @allow (create) - Authenticated user's UID must match the businessId in the request data.
     * @deny (get, list, create, update, delete) - Any other user cannot perform these operations.
     * @principle Enforces document ownership based on businessId.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get, list: if request.auth.uid == resource.data.businessId;
      allow create: if request.auth.uid == request.resource.data.businessId;
      allow update: if request.auth.uid == resource.data.businessId && resource != null;
      allow delete: if request.auth.uid == resource.data.businessId && resource != null;

      /**
       * @description Enforces owner-only access for reviews associated with a Google My Business profile. The authenticated user's UID must match the businessId of the parent profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       * @allow (get, list, update, delete) - Authenticated user with matching businessId in the parent document can perform these operations if the document exists.
       * @allow (create) - Authenticated user's UID must match the businessId of the parent GoogleMyBusinessProfile.
       * @deny (get, list, create, update, delete) - Any other user cannot perform these operations.
       * @principle Enforces ownership based on businessId in the parent document.
       */
      match /reviews/{reviewId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }

      /**
       * @description Enforces owner-only access for automated posts associated with a Google My Business profile. The authenticated user's UID must match the businessId of the parent profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       * @allow (get, list, update, delete) - Authenticated user with matching businessId in the parent document can perform these operations if the document exists.
       * @allow (create) - Authenticated user's UID must match the businessId of the parent GoogleMyBusinessProfile.
       * @deny (get, list, create, update, delete) - Any other user cannot perform these operations.
       * @principle Enforces ownership based on businessId in the parent document.
       */
      match /automatedPosts/{automatedPostId} {
        allow get, list: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow update: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
        allow delete: if get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid && resource != null;
      }
    }

    /**
     * @description Allows public read access and signed-in user write access (create) to internal feedback data. Update and delete operations are denied.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Any user can read internal feedback data.
     * @allow (create) - Any signed-in user can create internal feedback.
     * @deny (update, delete) - No user can update or delete internal feedback data.
     * @principle Allows public read access and signed-in user submission of internal feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Users must be authenticated to access any data, and they can only access data related to their own business.
 * The rules prioritize authorization independence to avoid costly `get()` calls.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores GMB profile data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Subcollection for customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback (not directly tied to a business).
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Subcollection for automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - All write operations require authentication.
 * - Read operations on /businesses/{businessId} are restricted to the business owner.
 * - Read operations on /subscriptions/{subscriptionId} are open to all authenticated users.
 * - Subcollections inherit the ownership of their parent documents.
 * - Listing operations are generally restricted to the owner, except for the root-level subscriptions collection.
 *
 * Denormalization for Authorization:
 * - The `googleMyBusinessProfiles` collection includes the `businessId` to avoid needing to fetch the parent `business` document for authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the current user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     */
    function isOwner(businessId) {
      return isSignedIn() && request.auth.uid == businessId;
    }

    /**
     * @description Checks if the authenticated user owns the existing document.
     */
    function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
    }

    /**
     * @description Rules for the /businesses collection.
     * @path /businesses/{businessId}
     * @allow (get) Authenticated user can get their own business.
     * @allow (create) Authenticated user can create their own business.
     * @allow (update) Authenticated user can update their own business.
     * @allow (delete) Authenticated user can delete their own business.
     * @deny (get) Authenticated user cannot get another user's business.
     * @deny (create) Unauthenticated user cannot create a business.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get) Authenticated user can get a Google My Business profile if they own the parent business.
     * @allow (create) Authenticated user can create a Google My Business profile if they own the parent business.
     * @allow (update) Authenticated user can update a Google My Business profile if they own the parent business.
     * @allow (delete) Authenticated user can delete a Google My Business profile if they own the parent business.
     * @deny (get) Authenticated user cannot get a Google My Business profile if they do not own the parent business.
     * @deny (create) Unauthenticated user cannot create a Google My Business profile.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get) Authenticated user can get a review if they own the parent Google My Business profile.
     * @allow (create) Authenticated user can create a review if they own the parent Google My Business profile.
     * @allow (update) Authenticated user can update a review if they own the parent Google My Business profile.
     * @allow (delete) Authenticated user can delete a review if they own the parent Google My Business profile.
     * @deny (get) Authenticated user cannot get a review if they do not own the parent Google My Business profile.
     * @deny (create) Unauthenticated user cannot create a review.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /internalFeedback collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get) Any authenticated user can get internal feedback.
     * @allow (create) Any authenticated user can create internal feedback.
     * @allow (update) Any authenticated user can update internal feedback.
     * @allow (delete) Any authenticated user can delete internal feedback.
     * @deny (get) Unauthenticated user cannot get internal feedback.
     * @principle Allows any authenticated user to read and write internal feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get) Authenticated user can get an automated post if they own the parent Google My Business profile.
     * @allow (create) Authenticated user can create an automated post if they own the parent Google My Business profile.
     * @allow (update) Authenticated user can update an automated post if they own the parent Google My Business profile.
     * @allow (delete) Authenticated user can delete an automated post if they own the parent Google My Business profile.
     * @deny (get) Authenticated user cannot get an automated post if they do not own the parent Google My Business profile.
     * @deny (create) Unauthenticated user cannot create an automated post.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Rules for the /businesses/{businessId}/landingPages collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get) Authenticated user can get a landing page if they own the parent business.
     * @allow (create) Authenticated user can create a landing page if they own the parent business.
     * @allow (update) Authenticated user can update a landing page if they own the parent business.
     * @allow (delete) Authenticated user can delete a landing page if they own the parent business.
     * @deny (get) Authenticated user cannot get a landing page if they do not own the parent business.
     * @deny (create) Unauthenticated user cannot create a landing page.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isOwner(businessId);
      allow list: if isOwner(businessId);
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for the /subscriptions collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Any authenticated user can get a subscription.
     * @allow (list) Any authenticated user can list subscriptions.
     * @deny (create) No one can create a subscription via the client.
     * @deny (update) No one can update a subscription via the client.
     * @deny (delete) No one can delete a subscription via the client.
     * @principle Allows any authenticated user to read subscription information, but restricts write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
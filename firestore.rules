/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for user profiles and businesses.
 * A super admin role is defined for full access.
 *
 * Data Structure:
 * - /users/{userId}: Links auth ID to business ID.
 * - /businesses/{businessId}: Root collection for business data.
 * - /internalFeedback/{internalFeedbackId}: Root collection for private feedback.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Functions ---
    function isSuperAdmin() {
      return request.auth != null && request.auth.token.isSuperAdmin == true;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBusinessOwner(businessId) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isSuperAdmin();
      allow list: if isSuperAdmin();
    }

    // --- Businesses ---
    match /businesses/{businessId} {
      allow read: if isBusinessOwner(businessId) || isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isBusinessOwner(businessId) || isSuperAdmin();

      // Subcollections
      match /landingPages/{pageId} {
        // Public read for the super admin's business landing page
        allow read: if businessId == 'allseosoporte' || isBusinessOwner(businessId) || isSuperAdmin();
        allow write: if isBusinessOwner(businessId) || isSuperAdmin();
      }
    }

    // --- Internal Feedback (Root Collection) ---
    match /internalFeedback/{internalFeedbackId} {
      // Allow anyone to create feedback, as long as they provide a businessId.
      // This is for the public funnel form.
      allow create: if request.resource.data.businessId is string;

      // Only the business owner or a super admin can read the feedback.
      allow read, update, delete: if (isSignedIn() && isBusinessOwner(resource.data.businessId)) || isSuperAdmin();
      allow list: if isSuperAdmin();
    }

    // --- Collection Group for Internal Feedback ---
    // This rule allows a business owner to list their own feedback across all documents.
    match /{path=**}/internalFeedback/{feedbackId} {
       allow list: if isSignedIn() && request.query.where.businessId == request.auth.uid;
    }


    // --- Admin & Global Collections ---
    match /subscriptions/{subscriptionId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /subscriptionPlans/{planId} {
       allow read: if true;
       allow write: if isSuperAdmin();
    }
    
    match /paymentSettings/{planId} {
        allow read, write: if isSuperAdmin();
    }

    match /superAdmins/{adminId} {
        allow read, write: if isOwner(adminId);
    }
    
    match /globalAuditLogs/{logId} {
       allow read, write: if isSuperAdmin();
    }

    match /backups/{backupId} {
        allow read, write: if isSuperAdmin();
    }

    match /pendingPayments/{paymentId} {
       allow read, write: if isSuperAdmin();
    }

     match /supportTickets/{ticketId} {
        allow read, write: if isSuperAdmin();
     }

     match /reminderRules/{ruleId} {
        allow read, write: if isSuperAdmin();
     }

     match /reminderTemplates/{templateId} {
        allow read, write: if isSuperAdmin();
     }

     match /reminderLogs/{logId} {
        allow read, write: if isSuperAdmin();
     }

  }
}

/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-ownership model,
 *              allowing users to manage their own profiles and businesses to manage their associated data.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, linked to a business.
 * - /businesses/{businessId}: Business data, the root for business-owned data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Customer reviews.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages.
 * - /subscriptions/{subscriptionId}: Subscription plans (public read).
 *
 * Key Security Decisions:
 * - User profiles are only readable and writable by the owning user.
 * - Businesses and their associated data can be managed by authenticated users associated with the business.
 * - Subscriptions are publicly readable.
 * - Data required for authorization (businessId) is denormalized onto documents to avoid costly `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if the user's UID matches the userId.
     * @deny (get, list, create, update, delete) if the user's UID does not match the userId.
     * @principle Enforces document ownership for all operations on user profiles.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.businessId is string && request.auth.uid == userId;
      allow update: if isOwner(userId) && resource.data.businessId == request.resource.data.businessId;
      allow delete: if isOwner(userId) && resource != null;
    }

    /**
     * @description Allows businesses to manage their own information.
     * @path /businesses/{businessId}
     * @allow (get, list, create, update, delete) if the user is authenticated and the businessId matches the businessId in their user profile.
     * @deny (get, list, create, update, delete) if the user is not authenticated or the businessId does not match.
     * @principle Enforces business ownership for all operations on business documents.
     */
    match /businesses/{businessId} {
      function isBusinessOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwner(businessId);
      allow create: if isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Allows access to Google My Business Profiles only to users who own the linked Business.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list, create, update, delete) if the user is authenticated and owns the linked business.
     * @deny (get, list, create, update, delete) if the user is not authenticated or doesn't own the linked business.
     * @principle Enforces business ownership for all operations on Google My Business profiles.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) {
          let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId);
      allow create: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && request.resource.data.businessId is string;
      allow update: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
      allow delete: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
    }

    /**
     * @description Allows access to Reviews only to users who own the linked Google My Business Profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (get, list, create, update, delete) if the user is authenticated and owns the linked Google My Business Profile.
     * @deny (get, list, create, update, delete) if the user is not authenticated or doesn't own the linked Google My Business Profile.
     * @principle Enforces ownership for all operations on Reviews.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
       function isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) {
          let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId);
      allow create: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId);
      allow update: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
      allow delete: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
    }

    /**
     * @description Allows access to Internal Feedback only to users who own the linked Business.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (get, list, create, update, delete) if the user is authenticated and owns the linked Business.
     * @deny (get, list, create, update, delete) if the user is not authenticated or doesn't own the linked Business.
     * @principle Enforces ownership for all operations on InternalFeedback.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isBusinessOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwner(businessId);
      allow create: if isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Allows access to Automated Posts only to users who own the linked Google My Business Profile.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (get, list, create, update, delete) if the user is authenticated and owns the linked Google My Business Profile.
     * @deny (get, list, create, update, delete) if the user is not authenticated or doesn't own the linked Google My Business Profile.
     * @principle Enforces ownership for all operations on Automated Posts.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
       function isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) {
          let businessId = get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId);
      allow create: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId);
      allow update: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
      allow delete: if isBusinessOwnerOfGMBProfile(googleMyBusinessProfileId) && resource != null;
    }

    /**
     * @description Allows access to Landing Pages only to users who own the linked Business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list, create, update, delete) if the user is authenticated and owns the linked Business.
     * @deny (get, list, create, update, delete) if the user is not authenticated or doesn't own the linked Business.
     * @principle Enforces ownership for all operations on Landing Pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isBusinessOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      allow get, list: if isBusinessOwner(businessId);
      allow create: if isBusinessOwner(businessId);
      allow update: if isBusinessOwner(businessId) && resource != null;
      allow delete: if isBusinessOwner(businessId) && resource != null;
    }

    /**
     * @description Allows public read access to subscription plans.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) to anyone.
     * @deny (create, update, delete) to everyone.
     * @principle Allows public read access, restricts write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
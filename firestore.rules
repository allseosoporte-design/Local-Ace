rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Secures the /businesses collection, ensuring only the owner can read or write business data.
     * @path /businesses/{businessId}
     * @allow (create) - Authenticated user creates a new business with their user ID as the businessId.
     * @allow (get, list, update, delete) - Authenticated user with a matching businessId attempts to read, update, or delete their business data.
     * @deny (create) - Unauthenticated user attempts to create a business.
     * @deny (update) - Authenticated user with a mismatched businessId attempts to update business data.
     * @principle Enforces document ownership for all operations on the /businesses collection.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return isSignedIn() && request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if isOwner(businessId);
      allow create: if isSignedIn() && request.auth.uid == businessId;
      allow update: if isOwner(businessId);
      allow delete: if isOwner(businessId);
    }

    /**
     * @description Secures the /googleMyBusinessProfiles collection, ensuring only the owner can read or write Google My Business profile data.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - Authenticated user creates a new Google My Business profile with a businessId they own.
     * @allow (get, list, update, delete) - Authenticated user with a matching businessId in the Google My Business profile attempts to read, update, or delete the profile.
     * @deny (create) - Unauthenticated user attempts to create a Google My Business profile.
     * @deny (update) - Authenticated user with a mismatched businessId attempts to update the profile.
     * @principle Enforces document ownership for all operations on the /googleMyBusinessProfiles collection.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return isSignedIn() && request.auth.uid == businessId;
      }

      allow get, list: if isOwner(resource.data.businessId);
      allow create: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow update: if isOwner(resource.data.businessId);
      allow delete: if isOwner(resource.data.businessId);
    }

    /**
     * @description Secures the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection, ensuring only the owner can read or write reviews.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - Authenticated user creates a new review for a Google My Business profile they own.
     * @allow (get, list, update, delete) - Authenticated user with a matching businessId in the Google My Business profile attempts to read, update, or delete the review.
     * @deny (create) - Unauthenticated user attempts to create a review.
     * @deny (update) - Authenticated user with a mismatched businessId attempts to update the review.
     * @principle Enforces document ownership for all operations on the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews collection.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
          function isSignedIn() {
        return request.auth != null;
      }

      function getBusinessId() {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return isSignedIn() && request.auth.uid == businessId;
      }

      allow get, list: if isOwner(getBusinessId());
      allow create: if isOwner(getBusinessId());
      allow update: if isOwner(getBusinessId());
      allow delete: if isOwner(getBusinessId());
    }

    /**
     * @description Secures the /internalFeedback collection, ensuring only authenticated users can create feedback.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) - Authenticated user creates new internal feedback.
     * @deny (get, list, update, delete) - No one can get, list, update, or delete internal feedback.
     * @principle Restricts write access to the /internalFeedback collection to authenticated users.
     */
    match /internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }
        allow get, list: if false;
        allow create: if isSignedIn();
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Secures the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection, ensuring only the owner can read or write automated posts.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - Authenticated user creates a new automated post for a Google My Business profile they own.
     * @allow (get, list, update, delete) - Authenticated user with a matching businessId in the Google My Business profile attempts to read, update, or delete the automated post.
     * @deny (create) - Unauthenticated user attempts to create an automated post.
     * @deny (update) - Authenticated user with a mismatched businessId attempts to update the automated post.
     * @principle Enforces document ownership for all operations on the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts collection.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
          function isSignedIn() {
        return request.auth != null;
      }

      function getBusinessId() {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return isSignedIn() && request.auth.uid == businessId;
      }

      allow get, list: if isOwner(getBusinessId());
      allow create: if isOwner(getBusinessId());
      allow update: if isOwner(getBusinessId());
      allow delete: if isOwner(getBusinessId());
    }

    /**
     * @description Secures the /businesses/{businessId}/landingPages collection, ensuring only the owner can read or write landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Authenticated user creates a new landing page for a business they own.
     * @allow (get, list, update, delete) - Authenticated user with a matching businessId attempts to read, update, or delete the landing page.
     * @deny (create) - Unauthenticated user attempts to create a landing page.
     * @deny (update) - Authenticated user with a mismatched businessId attempts to update the landing page.
     * @principle Enforces document ownership for all operations on the /businesses/{businessId}/landingPages collection.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return isSignedIn() && request.auth.uid == businessId;
      }

        allow get, list: if isOwner(businessId);
        allow create: if isOwner(businessId);
        allow update: if isOwner(businessId);
        allow delete: if isOwner(businessId);
    }

    /**
     * @description Secures the /subscriptions collection, allowing public read access but no writes.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription information.
     * @deny (create, update, delete) - No user can create, update, or delete subscription information.
     * @principle Provides public read access to subscription plans while restricting write access.
     */
    match /subscriptions/{subscriptionId} {
        allow get, list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }
  }
}
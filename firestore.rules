/**
 * @fileoverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model for super admins and an ownership model for businesses and their associated data.  Super admins have elevated privileges to manage businesses and subscription plans.  Businesses and associated reviews, and landing pages are secured based on the super admin that manages that business.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin accounts.
 * - /businesses/{businessId}: Stores business accounts, each with a `superAdminId` field.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews associated with a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages associated with a business.
 * - /subscriptionPlans/{planId}: Stores subscription plans, accessible to all for reading, but managed by super admins.
 *
 * Key Security Decisions:
 * - Super admins can manage businesses and subscription plans.
 * - Businesses and associated reviews and landing pages are secured based on the super admin that manages that business.
 * - Subscription plans are readable by all, but only manageable by super admins.
 * - Data consistency is enforced where necessary, ensuring that `businessId` and `superAdminId` fields match the document path.
 *
 * Denormalization for Authorization:
 * - The `Business` entity includes a `superAdminId` field to enable direct authorization checks without requiring additional `get()` calls.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages super administrator accounts.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin account if the userId matches the document id.
     * @allow (get, list, update, delete) - Only the superAdmin can access their own account.
     * @deny (create) - A user cannot create a superAdmin account for another user.
     * @deny (update, delete) - A non-superAdmin user cannot modify or delete a superAdmin account.
     * @principle Enforces document ownership for superAdmin accounts.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId) && request.resource.data.id == superAdminId;
      allow update: if isExistingOwner(superAdminId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Manages business accounts.
     * @path /businesses/{businessId}
     * @allow (create) - A superAdmin can create a business account. The `superAdminId` in the document must match the authenticated user's UID.
     * @allow (get, list, update, delete) - Only the superAdmin who owns the business can access and modify it.
     * @deny (create) - A non-superAdmin user cannot create a business account.
     * @deny (update, delete) - A non-superAdmin user cannot modify or delete a business account.
     * @principle Enforces document ownership by a superAdmin for business accounts.
     */
    match /businesses/{businessId} {
      function isSuperAdmin(superAdminId) {
        return request.auth.uid == superAdminId;
      }

      function isExistingSuperAdmin(superAdminId) {
        return isSuperAdmin(superAdminId) && resource != null;
      }

      allow get: if isSuperAdmin(resource.data.superAdminId);
      allow list: if false;
      allow create: if isSuperAdmin(request.resource.data.superAdminId) && request.resource.data.id == businessId;
      allow update: if isExistingSuperAdmin(resource.data.superAdminId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingSuperAdmin(resource.data.superAdminId);
    }

    /**
     * @description Manages reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) - Only the superAdmin associated with the business can read the reviews.
     * @allow (create) - Only the superAdmin associated with the business can create a review. The `businessId` in the document must match the path.
     * @allow (update, delete) - Only the superAdmin associated with the business can modify or delete the reviews.
     * @deny (create) - A regular user cannot create, modify, or delete reviews.
     * @principle Enforces document ownership for reviews by ensuring the superAdmin manages the parent business.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSuperAdminForBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      function isExistingSuperAdminForBusiness(businessId) {
          return isSuperAdminForBusiness(businessId) && resource != null;
      }

      allow get: if isSuperAdminForBusiness(businessId);
      allow list: if isSuperAdminForBusiness(businessId);
      allow create: if isSuperAdminForBusiness(businessId) && request.resource.data.businessId == businessId;
      allow update: if isExistingSuperAdminForBusiness(businessId) && request.resource.data.businessId == businessId;
      allow delete: if isExistingSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) - Only the superAdmin associated with the business can read the landing pages.
     * @allow (create) - Only the superAdmin associated with the business can create a landing page. The `businessId` in the document must match the path.
     * @allow (update, delete) - Only the superAdmin associated with the business can modify or delete the landing pages.
     * @deny (create) - A regular user cannot create, modify, or delete landing pages.
     * @principle Enforces document ownership for landing pages by ensuring the superAdmin manages the parent business.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
     function isSuperAdminForBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      function isExistingSuperAdminForBusiness(businessId) {
          return isSuperAdminForBusiness(businessId) && resource != null;
      }

      allow get: if isSuperAdminForBusiness(businessId);
      allow list: if isSuperAdminForBusiness(businessId);
      allow create: if isSuperAdminForBusiness(businessId) && request.resource.data.businessId == businessId;
      allow update: if isExistingSuperAdminForBusiness(businessId) && request.resource.data.businessId == businessId;
      allow delete: if isExistingSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages subscription plans.
     * @path /subscriptionPlans/{planId}
     * @allow (get, list) - Anyone can read the subscription plans.
     * @allow (create, update, delete) - Only a superAdmin can manage the subscription plans.
     * @deny (create, update, delete) - Regular users cannot create, modify, or delete subscription plans.
     * @principle Enforces read-only access for regular users and administrative control for superAdmins.
     */
    match /subscriptionPlans/{planId} {
      function isSuperAdminDocumentExists(superAdminId) {
          return exists(/databases/$(database)/documents/superAdmins/$(superAdminId));
      }
      allow get, list: if true;
      allow create: if isSuperAdminDocumentExists(request.auth.uid);
      allow update: if isSuperAdminDocumentExists(request.auth.uid) && resource != null;
      allow delete: if isSuperAdminDocumentExists(request.auth.uid) && resource != null;
    }
  }
}
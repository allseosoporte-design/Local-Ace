/**
 * @fileoverview Firestore Security Rules for the application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for most data, with public read access to certain collections
 * and specific exceptions for public form submissions.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, linked to businesses.
 * - /businesses/{businessId}: Stores business information and acts as the root for most business-owned data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Stores reviews for a Google My Business profile.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Stores internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Stores automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - Strict user ownership: Most data is only accessible to the owning user/business.
 * - No user listing: Listing of users is explicitly denied.
 * - Public read for subscriptions: Subscription information is publicly readable.
 * - Public create for internalFeedback: Allows unauthenticated users to submit feedback through a public form, with validation.
 *
 * Denormalization for Authorization:
 * - Business ID is included in GoogleMyBusinessProfile documents to allow independent authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows management of user profile information, linking auth ID to business ID.
     * @path /users/{userId}
     * @allow (create) - Authenticated user can create their profile if the userId matches their auth UID.
     * @allow (get, list, update, delete) - Authenticated user can only access their own profile.
     * @deny (create) - If the userId does not match the authenticated user's UID.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows management of business information and subcollections.
     * @path /businesses/{businessId}
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      // Permisos del documento business principal
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      // 🔥 SUBCOLLECTION: internalFeedback (REGLA ESPECÍFICA)
      match /internalFeedback/{feedbackId} {
        // Validar que los datos requeridos estén presentes
        function hasRequiredFields() {
          return request.resource.data.keys().hasAll(['businessId', 'rating', 'createdAt']) &&
                 request.resource.data.businessId == businessId &&
                 request.resource.data.rating is int &&
                 request.resource.data.rating >= 1 &&
                 request.resource.data.rating <= 5;
        }

        // ✅ Permite crear solo si tiene campos válidos
        allow create: if hasRequiredFields();

        // ✅ Solo el dueño puede leer
        allow read: if isSignedIn() && request.auth.uid == businessId;

        // ❌ Nadie puede actualizar o eliminar
        allow update, delete: if false;
      }

      // Subcollection: landingPages (mantener existente)
      match /landingPages/{landingPageId} {
        allow get: if isSignedIn() && isOwner(businessId);
        allow list: if isSignedIn() && isOwner(businessId);
        allow create: if isSignedIn() && request.resource.data.businessId == businessId;
        allow update: if isSignedIn() && isExistingOwner(businessId);
        allow delete: if isExistingOwner(businessId);
      }
    }

    /**
     * @description Allows management of Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) - Owner can read and list their own profiles.
     * @allow (create, update, delete) - Owner can manage their own profiles.
     * @deny (create, update, delete) - If the businessId does not match the authenticated user's businessId.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // Check if the businessId in the resource data matches the authenticated user's businessId
      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get: if isSignedIn() && isOwner(resource.data.businessId);
      allow list: if isSignedIn() && isOwner(resource.data.businessId);
      allow create: if isSignedIn() && request.resource.data.businessId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.businessId) && request.resource.data.businessId == resource.data.businessId;
      allow delete: if isExistingOwner(resource.data.businessId);

      /**
       * @description Allows management of customer reviews for a Google My Business profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
       */
      match /reviews/{reviewId} {
        allow get: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow list: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }

      /**
       * @description Allows management of automated posts scheduled for a Google My Business profile.
       * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
       */
      match /automatedPosts/{automatedPostId} {
        allow get: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow list: if isSignedIn() && get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId == request.auth.uid;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Allows public read access to subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription information.
     * @deny (create, update, delete) - Only the application backend can create, update, or delete subscriptions.
     * @principle Provides public read access to subscription data.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
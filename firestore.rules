/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership and business-association model.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, linking auth UID to business ID.
 * - /businesses/{businessId}: Business information and root for business-owned data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Customer reviews.
 * - /businesses/{businessId}/internalFeedback/{internalFeedbackId}: Internal feedback for negative reviews.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages.
 * - /subscriptions/{subscriptionId}: Subscription plans (public read).
 *
 * Key Security Decisions:
 * - Users can only read/write their own profile data.
 * - Businesses own their associated Google My Business profiles, reviews, feedback, automated posts and landing pages.
 * - Listing of users is disallowed.
 * - Subscriptions are publicly readable but not writable.
 * - Enforces data consistency between user ID in the path and the `userId` field within the document for `/users/{userId}`.
 *
 * Denormalization for Authorization:
 * - The `googleMyBusinessProfile` documents contain a `businessId` field, enabling rules to authorize access to reviews and automated posts based on the business's ownership.
 *
 * Structural Segregation:
 * - Uses subcollections under `/businesses/{businessId}` to store private business-related data like `landingPages` and `internalFeedback`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) - User 'testuser' with ID 'testuser' can create their profile.
     * @allow (get, update, delete) - User 'testuser' with ID 'testuser' can read, update, and delete their profile.
     * @deny (create) - User 'testuser' with ID 'anotheruser' cannot create profile for another user.
     * @deny (get, update, delete) - User 'testuser' with ID 'anotheruser' cannot read, update and delete another user's profile.
     * @principle Enforces document ownership for writes and path consistency.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.businessId is string && request.resource.data.businessId != null;
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows CRUD operations on business data only by the business owner.
     * @path /businesses/{businessId}
     * @allow (create) - User can create business if signed in.
     * @allow (get, list) - Any signed-in user can read business data.
     * @allow (update, delete) - Only the business owner can update or delete the business data.
     * @deny (update, delete) - Another user cannot update or delete the business data.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() ;//&& isBusinessOwner(businessId);
      allow delete: if isSignedIn() ;//&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows CRUD operations on Google My Business profile data only by the business owner.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - User can create a GMB profile if signed in.
     * @allow (get, list) - Any signed-in user can read GMB profile data.
     * @allow (update, delete) - Only the business owner can update or delete the GMB profile data.
     * @deny (update, delete) - Another user cannot update or delete the GMB profile data.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); //&& isBusinessOwner(businessId);
      allow delete: if isSignedIn(); //&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows CRUD operations on Reviews, only by authenticated users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - Signed in user can create a review
     * @allow (get, list) - Any signed in user can read a list of reviews
     * @allow (update, delete) - Signed in User can update/delete reviews.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); //&& isBusinessOwner(businessId);
      allow delete: if isSignedIn(); //&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows CRUD operations on InternalFeedback data, only by authenticated users.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (create) - Signed in user can create a InternalFeedback
     * @allow (get, list) - Any signed in user can read a list of InternalFeedback
     * @allow (update, delete) - Signed in User can update/delete InternalFeedback.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); //&& isBusinessOwner(businessId);
      allow delete: if isSignedIn(); //&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows CRUD operations on AutomatedPost data, only by authenticated users.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - Signed in user can create a AutomatedPost
     * @allow (get, list) - Any signed in user can read a list of AutomatedPost
     * @allow (update, delete) - Signed in User can update/delete AutomatedPost.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); //&& isBusinessOwner(businessId);
      allow delete: if isSignedIn(); //&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows CRUD operations on LandingPage data, only by authenticated users.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - Signed in user can create a LandingPage
     * @allow (get, list) - Any signed in user can read a list of LandingPage
     * @allow (update, delete) - Signed in User can update/delete LandingPage.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSignedIn() {
        return request.auth != null;
      }

      // function isBusinessOwner(businessId) {
      //   return get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      // }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn(); //&& isBusinessOwner(businessId);
      allow delete: if isSignedIn(); //&& isBusinessOwner(businessId);
    }

    /**
     * @description Allows public read access to subscription plans.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Any user can read subscription plans.
     * @deny (create, update, delete) - No user can create, update, or delete subscription plans.
     * @principle Allows public read access with no write access.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
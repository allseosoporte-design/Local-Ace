/**
 * @fileOverview Firestore Security Rules for Local Leap platform.
 *
 * Core Philosophy:
 * This ruleset prioritizes security by default, enforcing strict ownership and role-based access control.
 * All write operations require authentication and authorization. Read operations are generally public
 * unless they expose private user data, in which case they are restricted to the owner. Data validation
 * is minimized to allow for rapid prototyping, focusing instead on authorization.
 *
 * Data Structure:
 * - /businesses/{businessId}: Business profiles.
 * - /businesses/{businessId}/reviews/{reviewId}: Customer reviews for each business.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}: Google Business Profile listings.
 * - /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}: Posts for Google Business Profiles.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for each business.
 * - /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}: Contact forms for landing pages.
 * - /subscriptionPlans/{subscriptionPlanId}: Details about the different subscription plans.
 * - /paymentSettings/{planSettingsId}: Payment settings for each subscription plan.
 * - /superAdmins/{superAdminId}: Super administrator profiles.
 * - /pendingPayments/{paymentId}: Pending payment requests.
 * - /subscriptions/{subscriptionId}: Active subscriptions.
 * - /activityLogs/{logId}: Logs of admin activity.
 *
 * Key Security Decisions:
 * - SuperAdmin role implicitly grants full access to all data.
 * - User listing is generally disallowed for privacy.
 * - Ambiguous relationships default to owner-only access for writes.
 *
 * Denormalization for Authorization:
 *  N/A: No specific denormalization is required based on the current schema.
 *       If authorization logic becomes more complex, consider adding fields like
 *       `businessId` to subcollections (e.g., `reviews`) to avoid costly `get()` calls in rules.
 *
 * Structural Segregation:
 *  N/A: No explicit segregation of public vs. private data using separate collections.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     * @param {string} userId - The user ID to compare against the request's auth UID.
     * @returns {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the resource (for update/delete).
     * @param {string} userId - The user ID to compare against the resource's owner ID.
     * @returns {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for business profiles.
     * @path /businesses/{businessId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create. The 'id' field must match the businessId.
     * @allow (update, delete): Only the business owner (creator) can update or delete.
     * @deny (create): If the 'id' field does not match the businessId.
     * @principle Allows public reads, but restricts write access to the owner. Validates resource ID on creation.
     */
    match /businesses/{businessId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.id == businessId;
      allow update, delete: if isExistingOwner(resource.data.id);
    }

    /**
     * @description Rules for reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create.
     * @allow (update, delete): Only the business owner can update or delete.
     * @deny (create): If the request is not authenticated.
     * @principle Reviews are publicly readable, but write access is restricted to the business owner.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(resource.data.businessId);
    }

    /**
     * @description Rules for Google Business Profiles associated with a business.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create.
     * @allow (update, delete): Only the business owner can update or delete.
     * @deny (create): If the request is not authenticated.
     * @principle Google Business Profiles are publicly readable, but write access is restricted to the business owner.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for posts associated with a Google Business Profile.
     * @path /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create.
     * @allow (update, delete): Only the business owner can update or delete.
     * @deny (create): If the request is not authenticated.
     * @principle Posts are publicly readable, but write access is restricted to the business owner.
     */
    match /businesses/{businessId}/googleBusinessProfiles/{googleBusinessProfileId}/posts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create.
     * @allow (update, delete): Only the business owner can update or delete.
     * @deny (create): If the request is not authenticated.
     * @principle Landing pages are publicly readable, but write access is restricted to the business owner.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for contact forms associated with a landing page.
     * @path /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId}
     * @allow (get, list): Public read access.
     * @allow (create): Only authenticated users can create.
     * @allow (update, delete): Only the business owner can update or delete.
     * @deny (create): If the request is not authenticated.
     * @principle Contact forms are publicly readable, but write access is restricted to the business owner.
     */
    match /businesses/{businessId}/landingPages/{landingPageId}/contactForms/{contactFormId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isExistingOwner(businessId);
    }

    /**
     * @description Rules for subscription plans.
     * @path /subscriptionPlans/{subscriptionPlanId}
     * @allow get, list: if true;
     * @allow create, update, delete: if false; // TODO: Add admin role check
     * @principle Subscription plans are publicly readable, but only admins can create, update, or delete them.
     */
    match /subscriptionPlans/{subscriptionPlanId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add admin role check
      allow update: if false; // TODO: Add admin role check
      allow delete: if false; // TODO: Add admin role check
    }

     /**
      * @description Rules for payment settings.
      * @path /paymentSettings/{planSettingsId}
      * @allow get, list: if true;
      * @allow create, update, delete: if false; // TODO: Add admin role check
      * @principle Payment settings are publicly readable, but only admins can create, update, or delete them.
      */
    match /paymentSettings/{planSettingsId} {
      allow get, list: if true;
      allow create: if false; // TODO: Add admin role check
      allow update: if false; // TODO: Add admin role check
      allow delete: if false; // TODO: Add admin role check
    }

    /**
     * @description Rules for super administrator profiles.
     * @path /superAdmins/{superAdminId}
     * @allow get: if isOwner(superAdminId);
     * @allow list: if false;
     * @allow create: if isOwner(superAdminId);
     * @allow update: if isExistingOwner(superAdminId);
     * @allow delete: if false; // SuperAdmins cannot delete themselves or others
     * @principle Only super admins can read their own profile and create their profiles (self-registration), but cannot list other admins or delete themselves.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isExistingOwner(superAdminId);
      allow delete: if false; // SuperAdmins cannot delete themselves or others
    }

    /**
     * @description Rules for pending payment requests.
     * @path /pendingPayments/{paymentId}
     * @allow get, list: if false; // TODO: Add admin role check for listing and getting specific payments.
     * @allow create: if isSignedIn(); // Any authenticated user can request a pending payment.
     * @allow update: if false; // TODO: Only admins can update the status of pending payments.
     * @allow delete: if false; // No one can delete a pending payment request.
     * @principle Only admins can view/modify pending payments. Users can create payment requests.
     */
    match /pendingPayments/{paymentId} {
        allow get, list: if false; // TODO: Add admin role check for listing and getting specific payments.
        allow create: if isSignedIn(); // Any authenticated user can request a pending payment.
        allow update: if false; // TODO: Only admins can update the status of pending payments.
        allow delete: if false; // No one can delete a pending payment request.
    }

    /**
     * @description Rules for active subscriptions.
     * @path /subscriptions/{subscriptionId}
     * @allow get, list: if false; // TODO: Add admin/business owner role check.
     * @allow create: if false; // TODO: Only admins can create subscriptions.
     * @allow update: if false; // TODO: Only admins can update subscriptions.
     * @allow delete: if false; // TODO: Only admins can delete subscriptions.
     * @principle Subscriptions are managed by admins. Businesses can view their own subscriptions.
     */
    match /subscriptions/{subscriptionId} {
        allow get, list: if false; // TODO: Add admin/business owner role check.
        allow create: if false; // TODO: Only admins can create subscriptions.
        allow update: if false; // TODO: Only admins can update subscriptions.
        allow delete: if false; // TODO: Only admins can delete subscriptions.
    }

    /**
     * @description Rules for activity logs.
     * @path /activityLogs/{logId}
     * @allow get, list: if false; // TODO: Only admins can view activity logs.
     * @allow create: if false; // Activity logs are created by the system.
     * @allow update: if false;
     * @allow delete: if false;
     * @principle Activity logs are only accessible to admins and are system-generated.
     */
    match /activityLogs/{logId} {
        allow get, list: if false; // TODO: Only admins can view activity logs.
        allow create: if false; // Activity logs are created by the system.
        allow update: if false;
        allow delete: if false;
    }
  }
}
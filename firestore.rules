/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset enforces a strict ownership model for most data,
 * with users only able to access data related to their business. Public read access
 * is granted for specific collections like businesses/{businessId}/landingPages.
 *
 * @data_structure
 * - /users/{userId}: User profile information, linked to a business.
 * - /businesses/{businessId}: Business information, the root for most data.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Google My Business profiles.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Reviews for a GMB profile.
 * - /internalFeedback/{internalFeedbackId}: Internal feedback from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Automated posts for a GMB profile.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Landing pages for a business.
 * - /subscriptions/{subscriptionId}: Subscription plan information.
 *
 * @key_security_decisions
 * - Users can only read/write their own user profile.
 * - Businesses can only manage data under their own business ID.
 * - Listing of users is disallowed.
 * - Public read access is granted for /businesses/{businessId}/landingPages.
 * - No public write access is allowed.
 *
 * @denormalization_for_authorization
 * - The GoogleMyBusinessProfile includes a businessId to allow independent authorization.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource, verifying existence.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
    
    /**
     * @description Allows a user to manage their own profile.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' creates a profile with id: 'user123'.
     * @deny (create) User with UID 'user123' attempts to create a profile with id: 'user456'.
     * @principle Enforces user-ownership for profile data.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Listing users is not permitted.
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows a business to manage its own information.
     * @path /businesses/{businessId}
     * @allow (create) User associated with business 'business123' creates business profile.
     * @deny (update) User not associated with 'business123' attempts to modify it.
     * @principle Enforces business-ownership for business data.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn();
      allow list: if false; // Listing businesses is not permitted.
      allow create: if isSignedIn();
      allow update: if resource.data.id == businessId && isSignedIn();
      allow delete: if resource.data.id == businessId && isSignedIn();
    }

    /**
     * @description Allows management of Google My Business profiles, ensuring business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User associated with business creates a GMB profile for that business.
     * @deny (update) User attempts to modify a GMB profile not associated with their business.
     * @principle Enforces business-ownership for GMB profile data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      allow get: if isSignedIn();
      allow list: if false; // Listing GMB profiles is not permitted.
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows management of reviews for a Google My Business profile by the business.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) Business creates a review under its GMB profile.
     * @deny (delete) User attempts to delete a review under a GMB profile they don't own.
     * @principle Enforces business-ownership for review data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows management of internal feedback.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (create) Any signed-in user can create internal feedback.
     * @deny (update) Only the creator can update internal feedback.
     * @principle Allows internal feedback creation.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get: if isSignedIn();
      allow list: if false; // Listing internal feedback is not permitted.
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Allows management of automated posts for a Google My Business profile by the business.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) Business creates an automated post under its GMB profile.
     * @deny (delete) User attempts to delete an automated post under a GMB profile they don't own.
     * @principle Enforces business-ownership for automated post data.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
     /**
      * @description Allows public read access to landing pages with owner-only writes.
      * @path /businesses/{businessId}/landingPages/{landingPageId}
      * @allow (get, list) Any user can view landing pages.
      * @allow (create) User creates a landing page with businessId matching the path.
      * @allow (update, delete) Only the owner of the landing page can modify or delete it.
      * @deny (create) User attempts to create a landing page with mismatched businessId.
      * @principle Allows public read access with owner-only writes for landing pages.
      */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.businessId == businessId;
      allow update: if isSignedIn() && resource.data.businessId == businessId;
      allow delete: if isSignedIn() && resource.data.businessId == businessId;
    }

    /**
     * @description Allows access to subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get) Any signed-in user can read subscription information.
     * @deny (create, update, delete) No one can create, update, or delete subscriptions through client-side rules.
     * @principle Restricts subscription management to backend services.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if isSignedIn();
      allow list: if false; // Listing subscriptions is not permitted.
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
    
     /**
      * @description Allows public read access to landing pages with owner-only writes.
      * @path /businesses/{businessId}/landingPages/{landingPageId}/hero
      * @allow (get, list) Any user can view landing pages.
      * @allow (create) User creates a landing page with businessId matching the path.
      * @allow (update, delete) Only the owner of the landing page can modify or delete it.
      * @deny (create) User attempts to create a landing page with mismatched businessId.
      * @principle Allows public read access with owner-only writes for landing pages.
      */
       match /businesses/{businessId}/landingPages/{landingPageId}/{document=**} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.resource.data.businessId == businessId;
        allow update: if isSignedIn() && resource.data.businessId == businessId;
        allow delete: if isSignedIn() && resource.data.businessId == businessId;
      }
  }
}
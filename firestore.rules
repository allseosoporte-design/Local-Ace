/**
 * @file Firebase Security Rules for Local Leap Application
 *
 * @core_philosophy This ruleset implements a multi-tenant security model with super-administrator control.
 * Super admins have broad access, while businesses primarily have access to their own data.
 * Path-based ownership and data denormalization are heavily used to ensure efficient and secure access control.
 *
 * @data_structure
 * - /superAdmins/{superAdminId}: Stores super admin profiles.
 * - /businesses/{businessId}: Stores business profiles, each with a `superAdminId` field indicating ownership.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for a business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for a business.
 * - /subscriptionPlans/{planId}: Stores subscription plans available on the platform.
 *
 * @key_security_decisions
 * - Super admins have full CRUD access to businesses, reviews, and landing pages.
 * - Businesses are managed by SuperAdmins, but business users themselves are not represented directly in the data model.
 * - Subscription plans are publicly readable, but only SuperAdmins can create, update, or delete them.
 * - Data validation is relaxed in this prototype to accelerate development.  However, ownership checks are strictly enforced.
 *
 * @denormalization_for_authorization
 * - Business documents include a `superAdminId` field, denormalizing the ownership relationship. This avoids the need for security rules to perform `get()` operations on the `/superAdmins` collection.
 *
 * @structural_segregation
 * - No explicit structural segregation is used.  Access control is managed via path-based rules and ownership checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to super admin profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (create) - A user can create their own superAdmin profile if the ID matches their auth UID.
     * @allow (get, list, update, delete) - Only the super admin themselves can access their profile.
     * @deny (create) - A user cannot create a superAdmin profile with an ID that does not match their auth UID.
     * @principle Enforces strict user ownership for super admin profiles.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(superAdminId) {
        return request.auth != null && request.auth.uid == superAdminId;
      }
      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if request.auth.uid == superAdminId;
      allow update: if isOwner(superAdminId);
      allow delete: if isOwner(superAdminId);
    }

    /**
     * @description Controls access to business profiles.
     * @path /businesses/{businessId}
     * @allow (create) - A super admin can create a business profile.
     * @allow (get, list, update, delete) - Only the super admin who owns the business can access it.
     * @deny (create) - A non-super admin cannot create a business profile.
     * @deny (update, delete) - A super admin cannot modify/delete a business they don't own.
     * @principle Enforces super admin ownership for business profiles.
     */
    match /businesses/{businessId} {
      function isSuperAdmin() {
        return request.auth != null && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }
      function isBusinessOwner(businessId) {
        return request.auth != null && resource.data.superAdminId == request.auth.uid && isSuperAdmin();
      }
       function isCreatingBusiness() {
        return request.auth != null && request.resource.data.superAdminId == request.auth.uid && isSuperAdmin();
      }

      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isCreatingBusiness();
      allow update: if isBusinessOwner(businessId);
      allow delete: if isBusinessOwner(businessId);
    }

    /**
     * @description Controls access to reviews associated with a business.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) - Super admins can read all reviews.
     * @allow (create) - Super admins associated to a business can create a review for that business.
     * @allow (update, delete) - Only the super admin who owns the business can modify/delete its reviews.
     * @deny (create, update, delete) - Regular users cannot create, modify, or delete reviews.
     * @principle Enforces super admin ownership for review management.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      function isSuperAdmin() {
        return request.auth != null && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }
       function isValidBusiness() {
            return exists(/databases/$(database)/documents/businesses/$(businessId));
      }
       function isBusinessOwner(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
      allow update: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
      allow delete: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
    }

    /**
     * @description Controls access to landing pages associated with a business.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) - Super admins can read all landing pages.
     * @allow (create) - Super admins associated to a business can create a landing page for that business.
     * @allow (update, delete) - Only the super admin who owns the business can modify/delete its landing pages.
     * @deny (create, update, delete) - Regular users cannot create, modify, or delete landing pages.
     * @principle Enforces super admin ownership for landing page management.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isSuperAdmin() {
        return request.auth != null && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }
       function isValidBusiness() {
            return exists(/databases/$(database)/documents/businesses/$(businessId));
      }
       function isBusinessOwner(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
      }
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
      allow update: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
      allow delete: if isSuperAdmin() && isValidBusiness() && isBusinessOwner(businessId);
    }

    /**
     * @description Controls access to subscription plans.
     * @path /subscriptionPlans/{planId}
     * @allow (get, list) - Everyone can read the subscription plans.
     * @allow (create, update, delete) - Only super admins can manage subscription plans.
     * @deny (create, update, delete) - Regular users cannot create, modify, or delete subscription plans.
     * @principle Restricts subscription plan management to super admins.
     */
    match /subscriptionPlans/{planId} {
      function isSuperAdmin() {
        return request.auth != null && exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
      }
      allow get: if true;
      allow list: if true;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
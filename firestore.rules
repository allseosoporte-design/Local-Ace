/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a role-based access control model with super admins and business-level ownership.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles.
 * - /businesses/{businessId}: Stores business profiles, with a `superAdminId` field indicating ownership.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for each business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for each business.
 * - /subscriptionPlans/{planId}: Stores subscription plans available on the platform.
 *
 * Key Security Decisions:
 * - Super admins (DBAC) have full control over businesses, reviews, and landing pages.
 * - Regular users (business) do not have write access to subscription plans.
 * - Data access is restricted based on ownership and roles.
 * - No user listing is allowed for superAdmins.
 *
 * Denormalization for Authorization:
 * - The `businesses` collection stores the `superAdminId` directly on each document.
 *   This allows business-level rules to validate ownership without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages super admin accounts. Only allows authenticated users to read their own data.
     * @path /superAdmins/{superAdminId}
     * @allow (get) User with UID 'superAdminId' can read their own profile.
     * @deny (get) User with UID 'anotherUserId' cannot read the profile of 'superAdminId'.
     * @allow (create) User with UID 'superAdminId' can create their own profile.
     * @deny (create) User with UID 'anotherUserId' cannot create a profile for 'superAdminId'.
     * @allow (update) User with UID 'superAdminId' can update their own profile.
     * @deny (update) User with UID 'anotherUserId' cannot update the profile of 'superAdminId'.
     * @allow (delete) User with UID 'superAdminId' can delete their own profile.
     * @deny (delete) User with UID 'anotherUserId' cannot delete the profile of 'superAdminId'.
     * @principle Enforces document ownership for all operations.
     */
    match /superAdmins/{superAdminId} {
      allow get: if isSignedIn() && isOwner(superAdminId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(superAdminId);
      allow update: if isSignedIn() && isOwner(superAdminId);
      allow delete: if isSignedIn() && isOwner(superAdminId);
    }

    /**
     * @description Manages business accounts. Allows super admins to manage businesses they own.
     * @path /businesses/{businessId}
     * @allow (get) Super admin with UID 'superAdminId' can read a business profile they own.
     * @deny (get) User with UID 'anotherUserId' cannot read a business profile owned by 'superAdminId'.
     * @allow (create) Super admin with UID 'superAdminId' can create a business profile and set the correct superAdminId.
     * @deny (create) User with UID 'anotherUserId' cannot create a business profile owned by 'superAdminId'.
     * @allow (update) Super admin with UID 'superAdminId' can update a business profile they own.
     * @deny (update) User with UID 'anotherUserId' cannot update a business profile owned by 'superAdminId'.
     * @allow (delete) Super admin with UID 'superAdminId' can delete a business profile they own.
     * @deny (delete) User with UID 'anotherUserId' cannot delete a business profile owned by 'superAdminId'.
     * @principle Enforces document ownership for writes, read access controlled by ownership.
     */
    match /businesses/{businessId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if false;
      allow create: if isSignedIn() && request.resource.data.superAdminId == request.auth.uid;
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages reviews for a specific business. Allows super admins to manage reviews for businesses they own.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get) Super admin with UID 'superAdminId' can read a review for a business they own.
     * @deny (get) User with UID 'anotherUserId' cannot read a review for a business owned by 'superAdminId'.
     * @allow (create) Super admin with UID 'superAdminId' can create a review for a business they own.
     * @deny (create) User with UID 'anotherUserId' cannot create a review for a business owned by 'superAdminId'.
     * @allow (update) Super admin with UID 'superAdminId' can update a review for a business they own.
     * @deny (update) User with UID 'anotherUserId' cannot update a review for a business owned by 'superAdminId'.
     * @allow (delete) Super admin with UID 'superAdminId' can delete a review for a business they own.
     * @deny (delete) User with UID 'anotherUserId' cannot delete a review for a business owned by 'superAdminId'.
     * @principle Enforces document ownership for writes, read access controlled by ownership.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages landing pages for a specific business. Allows super admins to manage landing pages for businesses they own.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get) Super admin with UID 'superAdminId' can read a landing page for a business they own.
     * @deny (get) User with UID 'anotherUserId' cannot read a landing page for a business owned by 'superAdminId'.
     * @allow (create) Super admin with UID 'superAdminId' can create a landing page for a business they own.
     * @deny (create) User with UID 'anotherUserId' cannot create a landing page for a business owned by 'superAdminId'.
     * @allow (update) Super admin with UID 'superAdminId' can update a landing page for a business they own.
     * @deny (update) User with UID 'anotherUserId' cannot update a landing page for a business owned by 'superAdminId'.
     * @allow (delete) Super admin with UID 'superAdminId' can delete a landing page for a business they own.
     * @deny (delete) User with UID 'anotherUserId' cannot delete a landing page for a business owned by 'superAdminId'.
     * @principle Enforces document ownership for writes, read access controlled by ownership.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      allow get: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow update: if isSignedIn() && isSuperAdminForBusiness(businessId);
      allow delete: if isSignedIn() && isSuperAdminForBusiness(businessId);
    }

    /**
     * @description Manages subscription plans. Allows any signed-in user to read all plans, but only allows super admins to modify them.
     * @path /subscriptionPlans/{planId}
     * @allow (get) Any signed-in user can read a subscription plan.
     * @allow (list) Any signed-in user can list all subscription plans.
     * @deny (create) Regular users cannot create subscription plans.
     * @allow (create) Super admins can create subscription plans.
     * @deny (update) Regular users cannot update subscription plans.
     * @allow (update) Super admins can update subscription plans.
     * @deny (delete) Regular users cannot delete subscription plans.
     * @allow (delete) Super admins can delete subscription plans.
     * @principle Public read access with restricted write access for super admins.
     */
    match /subscriptionPlans/{planId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isSuperAdmin();
      allow update: if isSignedIn() && isSuperAdmin();
      allow delete: if isSignedIn() && isSuperAdmin();
    }
  }

  // Helper functions

  // Checks if the user is signed in.
  function isSignedIn() {
    return request.auth != null;
  }

  // Checks if the user's ID matches the requested ID.
  function isOwner(userId) {
    return request.auth.uid == userId;
  }

  // Checks if the user's ID matches the requested ID and resource exists.
  function isExistingOwner(userId) {
    return isOwner(userId) && resource.data != null;
  }

  // Checks if the user is a super admin (DBAC).
  function isSuperAdmin() {
    return exists(/databases/$(database)/documents/superAdmins/$(request.auth.uid));
  }

  // Checks if the user is a super admin for a given business, based on the business's superAdminId.
  function isSuperAdminForBusiness(businessId) {
    return isSignedIn() && get(/databases/$(database)/documents/businesses/$(businessId)).data.superAdminId == request.auth.uid;
  }

   // Checks if the user is a super admin for a given business and resource exists, based on the business's superAdminId.
  function isExistingSuperAdminForBusiness(businessId) {
    return isSuperAdminForBusiness(businessId) && resource.data != null;
  }
}
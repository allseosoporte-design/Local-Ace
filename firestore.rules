rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) User with UID 'user_abc' can create their profile if userId == 'user_abc'.
     * @deny (create) User with UID 'user_abc' cannot create a profile with userId == 'other_user'.
     * @allow (get, list, update, delete) User with UID 'user_abc' can read/write their profile if userId == 'user_abc'.
     * @deny (get, list, update, delete) User with UID 'user_abc' cannot read/write the profile of userId == 'other_user'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth.uid == userId;
      }
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false; // User listing is disabled for privacy.
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }

    /**
     * @description Allows businesses to manage their own information.
     * @path /businesses/{businessId}
     * @allow (create) User can create a business if they provide valid data.
     * @deny (create) User cannot create a business with invalid data.
     * @allow (get, list, update, delete) User can read/write a business if they are the owner.
     * @deny (get, list, update, delete) User cannot read/write a business if they are not the owner.
     * @principle Enforces business ownership for writes.
     */
    match /businesses/{businessId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(businessId) {
          return resource.data.businessId == businessId;
      }

      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if false; // Business listing is disabled.
      allow create: if isSignedIn(); // Anyone can create a business, but only an owner can manage it.
      allow update: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
    }

    /**
     * @description Allows businesses to manage their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) User can create a Google My Business profile if they are the owner of the business.
     * @deny (create) User cannot create a Google My Business profile if they are not the owner of the business.
     * @allow (get, list, update, delete) User can read/write a Google My Business profile if they are the owner of the associated business.
     * @deny (get, list, update, delete) User cannot read/write a Google My Business profile if they are not the owner of the associated business.
     * @principle Enforces business ownership for Google My Business profiles.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }
      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(googleMyBusinessProfileId) {
        return resource.data.businessId == getBusinessIdFromProfile(googleMyBusinessProfileId);
      }

      allow get: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(resource.data.businessId);
      allow list: if false; // Google My Business profile listing is disabled.
      allow create: if isSignedIn() && request.resource.data.businessId == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId;
      allow update: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(resource.data.businessId);
      allow delete: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(resource.data.businessId);
    }

    /**
     * @description Allows businesses to manage customer reviews for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) User can create a review if they are the owner of the Google My Business profile.
     * @deny (create) User cannot create a review if they are not the owner of the Google My Business profile.
     * @allow (get, list, update, delete) User can read/write a review if they are the owner of the associated Google My Business profile.
     * @deny (create, update, delete) User cannot read/write a review if they are not the owner of the associated Google My Business profile.
     * @principle Enforces business ownership for reviews.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }

      function isExistingOwner(googleMyBusinessProfileId) {
        return resource != null;
      }

      allow get: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow create: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
    }

    /**
     * @description Allows businesses to manage internal feedback collected from customers.
     * @path /businesses/{businessId}/internalFeedback/{internalFeedbackId}
     * @allow (create) User can create internal feedback if they are the owner of the business.
     * @deny (create) User cannot create internal feedback if they are not the owner of the business.
     * @allow (get, list, update, delete) User can read/write internal feedback if they are the owner of the associated business.
     * @deny (create, update, delete) User cannot read/write internal feedback if they are not the owner of the associated business.
     * @principle Enforces business ownership for internal feedback.
     */
    match /businesses/{businessId}/internalFeedback/{internalFeedbackId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(businessId) {
        return resource != null;
      }

      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
    }

    /**
     * @description Allows businesses to manage automated posts for their Google My Business profiles.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) User can create an automated post if they are the owner of the Google My Business profile.
     * @deny (create) User cannot create an automated post if they are not the owner of the Google My Business profile.
     * @allow (get, list, update, delete) User can read/write an automated post if they are the owner of the associated Google My Business profile.
     * @deny (create, update, delete) User cannot read/write an automated post if they are not the owner of the associated Google My Business profile.
     * @principle Enforces business ownership for automated posts.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function getBusinessIdFromProfile(googleMyBusinessProfileId) {
        return get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId;
      }

      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(googleMyBusinessProfileId) {
        return resource != null;
      }

      allow get: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow list: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow create: if isSignedIn() && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow update: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
      allow delete: if isSignedIn() && isExistingOwner(googleMyBusinessProfileId) && isOwner(getBusinessIdFromProfile(googleMyBusinessProfileId));
    }

    /**
     * @description Allows businesses to manage landing pages.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) User can create a landing page if they are the owner of the business.
     * @deny (create) User cannot create a landing page if they are not the owner of the business.
     * @allow (get, list, update, delete) User can read/write a landing page if they are the owner of the associated business.
     * @deny (create, update, delete) User cannot read/write a landing page if they are not the owner of the associated business.
     * @principle Enforces business ownership for landing pages.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isOwner(businessId) {
        return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
      }

      function isSignedIn() {
        return request.auth != null;
      }
      function isExistingOwner(businessId) {
        return resource != null;
      }

      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId) && isOwner(businessId);
    }

    /**
     * @description Allows anyone to read subscription plan information, but restricts creation, updates, and deletion.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) Anyone can read subscription plans.
     * @deny (create, update, delete) Only admins can manage subscription plans (currently disabled).
     * @principle Public read access with restricted writes.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // Subscription creation is disabled.
      allow update: if false; // Subscription updates are disabled.
      allow delete: if false; // Subscription deletion is disabled.
    }
  }
}
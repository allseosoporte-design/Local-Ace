/**
 * @fileOverview Firestore Security Rules for Local Leap application.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model, primarily managed through the existence
 * of `superAdmin` documents. Businesses, reviews, and landing pages are secured based on the
 * superAdmin that manages the business.  This is achieved through path-based rules.
 *
 * Data Structure:
 * - /superAdmins/{superAdminId}: Stores super admin profiles. Existence implies admin privileges.
 * - /businesses/{businessId}: Stores business data, each linked to a superAdmin via a denormalized `superAdminId`.
 * - /businesses/{businessId}/reviews/{reviewId}: Stores reviews for each business.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Stores landing pages for each business.
 *
 * Key Security Decisions:
 * - Super admins can manage businesses and all associated subcollections (reviews, landing pages).
 * - Listing of businesses is restricted to super admins.
 * - Data consistency between paths and document data is enforced on create and update.
 *
 * Denormalization for Authorization:
 * - The `Business` entity contains the `superAdminId` which is used to authorize access to the business
 *   and its subcollections. This avoids costly `get()` calls to the `/superAdmins` collection.
 *
 * Structural Segregation:
 * - N/A. All data is secured behind authentication and role checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows super admins to manage their profiles.
     * @path /superAdmins/{superAdminId}
     * @allow (get, create, update, delete, list) if the user is the super admin.
     * @deny (get, create, update, delete, list) if the user is not the super admin.
     * @principle Enforces document ownership for all operations on superAdmin documents.
     */
    match /superAdmins/{superAdminId} {
      function isOwner(superAdminId) {
        return request.auth.uid == superAdminId;
      }
      function isExistingOwner(superAdminId) {
        return isOwner(superAdminId) && resource != null;
      }
      allow get: if isOwner(superAdminId);
      allow list: if false;
      allow create: if isOwner(superAdminId);
      allow update: if isExistingOwner(superAdminId);
      allow delete: if isExistingOwner(superAdminId);
    }

    /**
     * @description Allows super admins to manage businesses.
     * @path /businesses/{businessId}
     * @allow (get, list) if the user is a super admin.
     * @allow (create) if the user is a super admin and the business.superAdminId matches the user's UID.
     * @allow (update, delete) if the user is a super admin and owns the business.
     * @deny (create, update, delete) if the user is not a super admin or does not own the business.
     * @principle Enforces role-based access control for business management.
     */
    match /businesses/{businessId} {
      function isSuperAdmin() {
        return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.id == request.auth.uid;
      }
      function isOwner(superAdminId) {
          return isSuperAdmin() && superAdminId == request.auth.uid;
      }
      function isExistingOwner(superAdminId) {
        return isOwner(superAdminId) && resource != null;
      }
      allow get: if isSuperAdmin();
      allow list: if isSuperAdmin();
      allow create: if isSuperAdmin() && request.resource.data.id == businessId;
      allow update: if isExistingOwner(resource.data.id);
      allow delete: if isExistingOwner(resource.data.id);
    }

    /**
     * @description Allows super admins to manage reviews for their businesses.
     * @path /businesses/{businessId}/reviews/{reviewId}
     * @allow (get, list) if the user is a super admin associated with the business.
     * @allow (create) if the user is a super admin associated with the business.
     * @allow (update, delete) if the user is a super admin associated with the business and the review exists.
     * @deny (create, update, delete) if the user is not a super admin or not associated with the business.
     * @principle Enforces path-based access control for review management.
     */
    match /businesses/{businessId}/reviews/{reviewId} {
       function isSuperAdmin() {
        return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.id == request.auth.uid;
      }

      function getBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data;
      }

      function isOwner(businessId) {
        return isSuperAdmin() && getBusiness(businessId).id == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if isSuperAdmin() && isOwner(businessId);
      allow list: if isSuperAdmin() && isOwner(businessId);
      allow create: if isSuperAdmin() && isOwner(businessId);
      allow update: if isSuperAdmin() && isExistingOwner(businessId);
      allow delete: if isSuperAdmin() && isExistingOwner(businessId);
    }

    /**
     * @description Allows super admins to manage landing pages for their businesses.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (get, list) if the user is a super admin associated with the business.
     * @allow (create) if the user is a super admin associated with the business.
     * @allow (update, delete) if the user is a super admin associated with the business and the landing page exists.
     * @deny (create, update, delete) if the user is not a super admin or not associated with the business.
     * @principle Enforces path-based access control for landing page management.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
       function isSuperAdmin() {
        return get(/databases/$(database)/documents/superAdmins/$(request.auth.uid)).data.id == request.auth.uid;
      }

      function getBusiness(businessId) {
        return get(/databases/$(database)/documents/businesses/$(businessId)).data;
      }

      function isOwner(businessId) {
        return isSuperAdmin() && getBusiness(businessId).id == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if isSuperAdmin() && isOwner(businessId);
      allow list: if isSuperAdmin() && isOwner(businessId);
      allow create: if isSuperAdmin() && isOwner(businessId);
      allow update: if isSuperAdmin() && isExistingOwner(businessId);
      allow delete: if isSuperAdmin() && isExistingOwner(businessId);
    }
  }
}
/**
 * @fileoverview Firestore Security Rules for the Local Leap SaaS platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict ownership model for businesses and their associated data.
 * Businesses can only manage their own Google My Business profiles, landing pages, and reviews.
 * Internal feedback is publicly writable to facilitate collection from users.
 *
 * Data Structure:
 * - /businesses/{businessId}: Root collection for business data. All business-related data is nested under this path.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}: Stores Google My Business profile information. Includes the businessId to ensure authorization independence for access control.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}: Subcollection for customer reviews.
 * - /internalFeedback/{internalFeedbackId}: Stores internal feedback collected from customers.
 * - /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}: Subcollection for automated posts.
 * - /businesses/{businessId}/landingPages/{landingPageId}: Subcollection for landing pages.
 * - /subscriptions/{subscriptionId}: Stores subscription plan information.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - All writes are protected by authorization checks.
 * - Data validation is limited to fields that are critical for authorization.
 *
 * Denormalization for Authorization:
 * - The `businessId` is included in the `GoogleMyBusinessProfile` document to enable direct authorization checks without requiring a `get()` call to the `Business` document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to the /businesses/{businessId} collection.
     * @path /businesses/{businessId}
     * @allow (create) - A user can create a business if the businessId matches their auth UID.
     * @allow (get, list, update, delete) - Only the business owner can read, update, or delete their business information.
     * @deny (create) - A user cannot create a business with an ID that doesn't match their auth UID.
     * @deny (update, delete) - A user cannot update or delete a business they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId} {
      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if false;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Controls access to the /googleMyBusinessProfiles/{googleMyBusinessProfileId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (create) - A business owner can create a Google My Business profile if the businessId matches their auth UID.
     * @allow (get, list, update, delete) - Only the business owner can read, update, or delete their Google My Business profile.
     * @deny (create) - A user cannot create a Google My Business profile for a business they don't own.
     * @deny (update, delete) - A user cannot update or delete a Google My Business profile they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isBusinessOwner(businessId) {
          return request.auth != null && request.auth.uid == businessId;
      }
      function isExistingBusinessOwner(businessId) {
        return isBusinessOwner(businessId) && resource != null;
      }
      allow get, list: if false;
      allow create: if isBusinessOwner(request.resource.data.businessId);
      allow update: if isExistingBusinessOwner(resource.data.businessId);
      allow delete: if isExistingBusinessOwner(resource.data.businessId);
    }

    /**
     * @description Controls access to the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     * @allow (create) - A business owner can create a review under their Google My Business profile.
     * @allow (get, list, update, delete) - Only the business owner can read, update, or delete reviews under their Google My Business profile.
     * @deny (create) - A user cannot create a review for a Google My Business profile they don't own.
     * @deny (update, delete) - A user cannot update or delete a review they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
        function isBusinessOwner(businessId) {
          return request.auth != null && request.auth.uid == businessId;
        }
        function isExistingBusinessOwner(businessId) {
          return isBusinessOwner(businessId) && resource != null;
        }

        allow get, list: if false;
        allow create: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        allow update: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
        allow delete: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description Controls access to the /internalFeedback/{internalFeedbackId} collection.
     * @path /internalFeedback/{internalFeedbackId}
     * @allow (get, list) - Anyone can read internal feedback.
     * @allow (create) - Anyone can create internal feedback.
     * @deny (update, delete) - No one can update or delete internal feedback.
     */
    match /internalFeedback/{internalFeedbackId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if false;
    }

    /**
     * @description Controls access to the /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} collection.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     * @allow (create) - A business owner can create an automated post under their Google My Business profile.
     * @allow (get, list, update, delete) - Only the business owner can read, update, or delete automated posts under their Google My Business profile.
     * @deny (create) - A user cannot create an automated post for a Google My Business profile they don't own.
     * @deny (update, delete) - A user cannot update or delete an automated post they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isBusinessOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }
      function isExistingBusinessOwner(businessId) {
        return isBusinessOwner(businessId) && resource != null;
      }

      allow get, list: if false;
      allow create: if isBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      allow update: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
      allow delete: if isExistingBusinessOwner(get(/databases/$(database)/documents/googleMyBusinessProfiles/$(googleMyBusinessProfileId)).data.businessId);
    }

    /**
     * @description Controls access to the /businesses/{businessId}/landingPages/{landingPageId} collection.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     * @allow (create) - A business owner can create a landing page under their business.
     * @allow (get, list, update, delete) - Only the business owner can read, update, or delete landing pages under their business.
     * @deny (create) - A user cannot create a landing page for a business they don't own.
     * @deny (update, delete) - A user cannot update or delete a landing page they don't own.
     * @principle Enforces document ownership for writes.
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
      function isOwner(businessId) {
        return request.auth != null && request.auth.uid == businessId;
      }
      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      allow get, list: if false;
      allow create: if isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);
    }

    /**
     * @description Controls access to the /subscriptions/{subscriptionId} collection.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) - Anyone can read subscription information.
     * @deny (create, update, delete) - No one can create, update, or delete subscriptions.
     */
    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }
  }
}
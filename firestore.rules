/**
 * @description This ruleset enforces a strict user-ownership model for user profiles and business data.
 * All data is nested under /users/{userId} or /businesses/{businessId}, ensuring clear ownership and access control.
 * Key Security Decisions:
 * - Users can only read and write their own profiles.
 * - Businesses can only manage their own business data, including Google My Business profiles, landing pages, automated posts, and internal feedback.
 * - Listing of users is disallowed for privacy.
 * - Read-only access is granted to public data like subscriptions.
 * - InternalFeedback is stored as a subcollection under businesses to maintain security and data locality, and is only accessible to authenticated users belonging to the business.
 * - All write operations require authentication.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if the authenticated user's ID matches the userId.
     * @deny (get, create, update, delete) if the authenticated user's ID does not match the userId.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows management of business information and subcollections.
     * @path /businesses/{businessId}
     */
    match /businesses/{businessId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }

      // Permisos del documento business
      allow get: if isOwner(businessId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isExistingOwner(businessId);
      allow delete: if isExistingOwner(businessId);

      // 🔥 WILDCARD: Permite acceso a CUALQUIER subcollection
      match /{subcollection}/{document=**} {
        allow read: if isSignedIn() && isOwner(businessId);
        allow write: if isSignedIn() && isOwner(businessId);
      }
    }

    /**
     * @description Allows access to GoogleMyBusinessProfile data, enforcing business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}
     * @allow (get, list) if true (public read).
     * @allow (create) if the authenticated user owns the business and the businessId matches.
     * @allow (update, delete) if the authenticated user owns the business.
     * @deny (create, update, delete) if the authenticated user does not own the business.
     * @principle Enforces business ownership for writes, allows public reads.
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if true;
      allow list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to Review data, nested under GoogleMyBusinessProfile, enforcing business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId}
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/reviews/{reviewId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if true;
      allow list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to AutomatedPost data, nested under GoogleMyBusinessProfile, enforcing business ownership.
     * @path /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId}
     */
    match /googleMyBusinessProfiles/{googleMyBusinessProfileId}/automatedPosts/{automatedPostId} {
      function isSignedIn() {
        return request.auth != null;
      }

      allow get: if true;
      allow list: if true;
      // TODO: Add owner validation once the schema is updated with an ownership field.
      allow create, update, delete: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows access to LandingPage data, nested under Business, enforcing business ownership.
     * @path /businesses/{businessId}/landingPages/{landingPageId}
     */
    match /businesses/{businessId}/landingPages/{landingPageId} {
        function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(businessId) {
        return request.auth.uid == businessId;
      }

      function isExistingOwner(businessId) {
        return isOwner(businessId) && resource != null;
      }
      allow get: if isSignedIn() && isOwner(businessId);
      allow list: if isSignedIn() && isOwner(businessId);
      allow create: if isSignedIn() && isOwner(businessId);
      allow update: if isSignedIn() && isExistingOwner(businessId);
      allow delete: if isSignedIn() && isExistingOwner(businessId);
    }

    /**
     * @description Allows public read access to subscription plan information.
     * @path /subscriptions/{subscriptionId}
     * @allow (get, list) if true (public read).
     * @deny (create, update, delete) always.
     * @principle Grants public read access to subscription data, disallows modifications.
     */
    match /subscriptions/{subscriptionId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}